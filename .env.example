# --- URL công khai (dùng khi build link return/cancel PayOS nếu không set PAYOS_RETURN_URL / PAYOS_CANCEL_URL)
# Thứ tự ưu tiên trong code: APP_PUBLIC_URL → FRONTEND_URL → APP_URL → http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000

# --- PayOS — https://my.payos.vn (chỉ placeholder trong repo; credential thật chỉ trong .env local)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Tuỳ chọn: base API merchant (mặc định SDK @payos/node dùng https://api-merchant.payos.vn)
# PAYOS_BASE_URL=https://api-merchant.payos.vn
# (alias) PAYOS_ENDPOINT=... — cùng ý nghĩa với PAYOS_BASE_URL trong src/config/payos.js

# Tuỳ chọn: return / cancel (code tự thêm ?orderId= hoặc &orderId=)
# Mặc định khi không set: {APP_PUBLIC_URL}/checkout/payos/return và .../cancel
# Route web: GET /checkout/payos/return|cancel (mặc định trong code) hoặc /payment/payos/... (alias cùng view)
# PAYOS_RETURN_URL=http://localhost:3000/checkout/payos/return
# PAYOS_CANCEL_URL=http://localhost:3000/checkout/payos/cancel

# Webhook (đăng ký trên PayOS Dashboard, không phải biến env):
#   POST {APP_PUBLIC_URL}/api/v1/webhooks/payos
# (routes: app /api → api/index /v1/webhooks → webhooks.route POST /payos)
# Local: cần tunnel (ngrok, cloudflared) nếu PayOS gọi từ internet.

# --- Email / JWT (nếu dùng trong dự án)
# EMAIL_USER=
# EMAIL_PASSWORD=
# FRONTEND_URL=http://localhost:3000
# JWT_SECRET=
