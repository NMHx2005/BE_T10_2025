doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= title || 'Xác thực'
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap", rel="stylesheet")
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css", rel="stylesheet")
    script(src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4")
    style.
      :root {
        --auth-accent: #f48525;
        --auth-accent-hover: #e07820;
        --auth-surface: rgba(255, 255, 255, 0.98);
      }
      body.auth-shell {
        font-family: 'DM Sans', system-ui, sans-serif;
        min-height: 100vh;
        background: #f4f5f7;
      }
      .auth-card {
        background: var(--auth-surface);
        border: 1px solid #dee1e6;
        box-shadow: 0 2px 8px rgba(34, 37, 42, 0.08);
      }
      .auth-input {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.75rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 0.9375rem;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .auth-input:focus {
        outline: none;
        border-color: var(--auth-accent);
        box-shadow: 0 0 0 3px rgba(244, 133, 37, 0.2);
      }
      .auth-input-standalone {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 0.9375rem;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .auth-input-standalone:focus {
        outline: none;
        border-color: var(--auth-accent);
        box-shadow: 0 0 0 3px rgba(244, 133, 37, 0.2);
      }
      .auth-btn-primary {
        width: 100%;
        padding: 0.875rem 1.25rem;
        border-radius: 0;
        font-weight: 600;
        font-size: 0.9375rem;
        color: #fff;
        background: #f48525;
        border: none;
        cursor: pointer;
        transition: background-color 0.15s, opacity 0.15s;
      }
      .auth-btn-primary:hover:not(:disabled) {
        background: #e07820;
      }
      .auth-btn-primary:disabled {
        opacity: 0.65;
        cursor: not-allowed;
      }
    block head

  body.auth-shell.flex.items-center.justify-center.p-4(class="sm:p-6")
    .relative.z-10.w-full.max-w-md
      block content
    include ../partials/notification

    block scripts
