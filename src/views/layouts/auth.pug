doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title= title || 'Xác thực'
    link(rel="preconnect", href="https://fonts.googleapis.com")
    link(rel="preconnect", href="https://fonts.gstatic.com", crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&display=swap", rel="stylesheet")
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css", rel="stylesheet")
    script(src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4")
    style.
      :root {
        --auth-accent: #4f46e5;
        --auth-accent-hover: #4338ca;
        --auth-surface: rgba(255, 255, 255, 0.92);
      }
      body.auth-shell {
        font-family: 'DM Sans', system-ui, sans-serif;
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 45%, #312e81 100%);
      }
      body.auth-shell::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 50% at 20% 40%, rgba(99, 102, 241, 0.35), transparent),
          radial-gradient(ellipse 60% 40% at 80% 60%, rgba(168, 85, 247, 0.25), transparent);
        pointer-events: none;
      }
      .auth-card {
        background: var(--auth-surface);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.2);
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.35);
      }
      .auth-input {
        width: 100%;
        padding: 0.75rem 1rem 0.75rem 2.75rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 0.9375rem;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .auth-input:focus {
        outline: none;
        border-color: var(--auth-accent);
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.2);
      }
      .auth-input-standalone {
        width: 100%;
        padding: 0.75rem 1rem;
        border: 1px solid #e2e8f0;
        border-radius: 0.75rem;
        font-size: 0.9375rem;
        transition: border-color 0.15s, box-shadow 0.15s;
      }
      .auth-input-standalone:focus {
        outline: none;
        border-color: var(--auth-accent);
        box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.2);
      }
      .auth-btn-primary {
        width: 100%;
        padding: 0.875rem 1.25rem;
        border-radius: 0.75rem;
        font-weight: 600;
        font-size: 0.9375rem;
        color: #fff;
        background: linear-gradient(135deg, #4f46e5, #7c3aed);
        border: none;
        cursor: pointer;
        transition: transform 0.15s, box-shadow 0.15s, opacity 0.15s;
      }
      .auth-btn-primary:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 10px 25px -5px rgba(79, 70, 229, 0.45);
      }
      .auth-btn-primary:disabled {
        opacity: 0.65;
        cursor: not-allowed;
      }
    block head

  body.auth-shell.flex.items-center.justify-center.p-4(class="sm:p-6")
    .relative.z-10.w-full.max-w-md
      block content

    block scripts
