doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(http-equiv="X-UA-Compatible", content="ie=edge")
    
    title= title || 'Product Management System'
    
    // Font Awesome CDN
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css", rel="stylesheet")
    
    // Tailwind CSS CDN
    script(src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4")
    
    // Custom CSS
    style.
      .btn-primary {
        @apply bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors duration-200;
      }
      .btn-secondary {
        @apply bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-colors duration-200;
      }
      .form-input {
        @apply w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent;
      }
    
    block head

  body.min-h-screen.flex.flex-col.bg-gray-50
    // Header
    include ../partials/navigation
    
    // Main Content
    main.flex-1
      block content
    
    // Footer
    include ../partials/footer
    
    // Global Notification
    include ../partials/notification
    script.
      (function () {
        try {
          var raw = sessionStorage.getItem('app:notice');
          if (!raw) return;
          sessionStorage.removeItem('app:notice');
          var notice = JSON.parse(raw);
          if (!window.AppNotify || !notice || !notice.type) return;
          if (notice.type === 'success') return window.AppNotify.success(notice.message || '', notice.title);
          if (notice.type === 'error') return window.AppNotify.error(notice.message || '', notice.title);
          if (notice.type === 'warning') return window.AppNotify.warning(notice.message || '', notice.title);
          window.AppNotify.info(notice.message || '', notice.title);
        } catch (e) {}
      })();
    
    // JavaScript
    // script(src="/js/main.js")
    
    block scripts