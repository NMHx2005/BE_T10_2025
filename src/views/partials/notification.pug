//- Global notification (Antd-like behavior, PRO-TOOLS visual style)
#app-notification-root.pointer-events-none.fixed.right-4.top-4(class="z-[1200]" aria-live="polite" aria-atomic="true")

style.
  .app-notification-stack {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: min(92vw, 380px);
  }
  .app-notification {
    pointer-events: auto;
    border: 1px solid #dee1e6;
    background: #fff;
    box-shadow: 0 8px 24px rgba(34, 37, 42, 0.12);
    overflow: hidden;
    transform: translateY(-8px);
    opacity: 0;
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .app-notification.show {
    transform: translateY(0);
    opacity: 1;
  }
  .app-notification-head {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 12px 8px;
  }
  .app-notification-icon {
    margin-top: 2px;
    font-size: 14px;
  }
  .app-notification-title {
    font-size: 14px;
    line-height: 1.3;
    font-weight: 700;
    color: #0d0d0d;
  }
  .app-notification-desc {
    font-size: 13px;
    line-height: 1.4;
    color: #323842;
    margin-top: 2px;
  }
  .app-notification-close {
    margin-left: auto;
    border: 0;
    background: transparent;
    color: #8c8f95;
    cursor: pointer;
    font-size: 13px;
    padding: 2px;
  }
  .app-notification-bar {
    height: 3px;
    width: 100%;
    transform-origin: left;
    animation: app-notify-shrink linear forwards;
  }
  @keyframes app-notify-shrink {
    from { transform: scaleX(1); }
    to { transform: scaleX(0); }
  }
  .app-notification.success .app-notification-icon { color: #0f9f53; }
  .app-notification.success .app-notification-bar { background: #0f9f53; }
  .app-notification.error .app-notification-icon { color: #dc2626; }
  .app-notification.error .app-notification-bar { background: #dc2626; }
  .app-notification.warning .app-notification-icon { color: #d97706; }
  .app-notification.warning .app-notification-bar { background: #d97706; }
  .app-notification.info .app-notification-icon { color: #f48525; }
  .app-notification.info .app-notification-bar { background: #f48525; }

script.
  (function () {
    if (window.AppNotify) return;

    var root = document.getElementById('app-notification-root');
    if (!root) return;

    var stack = document.createElement('div');
    stack.className = 'app-notification-stack';
    root.appendChild(stack);

    var iconMap = {
      success: 'fa-solid fa-circle-check',
      error: 'fa-solid fa-circle-xmark',
      warning: 'fa-solid fa-triangle-exclamation',
      info: 'fa-solid fa-circle-info'
    };

    function removeNotice(el) {
      if (!el) return;
      el.classList.remove('show');
      setTimeout(function () {
        if (el.parentNode) el.parentNode.removeChild(el);
      }, 180);
    }

    function notify(options) {
      var opts = options || {};
      var type = opts.type || 'info';
      var title = opts.title || (type === 'error' ? 'Có lỗi xảy ra' : 'Thông báo');
      var message = opts.message || '';
      var duration = Number(opts.duration);
      if (!Number.isFinite(duration) || duration <= 0) duration = 3000;

      var item = document.createElement('div');
      item.className = 'app-notification ' + type;
      item.setAttribute('role', 'status');
      item.innerHTML =
        '<div class="app-notification-head">' +
          '<i class="app-notification-icon ' + (iconMap[type] || iconMap.info) + '" aria-hidden="true"></i>' +
          '<div>' +
            '<div class="app-notification-title"></div>' +
            '<div class="app-notification-desc"></div>' +
          '</div>' +
          '<button class="app-notification-close" type="button" aria-label="Đóng">' +
            '<i class="fa-solid fa-xmark" aria-hidden="true"></i>' +
          '</button>' +
        '</div>' +
        '<div class="app-notification-bar"></div>';

      item.querySelector('.app-notification-title').textContent = title;
      item.querySelector('.app-notification-desc').textContent = message;
      item.querySelector('.app-notification-close').addEventListener('click', function () {
        removeNotice(item);
      });
      item.querySelector('.app-notification-bar').style.animationDuration = duration + 'ms';

      stack.prepend(item);
      requestAnimationFrame(function () {
        item.classList.add('show');
      });

      var timer = setTimeout(function () {
        removeNotice(item);
      }, duration);

      item.addEventListener('mouseenter', function () {
        clearTimeout(timer);
        item.querySelector('.app-notification-bar').style.animationPlayState = 'paused';
      });
      item.addEventListener('mouseleave', function () {
        item.querySelector('.app-notification-bar').style.animationPlayState = 'running';
      });

      return function closeNow() {
        clearTimeout(timer);
        removeNotice(item);
      };
    }

    window.AppNotify = {
      open: notify,
      success: function (message, title, duration) { return notify({ type: 'success', message: message, title: title || 'Thành công', duration: duration }); },
      error: function (message, title, duration) { return notify({ type: 'error', message: message, title: title || 'Thất bại', duration: duration }); },
      warning: function (message, title, duration) { return notify({ type: 'warning', message: message, title: title || 'Cảnh báo', duration: duration }); },
      info: function (message, title, duration) { return notify({ type: 'info', message: message, title: title || 'Thông tin', duration: duration }); }
    };

    var nativeAlert = window.alert;
    window.alert = function (msg) {
      if (window.AppNotify) window.AppNotify.info(String(msg || ''));
      else nativeAlert(msg);
    };
  })();

