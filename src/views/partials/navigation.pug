//- Header theo Figma: 81px, nền trắng ~95% + blur 4px, viền #dee1e6, accent #f48525
//- Các class có [...] đặt trong class="..." (Pug không parse được .max-w-[1440px])
- var path = typeof currentPath !== 'undefined' ? currentPath : '/'
- var isHome = path === '/' || path === ''
- var isProducts = path.indexOf('/products') === 0

nav#site-header.sticky.top-0.z-50(
  class="border-b border-[#dee1e6] bg-[rgba(255,255,255,0.95)] backdrop-blur-[4px]"
  role="navigation"
  aria-label="Thanh điều hướng chính"
)
  div(class="mx-auto max-w-[1440px] px-4 sm:px-8 lg:px-[128px]")
    div(class="flex h-[81px] items-center justify-between gap-4")
      //- Trái: logo + menu desktop
      .flex.min-w-0.flex-1.items-center(class="gap-6 lg:gap-10")
        a.flex.items-center.gap-2.shrink-0(href="/" class="min-w-0")
          div(class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[7px] bg-[#f48525]")
            i.fa-solid.fa-wrench.text-lg.text-white(aria-hidden="true")
          span.text-lg.font-semibold.tracking-tight(class="text-[#f48525]") PRO-TOOLS

        ul.hidden.items-center(class="lg:flex lg:gap-8")
          li
            a.text-sm.font-medium.transition-colors(
              href="/"
              class=isHome ? 'text-[#f48525] border-b-2 border-[#f48525] pb-1' : 'text-[#181b20] hover:text-[#f48525] border-b-2 border-transparent pb-1'
            ) Trang chủ
          li
            a.text-sm.font-medium.transition-colors(
              href="/products"
              class=isProducts ? 'text-[#f48525] border-b-2 border-[#f48525] pb-1' : 'text-[#181b20] hover:text-[#f48525] border-b-2 border-transparent pb-1'
            ) Sản phẩm
          li
            a.text-sm.font-medium.transition-colors(href="#" class="text-[#181b20] hover:text-[#f48525]") Bộ sưu tập
          li
            a.text-sm.font-medium.transition-colors(href="#" class="text-[#181b20] hover:text-[#f48525]") Blog
          li
            a.text-sm.font-medium.transition-colors(href="#" class="text-[#181b20] hover:text-[#f48525]") Liên hệ

      //- Phải: tìm kiếm + giỏ + avatar (tablet+)
      .hidden.items-center(class="md:flex md:gap-5")
        form.flex.items-center(action="/products" method="get" role="search" class="w-[255px] max-w-[36vw]")
          label.sr-only(for="header-search") Tìm sản phẩm
          .relative.w-full
            i.fa-solid.fa-magnifying-glass.pointer-events-none.absolute.left-3.text-sm(
              class="top-1/2 -translate-y-1/2 text-[#323842]"
              aria-hidden="true"
            )
            input#header-search.w-full.border.pl-10.pr-3.text-sm.outline-none.transition-shadow(
              type="search"
              name="q"
              placeholder="Tìm sản phẩm..."
              class="h-[39px] border-[#bdc2cb] text-[#323842] placeholder:text-[#323842]/80 focus:border-[#f48525] focus:ring-2 focus:ring-[#f48525]/25"
            )

        a#nav-cart-link.relative.inline-flex.transition-colors(
          href="/cart"
          class="text-[#181b20] hover:text-[#f48525]"
          aria-label="Giỏ hàng"
        )
          i.fa-solid.fa-bag-shopping.text-2xl(aria-hidden="true")
          span#nav-cart-badge.absolute.-top-1.min-h-5.min-w-5.rounded-full.px-1.text-center.text-xs.font-semibold.leading-5.text-white(
            class="left-[14px] bg-[#f48525]"
          ) 0

        .relative
          button#account-menu-button.relative.inline-flex.shrink-0.items-center.justify-center.overflow-hidden.rounded-full(
            type="button"
            class="h-9 w-9 bg-[#fbe7f8]"
            aria-label="Mở menu tài khoản"
            aria-expanded="false"
            aria-controls="account-dropdown"
          )
            i.fa-solid.fa-user.text-lg(class="text-[#181b20]" aria-hidden="true")
            span.absolute.bottom-0.right-0.rounded-full.border-white(
              class="h-[9px] w-[9px] border-[1.5px] bg-[#1dd75b]"
              aria-hidden="true"
            )
          #account-dropdown.hidden.absolute.right-0.top-12.w-56.overflow-hidden.border.bg-white(
            class="border-[#dee1e6] shadow-[0_8px_24px_rgba(34,37,42,0.12)]"
            role="menu"
            aria-labelledby="account-menu-button"
          )
            p#account-menu-greeting.px-4.py-3.text-xs.font-medium.uppercase.tracking-wide(
              class="bg-[#f9fafb] text-[#8c8f95]"
            ) Tài khoản
            ul#account-menu-list.py-1

      //- Mobile: icon tìm + menu
      .flex.items-center(class="md:hidden gap-3")
        a(href="/products" class="text-[#181b20]" aria-label="Tìm kiếm")
          i.fa-solid.fa-magnifying-glass.text-xl(aria-hidden="true")
        button#nav-mobile-toggle.inline-flex.items-center.justify-center.rounded-md.p-2.transition-colors(
          type="button"
          class="text-[#181b20] hover:bg-black/5"
          aria-expanded="false"
          aria-controls="mobile-nav-panel"
        )
          i.fa-solid.fa-bars.text-xl(aria-hidden="true")
          span.sr-only Mở menu

  //- Panel menu mobile
  #mobile-nav-panel.hidden.border-t.px-4.py-4.backdrop-blur-md(
    class="border-[#dee1e6] bg-[rgba(255,255,255,0.98)] lg:hidden"
  )
    form.mb-4(action="/products" method="get" role="search")
      label.sr-only(for="header-search-mobile") Tìm sản phẩm
      .relative
        i.fa-solid.fa-magnifying-glass.pointer-events-none.absolute.left-3.text-sm(class="top-1/2 -translate-y-1/2 text-[#323842]")
        input#header-search-mobile.w-full.border.pl-10.pr-3.text-sm(
          type="search"
          name="q"
          placeholder="Tìm sản phẩm..."
          class="h-[39px] border-[#bdc2cb] text-[#323842] focus:border-[#f48525] focus:outline-none focus:ring-2 focus:ring-[#f48525]/25"
        )
    ul.flex.flex-col.gap-1
      li
        a.block.py-2.text-sm.font-medium(href="/" class=isHome ? 'text-[#f48525]' : 'text-[#181b20]') Trang chủ
      li
        a.block.py-2.text-sm.font-medium(href="/products" class=isProducts ? 'text-[#f48525]' : 'text-[#181b20]') Sản phẩm
      li
        a.block.py-2.text-sm.font-medium(href="#" class="text-[#181b20]") Bộ sưu tập
      li
        a.block.py-2.text-sm.font-medium(href="#" class="text-[#181b20]") Blog
      li
        a.block.py-2.text-sm.font-medium(href="#" class="text-[#181b20]") Liên hệ
      li
        a.block.py-2.text-sm.font-medium(href="/order-tracking" class="text-[#181b20]") Tra cứu đơn
    .mt-4.flex.items-center.justify-between.border-t.pt-4(class="border-[#dee1e6]")
      a.flex.items-center.gap-2.text-sm.font-medium(href="/cart" class="text-[#181b20]")
        span.relative.inline-flex
          i.fa-solid.fa-bag-shopping.text-xl
          span#nav-mobile-cart-badge.absolute.-top-1.left-4.min-h-5.min-w-5.rounded-full.px-1.text-center.text-xs.font-semibold.leading-5.text-white(class="bg-[#f48525]") 0
        | Giỏ hàng
      button#mobile-account-toggle.flex.items-center.justify-center.rounded-full(
        type="button"
        class="h-9 w-9 bg-[#fbe7f8]"
        aria-label="Mở menu tài khoản"
        aria-expanded="false"
        aria-controls="mobile-account-dropdown"
      )
        i.fa-solid.fa-user(class="text-[#181b20]")
    #mobile-account-dropdown.hidden.mt-3.border.bg-white(
      class="border-[#dee1e6]"
    )
      p#mobile-account-greeting.px-4.py-3.text-xs.font-medium.uppercase.tracking-wide(
        class="bg-[#f9fafb] text-[#8c8f95]"
      ) Tài khoản
      ul#mobile-account-menu.py-1

script.
  (function () {
    var btn = document.getElementById('nav-mobile-toggle');
    var panel = document.getElementById('mobile-nav-panel');
    if (!btn || !panel) return;
    btn.addEventListener('click', function () {
      panel.classList.toggle('hidden');
      var open = !panel.classList.contains('hidden');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });

    var accountBtn = document.getElementById('account-menu-button');
    var accountDrop = document.getElementById('account-dropdown');
    var accountList = document.getElementById('account-menu-list');
    var accountGreeting = document.getElementById('account-menu-greeting');

    var mobileAccountBtn = document.getElementById('mobile-account-toggle');
    var mobileAccountDrop = document.getElementById('mobile-account-dropdown');
    var mobileAccountList = document.getElementById('mobile-account-menu');
    var mobileAccountGreeting = document.getElementById('mobile-account-greeting');

    function getAuthState() {
      var token = localStorage.getItem('accessToken');
      var rawUser = localStorage.getItem('user');
      var user = null;
      if (rawUser) {
        try {
          user = JSON.parse(rawUser);
        } catch (e) {
          user = null;
        }
      }
      return { token: token, user: user, loggedIn: !!token };
    }

    function itemHtml(item) {
      return (
        '<li>' +
          '<a class="flex items-center gap-3 px-4 py-2 text-sm text-[#181b20] transition-colors hover:bg-[#fff7ef] hover:text-[#f48525]" href="' + item.href + '"' +
          (item.action ? ' data-action="' + item.action + '"' : '') +
          '>' +
            '<i class="' + item.icon + ' text-sm" aria-hidden="true"></i>' +
            '<span>' + item.label + '</span>' +
          '</a>' +
        '</li>'
      );
    }

    function renderAccountMenus() {
      var state = getAuthState();
      var name = state.user && (state.user.username || state.user.email) ? (state.user.username || state.user.email) : 'Khách';
      var items = state.loggedIn
        ? [
            { href: '/profile', icon: 'fa-regular fa-user', label: 'Trang cá nhân' },
            { href: '/profile/orders', icon: 'fa-solid fa-bag-shopping', label: 'Đơn hàng của tôi' },
            { href: '/wishlist', icon: 'fa-regular fa-heart', label: 'Yêu thích' },
            { href: '/profile/addresses', icon: 'fa-solid fa-location-dot', label: 'Sổ địa chỉ' },
            { href: '/auth/logout', icon: 'fa-solid fa-right-from-bracket', label: 'Đăng xuất', action: 'logout' }
          ]
        : [
            { href: '/auth/login', icon: 'fa-solid fa-right-to-bracket', label: 'Đăng nhập' },
            { href: '/auth/register', icon: 'fa-solid fa-user-plus', label: 'Đăng ký tài khoản' }
          ];

      if (accountGreeting) accountGreeting.textContent = state.loggedIn ? ('Xin chào, ' + name) : 'Khách';
      if (mobileAccountGreeting) mobileAccountGreeting.textContent = state.loggedIn ? ('Xin chào, ' + name) : 'Khách';
      if (accountList) accountList.innerHTML = items.map(itemHtml).join('');
      if (mobileAccountList) mobileAccountList.innerHTML = items.map(itemHtml).join('');
    }

    function closeDesktopDropdown() {
      if (!accountDrop || !accountBtn) return;
      accountDrop.classList.add('hidden');
      accountBtn.setAttribute('aria-expanded', 'false');
    }

    function closeMobileDropdown() {
      if (!mobileAccountDrop || !mobileAccountBtn) return;
      mobileAccountDrop.classList.add('hidden');
      mobileAccountBtn.setAttribute('aria-expanded', 'false');
    }

    if (accountBtn && accountDrop) {
      accountBtn.addEventListener('click', function (e) {
        e.stopPropagation();
        accountDrop.classList.toggle('hidden');
        var open = !accountDrop.classList.contains('hidden');
        accountBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      document.addEventListener('click', function (e) {
        if (!accountDrop.contains(e.target) && !accountBtn.contains(e.target)) {
          closeDesktopDropdown();
        }
      });
    }

    if (mobileAccountBtn && mobileAccountDrop) {
      mobileAccountBtn.addEventListener('click', function () {
        mobileAccountDrop.classList.toggle('hidden');
        var open = !mobileAccountDrop.classList.contains('hidden');
        mobileAccountBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    }

    function handleMenuClick(e) {
      var link = e.target.closest('a[data-action]');
      if (!link) return;
      if (link.dataset.action === 'logout') {
        e.preventDefault();
        var state = getAuthState();
        fetch('/api/v1/auth/logout', {
          method: 'POST',
          headers: state.token ? { Authorization: 'Bearer ' + state.token } : {}
        }).catch(function () {});
        localStorage.removeItem('accessToken');
        localStorage.removeItem('refreshToken');
        localStorage.removeItem('user');
        closeDesktopDropdown();
        closeMobileDropdown();
        window.location.href = '/auth/login';
      }
    }

    if (accountList) accountList.addEventListener('click', handleMenuClick);
    if (mobileAccountList) mobileAccountList.addEventListener('click', handleMenuClick);

    function updateCartBadges() {
      var n = window.ProToolsStore ? window.ProToolsStore.cartCount() : 0;
      var t = n > 99 ? '99+' : String(n);
      var b = document.getElementById('nav-cart-badge');
      var m = document.getElementById('nav-mobile-cart-badge');
      if (b) b.textContent = t;
      if (m) m.textContent = t;
    }

    window.addEventListener('protools-cart-updated', updateCartBadges);
    renderAccountMenus();
    updateCartBadges();
  })();
