extends ../../layouts/admin

block content
  .mb-8.border.bg-white.p-6(class="border-[#dee1e6]")
    .flex.items-center.gap-4
      a.text-blue-600(class="hover:text-blue-700" href="/admin/users")
        i.fas.fa-arrow-left.text-xl
      .flex.flex-col
        p.text-xs.uppercase.tracking-widest(class="text-[#8c8f95]") User Profile
        h1.text-3xl.font-bold(class="text-[#0d0d0d]")= 'Chi tiết: ' + (user && user.username ? user.username : '')
        p.text-gray-600.mt-2= user && user.email ? user.email : ''

  .grid.grid-cols-1(class="lg:grid-cols-3 gap-6")
    .col-span-1(class="lg:col-span-2")
      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-6 Thông tin tài khoản

        form.space-y-4#user-form
          .grid.grid-cols-1(class="md:grid-cols-2 gap-4")
            .form-group
              label.block.text-sm.font-medium.text-gray-700.mb-2(for="username") Username
              input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
                class="focus:ring-2 focus:ring-blue-500"
                type="text"
                id="username"
                name="username"
                value=user && user.username ? user.username : ''
                required
              )

            .form-group
              label.block.text-sm.font-medium.text-gray-700.mb-2(for="email") Email
              input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg.bg-gray-50(
                class="focus:ring-2 focus:ring-blue-500"
                type="email"
                id="email"
                name="email"
                value=user && user.email ? user.email : ''
                disabled
              )
              p.text-xs.text-gray-500.mt-1 Email không đổi qua form này

          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-2(for="phone") Điện thoại
            input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
              class="focus:ring-2 focus:ring-blue-500"
              type="tel"
              id="phone"
              name="phone"
              value=user && user.phone ? user.phone : ''
              placeholder="0xxxxxxxxx"
            )

          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-2(for="avatar") Avatar (URL)
            input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
              class="focus:ring-2 focus:ring-blue-500"
              type="url"
              id="avatar"
              name="avatar"
              value=user && user.avatar ? user.avatar : ''
              placeholder="https://..."
            )

          .grid.grid-cols-1(class="md:grid-cols-2 gap-4")
            .form-group
              label.block.text-sm.font-medium.text-gray-700.mb-2(for="role") Vai trò
              select.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
                class="focus:ring-2 focus:ring-blue-500"
                id="role"
                name="role"
              )
                option(value="user" selected=user && user.role === 'user') User
                option(value="admin" selected=user && user.role === 'admin') Admin

            .form-group
              label.block.text-sm.font-medium.text-gray-700.mb-2(for="status") Trạng thái
              select.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
                class="focus:ring-2 focus:ring-blue-500"
                id="status"
                name="status"
              )
                option(value="active" selected=user && user.status === 'active') Active
                option(value="inactive" selected=user && user.status === 'inactive') Inactive

          .flex.gap-3.justify-end.pt-4.border-t
            button.px-4.py-2.border.border-gray-300.rounded-lg.text-gray-700.font-medium.transition-colors(
              class="hover:bg-gray-50"
              type="button"
              onclick="location.href='/admin/users'"
            ) Hủy

            button.px-4.py-2.text-white.rounded-lg.font-medium.transition-colors(
              class="bg-blue-600 hover:bg-blue-700"
              type="submit"
            )
              i.fas.fa-save.mr-2
              | Lưu

      .bg-white.p-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Đơn hàng gần đây

        if user.recentOrders && user.recentOrders.length > 0
          .space-y-3
            each order in user.recentOrders
              .flex.items-center.justify-between.p-4.border-b(class="last:border-b-0")
                .flex-1
                  p.font-medium.text-gray-900= order.orderNumber || order._id
                  p.text-sm.text-gray-500= order.createdAt ? new Date(order.createdAt).toLocaleString('vi-VN') : ''
                .flex.items-center.gap-4
                  .text-right
                    p.font-medium.text-gray-900
                      = (order.total != null ? Number(order.total) : 0).toLocaleString('vi-VN') + ' ₫'
                    span.inline-block.px-3.py-1.text-xs.font-medium.rounded-full(
                      class={
                        'pending': 'bg-yellow-100 text-yellow-800',
                        'confirmed': 'bg-blue-100 text-blue-800',
                        'processing': 'bg-purple-100 text-purple-800',
                        'shipped': 'bg-indigo-100 text-indigo-800',
                        'delivered': 'bg-green-100 text-green-800',
                        'cancelled': 'bg-red-100 text-red-800'
                      }[order.status] || 'bg-gray-100 text-gray-800'
                    )= order.status
                  a.text-blue-600(class="hover:text-blue-700" href=`/admin/orders/${order._id}`)
                    i.fas.fa-eye
        else
          p.text-gray-500.text-center.py-4 Chưa có đơn hàng

    .col-span-1
      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Trạng thái

        .space-y-4
          .flex.items-center.justify-between.pb-4.border-b
            .flex.flex-col
              span.text-sm.font-medium.text-gray-700 Vai trò
            span.inline-block.px-3.py-1.text-sm.font-medium.rounded-full(
              class=user.role === 'admin' ? 'bg-red-100 text-red-800' : 'bg-gray-100 text-gray-800'
            )= user.role === 'admin' ? 'Admin' : 'User'

          .flex.items-center.justify-between.pb-4.border-b
            .flex.flex-col
              span.text-sm.font-medium.text-gray-700 Trạng thái
            span.inline-block.px-3.py-1.text-sm.font-medium.rounded-full(
              class=user.status === 'active' ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-800'
            )= user.status === 'active' ? 'Active' : 'Inactive'

          .flex.items-center.justify-between
            .flex.flex-col
              span.text-sm.font-medium.text-gray-700 Tham gia
            span.text-gray-900.font-medium
              = user.createdAt ? new Date(user.createdAt).toLocaleDateString('vi-VN') : '—'

      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Thống kê

        .space-y-4
          .p-4.bg-blue-50.rounded-lg
            p.text-sm.text-gray-600 Tổng đơn
            p.text-2xl.font-bold.text-blue-600= user.totalOrders != null ? user.totalOrders : 0

          .p-4.bg-green-50.rounded-lg
            p.text-sm.text-gray-600 Tổng chi
            p.text-2xl.font-bold.text-green-600
              = (user.totalSpent != null ? Number(user.totalSpent) : 0).toLocaleString('vi-VN') + ' ₫'

      .bg-white.p-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Thao tác nhanh

        .space-y-3
          button.w-full.px-4.py-2.text-center.bg-red-100.text-red-800.rounded-lg.font-medium.transition-colors(
            class="hover:bg-red-200"
            type="button"
            id="btn-delete-user"
          )
            i.fas.fa-user-slash.mr-2
            | Vô hiệu hóa tài khoản

block scripts
  script.
    (function () {
      var userId = !{JSON.stringify(user && user._id ? String(user._id) : '')};
      var form = document.getElementById('user-form');

      function getToken() {
        return localStorage.getItem('accessToken') || '';
      }

      function getSelfId() {
        try {
          var u = JSON.parse(localStorage.getItem('user') || 'null');
          return u && u._id ? String(u._id) : '';
        } catch (e) {
          return '';
        }
      }

      async function saveUser(body) {
        var token = getToken();
        if (!token) {
          if (window.AppNotify) window.AppNotify.warning('Vui lòng đăng nhập admin.');
          window.location.href = '/auth/login';
          return;
        }
        var res = await fetch('/api/v1/users/' + encodeURIComponent(userId), {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            Authorization: 'Bearer ' + token,
          },
          body: JSON.stringify(body),
        });
        var data = await res.json().catch(function () {
          return {};
        });
        if (!res.ok) {
          throw new Error(data.message || 'Cập nhật thất bại.');
        }
        return data;
      }

      if (form) {
        form.addEventListener('submit', async function (e) {
          e.preventDefault();
          try {
            var body = {
              username: document.getElementById('username').value.trim(),
              phone: document.getElementById('phone').value.trim(),
              role: document.getElementById('role').value,
              status: document.getElementById('status').value,
              avatar: document.getElementById('avatar').value.trim(),
            };
            var data = await saveUser(body);
            if (window.AppNotify) window.AppNotify.success(data.message || 'Đã lưu.');
            setTimeout(function () {
              window.location.reload();
            }, 400);
          } catch (err) {
            if (window.AppNotify) window.AppNotify.error(err.message || 'Lỗi.');
          }
        });
      }

      var btnDel = document.getElementById('btn-delete-user');
      if (btnDel) {
        btnDel.addEventListener('click', async function () {
          if (getSelfId() === userId) {
            if (window.AppNotify) window.AppNotify.warning('Không thể vô hiệu hóa chính tài khoản đang đăng nhập.');
            return;
          }
          if (!confirm('Vô hiệu hóa tài khoản này? (inactive — giữ dữ liệu trong hệ thống.)')) return;
          var token = getToken();
          if (!token) {
            if (window.AppNotify) window.AppNotify.warning('Vui lòng đăng nhập admin.');
            return;
          }
          try {
            var res = await fetch('/api/v1/users/' + encodeURIComponent(userId), {
              method: 'DELETE',
              headers: { Authorization: 'Bearer ' + token },
            });
            var data = await res.json().catch(function () {
              return {};
            });
            if (!res.ok) {
              throw new Error(data.message || 'Thao tác thất bại.');
            }
            if (window.AppNotify) window.AppNotify.success(data.message || 'Đã vô hiệu hóa.');
            window.location.href = '/admin/users';
          } catch (err) {
            if (window.AppNotify) window.AppNotify.error(err.message || 'Lỗi.');
          }
        });
      }
    })();
