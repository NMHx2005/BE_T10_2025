extends ../../layouts/admin
include ../../mixins/cards
include ../../mixins/buttons

block content
  - const __filters = filters || {}
  - const __search = __filters.search || ''
  - const __category = __filters.category || ''
  - const __status = __filters.status || ''
  - const __querySuffix = (function(){ const p = []; if (__search) p.push('search=' + encodeURIComponent(__search)); if (__category) p.push('category=' + encodeURIComponent(__category)); if (__status) p.push('status=' + encodeURIComponent(__status)); return p.length ? '&' + p.join('&') : ''; })()
  // Page Header
  .mb-8.border.bg-white.p-6(class="border-[#dee1e6]")
    .flex.items-center.justify-between
      .flex.flex-col
        p.text-xs.uppercase.tracking-widest(class="text-[#8c8f95]") Catalog
        h1.text-3xl.font-bold(class="text-[#0d0d0d]") Products Management
        p.mt-2(class="text-[#5f6673]") Total: 
          span.font-semibold #{totalProducts || 0}
          |  products
      
      a.text-white.font-medium.py-2.px-6.transition-colors.flex.items-center.gap-2(class="bg-[#f48525] hover:bg-[#e07820]"
        href="/admin/products/create"
      )
        i.fas.fa-plus.mr-2
        | Add Product

  // Filters & Search
  .bg-white.p-6.mb-6
    .grid.grid-cols-1(class="md:grid-cols-4 gap-4")
      .form-group
        input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
          class="focus:ring-2 focus:ring-blue-500"
          type="text",
          placeholder="Search products...",
          id="search-input",
          value=__search
        )
      
      select.form-input.px-4.py-2.border.border-gray-300.rounded-lg(
        class="focus:ring-2 focus:ring-blue-500"
        id="category-filter"
      )
        option(value="") All Categories
        if categories && categories.length > 0
          each category in categories
            option(value=category._id)
              = category.name
      
      select.form-input.px-4.py-2.border.border-gray-300.rounded-lg(
        class="focus:ring-2 focus:ring-blue-500"
        id="status-filter"
      )
        option(value="") All Status
        option(value="active") Active
        option(value="draft") Draft
        option(value="inactive") Inactive
        option(value="archived") Archived
        option(value="deleted") Đã xóa mềm
      
      button#apply-filter-btn.bg-blue-600.text-white.font-medium.py-2.px-4.rounded-lg.transition-colors(
        class="hover:bg-blue-700"
        type="button",
        onclick="applyFilters()"
      )
        i.fas.fa-filter.mr-2
        | Apply Filters

  // Products Table
  if products && products.length > 0
    .bg-white.overflow-hidden
      .overflow-x-auto
        table.w-full
          thead.bg-gray-100.border-b.border-gray-200
            tr
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Product Name
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Category
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Stock
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Status
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Views
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Created
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Actions
          
          tbody.divide-y.divide-gray-200
            each product in products
              -
                var __isSoftDeleted = product.deleted === true || product.status === 'deleted'
              tr.transition-colors(class=__isSoftDeleted ? "hover:bg-gray-50 bg-red-50/40 opacity-90" : "hover:bg-gray-50")
                // Product Name
                td.px-6.py-4
                  .flex.items-center.gap-3
                    - const __thumb = (product.images && product.images[0]) || (product.variants && product.variants[0] && product.variants[0].images && product.variants[0].images[0])
                    if __thumb
                      img.w-10.h-10.rounded.object-cover(src=__thumb, alt=product.name)
                    else
                      .w-10.h-10.rounded.bg-gray-200.flex.items-center.justify-center
                        i.fas.fa-image.text-gray-400.text-xs
                    .flex.flex-col
                      p.font-medium.text-gray-900.truncate
                        = product.name
                      p.text-xs.text-gray-500
                        = (product.variants && product.variants[0] && product.variants[0].sku) || '—'
                
                // Category
                td.px-6.py-4.text-sm.text-gray-600
                  = (product.category && product.category.name) || 'Uncategorized'
                
                // Stock (tổng tồn theo variants — virtual totalStock)
                - const __stock = typeof product.totalStock === 'number' ? product.totalStock : (product.variants || []).reduce((s, v) => s + (Number(v.stock) || 0), 0)
                td.px-6.py-4.text-sm
                  span(class={
                    'text-green-600': __stock > 10,
                    'text-yellow-600': __stock <= 10 && __stock > 0,
                    'text-red-600': __stock === 0
                  })
                    = __stock
                
                // Status
                td.px-6.py-4
                  span.px-2.py-1.rounded-full.text-xs.font-semibold(class={
                    'bg-red-100 text-red-800': __isSoftDeleted,
                    'bg-green-100 text-green-800': product.status === 'active' && !__isSoftDeleted,
                    'bg-yellow-100 text-yellow-800': product.status === 'draft' && !__isSoftDeleted,
                    'bg-gray-100 text-gray-800': (product.status === 'archived' || product.status === 'inactive') && !__isSoftDeleted
                  })
                    = __isSoftDeleted ? 'deleted' : (product.status || '—')
                
                // Views
                td.px-6.py-4.text-sm.text-gray-600
                  = product.viewCount || 0
                
                // Created Date
                td.px-6.py-4.text-sm.text-gray-600
                  = new Date(product.createdAt).toLocaleDateString()
                
                // Actions
                td.px-6.py-4.text-sm.flex.gap-2
                  if !__isSoftDeleted
                    a.text-blue-600.transition-colors.px-2.py-1(class="hover:text-blue-700"
                      href=`/admin/products/${product._id}`,
                      title="Sửa"
                    )
                      i.fas.fa-edit
                    
                    a.text-gray-600.transition-colors.px-2.py-1(class="hover:text-gray-700"
                      href=`/products/${product.slug || product._id}`,
                      target="_blank",
                      title="Xem trên site"
                    )
                      i.fas.fa-external-link-alt
                    
                    button.text-red-600.transition-colors.px-2.py-1(class="hover:text-red-700"
                      type="button",
                      onclick=`softDeleteProduct('${product._id}')`,
                      title="Xóa mềm (ẩn khỏi kho)"
                    )
                      i.fas.fa-trash
                  else
                    button.text-emerald-700.transition-colors.px-2.py-1(class="hover:text-emerald-900"
                      type="button",
                      onclick=`restoreProduct('${product._id}')`,
                      title="Khôi phục sản phẩm"
                    )
                      i.fas.fa-rotate-left

      // Pagination
      if pagination && pagination.pages > 1
        - const currentPage = Number(pagination.current || pagination.page || 1)
        - const limit = Number(pagination.limit || 10)
        - const total = Number(pagination.total || 0)
        .bg-gray-50.px-6.py-4.flex.justify-between.items-center
          p.text-sm.text-gray-600
            | Showing 
            span.font-semibold= total > 0 ? ((currentPage - 1) * limit + 1) : 0
            |  to 
            span.font-semibold= Math.min(currentPage * limit, total)
            |  of 
            span.font-semibold= total
          
          .flex.gap-2
            if currentPage > 1
              a.px-3.py-2.border.border-gray-300.rounded.text-gray-700(class="hover:bg-gray-100"
                href=`/admin/products?page=${currentPage - 1}${__querySuffix}`
              )
                i.fas.fa-chevron-left
            
            each i in [...Array(pagination.pages).keys()].map(x => x + 1)
              if i === currentPage
                .px-3.py-2.bg-blue-600.text-white.rounded
                  = i
              else if i === 1 || i === pagination.pages || (i >= currentPage - 1 && i <= currentPage + 1)
                a.px-3.py-2.border.border-gray-300.rounded.text-gray-700(class="hover:bg-gray-100"
                  href=`/admin/products?page=${i}${__querySuffix}`
                )
                  = i
            
            if currentPage < pagination.pages
              a.px-3.py-2.border.border-gray-300.rounded.text-gray-700(class="hover:bg-gray-100"
                href=`/admin/products?page=${currentPage + 1}${__querySuffix}`
              )
                i.fas.fa-chevron-right
  else
    // No Products
    .bg-white.p-12.text-center
      i.fas.fa-box.text-gray-400.text-5xl.mb-4
      h3.text-xl.font-semibold.text-gray-900.mb-2 No Products Found
      p.text-gray-600.mb-6 Start by creating your first product
      a.inline-block.text-white.font-medium.py-2.px-6.transition-colors(class="bg-[#f48525] hover:bg-[#e07820]"
        href="/admin/products/create"
      )
        i.fas.fa-plus.mr-2
        | Create Product

block scripts
  script.
    function getAdminToken() {
      return localStorage.getItem('accessToken') || '';
    }

    async function softDeleteProduct(productId) {
      if (!confirm('Xóa mềm sản phẩm? (Ẩn khỏi catalog — có thể khôi phục sau.)')) return;
      var token = getAdminToken();
      if (!token) {
        if (window.AppNotify) window.AppNotify.warning('Vui lòng đăng nhập admin.');
        window.location.href = '/auth/login';
        return;
      }
      try {
        var res = await fetch('/api/v1/products/' + encodeURIComponent(productId), {
          method: 'DELETE',
          headers: { Authorization: 'Bearer ' + token },
        });
        var data = await res.json().catch(function () { return {}; });
        if (!res.ok) throw new Error(data.message || 'Không thể xóa mềm.');
        if (window.AppNotify) window.AppNotify.success(data.message || 'Đã xóa mềm.');
        setTimeout(function () { window.location.reload(); }, 400);
      } catch (err) {
        if (window.AppNotify) window.AppNotify.error(err.message || 'Có lỗi xảy ra.');
      }
    }

    async function restoreProduct(productId) {
      if (!confirm('Khôi phục sản phẩm này về trạng thái active?')) return;
      var token = getAdminToken();
      if (!token) {
        if (window.AppNotify) window.AppNotify.warning('Vui lòng đăng nhập admin.');
        window.location.href = '/auth/login';
        return;
      }
      try {
        var res = await fetch('/api/v1/products/' + encodeURIComponent(productId) + '/restore', {
          method: 'PATCH',
          headers: { Authorization: 'Bearer ' + token },
        });
        var data = await res.json().catch(function () { return {}; });
        if (!res.ok) throw new Error(data.message || 'Không thể khôi phục.');
        if (window.AppNotify) window.AppNotify.success(data.message || 'Đã khôi phục.');
        setTimeout(function () { window.location.reload(); }, 400);
      } catch (err) {
        if (window.AppNotify) window.AppNotify.error(err.message || 'Có lỗi xảy ra.');
      }
    }

    function applyFilters() {
      var searchInput = document.getElementById('search-input');
      var categorySelect = document.getElementById('category-filter');
      var statusSelect = document.getElementById('status-filter');
      var search = searchInput ? searchInput.value : '';
      var category = categorySelect ? categorySelect.value : '';
      var status = statusSelect ? statusSelect.value : '';
      
      var params = new URLSearchParams();
      if (search && search.trim()) params.set('search', search.trim());
      if (category) params.set('category', category);
      if (status) params.set('status', status);
      
      window.location.href = '/admin/products' + (params.toString() ? ('?' + params.toString()) : '');
    }

    (function initFilters() {
      var categorySelect = document.getElementById('category-filter');
      var statusSelect = document.getElementById('status-filter');
      if (categorySelect) categorySelect.value = !{JSON.stringify(__category)};
      if (statusSelect) statusSelect.value = !{JSON.stringify(__status)};

      var searchInput = document.getElementById('search-input');
      var applyBtn = document.getElementById('apply-filter-btn');
      if (applyBtn) {
        applyBtn.addEventListener('click', function (e) {
          e.preventDefault();
          applyFilters();
        });
      }
      if (searchInput) {
        searchInput.addEventListener('keydown', function (e) {
          if (e.key === 'Enter') {
            e.preventDefault();
            applyFilters();
          }
        });
      }

      window.applyFilters = applyFilters;
    })();
