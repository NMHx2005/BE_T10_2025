extends ../../layouts/admin

block content
  -
    function vnd(n) {
      if (n == null || Number.isNaN(Number(n))) return '—'
      return new Intl.NumberFormat('vi-VN').format(Math.round(Number(n))) + '₫'
    }
    function lineImg(prod) {
      if (!prod || !prod.images || !prod.images.length) return null
      var x = prod.images[0]
      if (typeof x === 'string') return x.trim() || null
      if (x && typeof x.url === 'string') return x.url.trim() || null
      return null
    }

  // Page Header
  .mb-8.border.bg-white.p-6(class="border-[#dee1e6]")
    .flex.items-center.gap-4
      a.text-blue-600(class="hover:text-blue-700" href="/admin/orders")
        i.fas.fa-arrow-left.text-xl
      .flex.flex-col
        p.text-xs.uppercase.tracking-widest(class="text-[#8c8f95]") Chi tiết đơn
        h1.text-3xl.font-bold(class="text-[#0d0d0d]")
          = 'Đơn ' + order.orderNumber
        p.text-gray-600.mt-2
          = 'Đặt lúc ' + new Date(order.createdAt).toLocaleString('vi-VN')

  .grid.grid-cols-1(class="lg:grid-cols-3 gap-6")
    .col-span-1(class="lg:col-span-2")
      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Sản phẩm

        .space-y-4
          if order.items && order.items.length > 0
            each item in order.items
              - var thumb = lineImg(item.product)
              .flex.items-center.justify-between.p-4.border.border-gray-200.rounded-lg
                .flex.items-center.gap-4
                  if thumb
                    img.w-16.h-16.rounded.object-cover(src=thumb, alt=(item.product && item.product.name) || '')
                  else
                    .w-16.h-16.rounded.bg-gray-200.flex.items-center.justify-center
                      i.fas.fa-image.text-gray-400
                  .flex-1
                    p.font-medium.text-gray-900= (item.product && item.product.name) || (item.productName || 'Sản phẩm')
                    if item.variant && item.variant.name
                      p.text-sm.text-gray-600= 'Biến thể: ' + item.variant.name
                    p.text-sm.text-gray-500
                      = 'SL: ' + item.quantity + ' × ' + vnd(item.price)
                .text-right
                  p.font-bold.text-gray-900= vnd(item.subtotal != null ? item.subtotal : (item.quantity || 0) * (item.price || 0))

            .border-t.pt-4.mt-4
              .flex.justify-between.mb-2
                span.text-gray-700 Tạm tính
                span.font-medium= vnd(order.subtotal)
              .flex.justify-between.mb-2
                span.text-gray-700 Phí giao hàng
                span.font-medium= vnd(order.shippingFee)
              .flex.justify-between.mb-2
                span.text-gray-700 Thuế
                span.font-medium= vnd(order.tax)
              if order.discount > 0
                .flex.justify-between.mb-2
                  span.text-gray-700 Giảm giá
                  span.font-medium.text-emerald-700= '− ' + vnd(order.discount)
              .flex.justify-between.text-lg.font-bold.text-gray-900.pt-2.border-t
                span Tổng cộng
                span= vnd(order.total)
          else
            p.text-gray-500.text-center.py-4 Không có dòng sản phẩm

      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Địa chỉ giao hàng
        if order.shippingAddress && (order.shippingAddress.fullName || order.shippingAddress.address)
          .p-4.bg-gray-50.rounded-lg
            p.font-medium.text-gray-900= order.shippingAddress.fullName || ''
            if order.shippingAddress.address
              p.text-gray-700= order.shippingAddress.address
            p.text-gray-700
              = [order.shippingAddress.ward, order.shippingAddress.district, order.shippingAddress.city].filter(Boolean).join(', ')
            p.text-gray-600.mt-2
              = 'Điện thoại: ' + (order.shippingAddress.phone || '—')
            if order.shippingAddress.note
              p.text-gray-600.mt-2= 'Ghi chú: ' + order.shippingAddress.note
        else
          p.text-gray-500 Chưa có địa chỉ

      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Địa chỉ thanh toán
        if order.billingAddress && (order.billingAddress.fullName || order.billingAddress.address)
          .p-4.bg-gray-50.rounded-lg
            p.font-medium.text-gray-900= order.billingAddress.fullName || ''
            if order.billingAddress.address
              p.text-gray-700= order.billingAddress.address
            p.text-gray-700
              = [order.billingAddress.ward, order.billingAddress.district, order.billingAddress.city].filter(Boolean).join(', ')
            p.text-gray-600.mt-2= 'Điện thoại: ' + (order.billingAddress.phone || '—')
        else
          p.text-gray-500 Giống địa chỉ giao hàng

      .bg-white.p-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Trạng thái xử lý
        if order.status === 'cancelled' || order.status === 'refunded'
          p.text-sm.text-red-700.font-medium Đơn đã hủy / hoàn tiền — không hiển thị timeline.
        else
          - const flow = ['pending', 'confirmed', 'processing', 'shipped', 'delivered']
          - const idxCur = flow.indexOf(order.status)
          ul.space-y-3
            each st, i in flow
              li.flex.items-center.gap-3
                span.w-8.h-8.rounded-full.flex.items-center.justify-center.text-xs.font-bold(
                  class=(idxCur >= 0 && i < idxCur) ? 'bg-emerald-600 text-white' : (i === idxCur) ? 'bg-blue-600 text-white' : 'bg-gray-200 text-gray-600'
                )= i + 1
                span.text-sm.font-medium.text-gray-800.capitalize= st

    .col-span-1
      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Cập nhật trạng thái
        form.space-y-3#status-form
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="detail-status") Trạng thái đơn
          select#detail-status.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500",
            name="status"
          )
            option(value="pending", selected=order.status === 'pending') Chờ xác nhận
            option(value="confirmed", selected=order.status === 'confirmed') Đã xác nhận
            option(value="processing", selected=order.status === 'processing') Đang xử lý
            option(value="shipped", selected=order.status === 'shipped') Đang giao
            option(value="delivered", selected=order.status === 'delivered') Đã giao
            option(value="cancelled", selected=order.status === 'cancelled') Đã hủy
            option(value="refunded", selected=order.status === 'refunded') Hoàn tiền
          button.w-full.px-4.py-2.text-white.rounded-lg.font-medium.transition-colors(
            class="bg-[#f48525] hover:bg-[#e07820]",
            type="submit"
          )
            i.fas.fa-save.mr-2
            | Lưu

        .p-4.mt-4.rounded-lg(
          class={
            'pending': 'bg-yellow-50 border border-yellow-200',
            'confirmed': 'bg-blue-50 border border-blue-200',
            'processing': 'bg-purple-50 border border-purple-200',
            'shipped': 'bg-indigo-50 border border-indigo-200',
            'delivered': 'bg-green-50 border border-green-200',
            'cancelled': 'bg-red-50 border border-red-200',
            'refunded': 'bg-gray-50 border border-gray-200'
          }[order.status] || 'bg-gray-50 border border-gray-200'
        )
          p.text-sm.font-medium.text-gray-800
            = 'Hiện tại: ' + (order.status || '—')

      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Vận chuyển
        if order.shipping && (order.shipping.trackingNumber || order.shipping.carrier)
          .space-y-3.text-sm
            if order.shipping.trackingNumber
              .flex.justify-between
                span.text-gray-600 Mã vận đơn
                span.font-mono.font-medium= order.shipping.trackingNumber
            if order.shipping.carrier
              .flex.justify-between
                span.text-gray-600 Đơn vị
                span= order.shipping.carrier
            if order.shipping.estimatedDelivery
              .flex.justify-between
                span.text-gray-600 Dự kiến
                span= new Date(order.shipping.estimatedDelivery).toLocaleDateString('vi-VN')
        else
          p.text-gray-500.text-sm Chưa có thông tin vận chuyển

      .bg-white.p-6.mb-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Thanh toán
        .space-y-3.text-sm
          .flex.justify-between
            span.text-gray-600 Số tiền
            span.font-bold.text-gray-900= vnd(order.total)
          .flex.justify-between
            span.text-gray-600 Phương thức
            span.font-medium= order.payment && order.payment.method ? order.payment.method : '—'
          .flex.justify-between.items-center
            span.text-gray-600 Trạng thái TT
            span.px-2.py-1.rounded-full.text-xs.font-semibold(
              class=(order.payment && order.payment.status === 'paid') ? 'bg-green-100 text-green-800' : (order.payment && order.payment.status === 'failed') ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800'
            )
              = order.payment && order.payment.status ? order.payment.status : '—'

      .bg-white.p-6
        h2.text-xl.font-semibold.text-gray-900.mb-4 Khách hàng
        if order.customer && order.customer._id
          a.block.p-3.bg-gray-50(class="hover:bg-gray-100 rounded-lg transition-colors" href=`/admin/users/${order.customer._id}`)
            p.font-medium.text-gray-900= order.customer.username || '—'
            p.text-sm.text-gray-600= order.customer.email || '—'
            p.text-sm.text-gray-500.mt-1
              i.fas.fa-arrow-right.mr-1
              | Xem hồ sơ
        else
          p.text-gray-500 Không gắn tài khoản

block scripts
  script.
    (function () {
      var form = document.getElementById('status-form');
      if (!form) return;
      var orderId = !{JSON.stringify(order && order._id ? String(order._id) : '')};
      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var token = localStorage.getItem('accessToken') || '';
        if (!token) {
          if (window.AppNotify) window.AppNotify.warning('Vui lòng đăng nhập admin.');
          window.location.href = '/auth/login';
          return;
        }
        var sel = document.getElementById('detail-status');
        var newStatus = sel ? sel.value : '';
        var body = { status: newStatus };
        if (newStatus === 'shipped') {
          var track = window.prompt('Mã vận đơn (bắt buộc):', '');
          if (!track || !track.trim()) {
            if (window.AppNotify) window.AppNotify.warning('Cần mã vận đơn.');
            return;
          }
          body.trackingNumber = track.trim();
        }
        try {
          var res = await fetch('/api/v1/orders/' + encodeURIComponent(orderId), {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
              Authorization: 'Bearer ' + token
            },
            body: JSON.stringify(body)
          });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) throw new Error(data.message || 'Cập nhật thất bại.');
          if (window.AppNotify) window.AppNotify.success('Đã lưu trạng thái.');
          window.location.reload();
        } catch (err) {
          if (window.AppNotify) window.AppNotify.error(err.message || 'Lỗi');
        }
      });
    })();
