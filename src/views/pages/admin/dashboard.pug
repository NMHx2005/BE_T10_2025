extends ../../layouts/admin
include ../../mixins/cards
include ../../mixins/buttons

block content
  .mb-8.border.bg-white.p-6(class="border-[#dee1e6]")
    .flex.flex-col.gap-4(class="lg:flex-row lg:items-center lg:justify-between")
      .space-y-2
        p.text-xs.uppercase(class="tracking-[0.2em] text-[#8c8f95]") Admin Overview
        h2.text-3xl.font-bold(class="text-[#0d0d0d]") Operation cockpit
        p.text-sm(class="text-[#5f6673]") Theo doi tong quan san pham, don hang va hieu suat van hanh trong ngay.
      .grid.grid-cols-2.gap-3(class="sm:grid-cols-3")
        a.inline-flex.items-center.justify-center.gap-2.px-4.py-2.text-sm.font-semibold.text-white(class="bg-[#f48525] hover:bg-[#e07820]" href="/admin/products/create")
          i.fas.fa-plus
          | Tao san pham
        a.inline-flex.items-center.justify-center.gap-2.border.px-4.py-2.text-sm.font-semibold(class="border-[#dee1e6] text-[#0d0d0d] hover:bg-[#fff7ef]" href="/admin/orders")
          i.fas.fa-receipt
          | Don hang
        a.inline-flex.items-center.justify-center.gap-2.border.px-4.py-2.text-sm.font-semibold(class="border-[#dee1e6] text-[#0d0d0d] hover:bg-[#fff7ef]" href="/admin/users")
          i.fas.fa-users
          | Nguoi dung

  .grid.grid-cols-1.gap-5.mb-8(class="sm:grid-cols-2 xl:grid-cols-4")
    .bg-white.p-5
      p.text-xs.uppercase.tracking-wider(class="text-[#8c8f95]") Products
      p.mt-2.text-3xl.font-bold(class="text-[#0d0d0d]") 1,247
      p.mt-2.text-xs(class="text-emerald-700") +12% so voi thang truoc
    .bg-white.p-5
      p.text-xs.uppercase.tracking-wider(class="text-[#8c8f95]") Orders
      p.mt-2.text-3xl.font-bold(class="text-[#0d0d0d]") 892
      p.mt-2.text-xs(class="text-amber-700") 36 don dang xu ly
    .bg-white.p-5
      p.text-xs.uppercase.tracking-wider(class="text-[#8c8f95]") Revenue
      p.mt-2.text-3xl.font-bold(class="text-[#0d0d0d]") $45,678
      p.mt-2.text-xs(class="text-emerald-700") +15% so voi thang truoc
    .bg-white.p-5
      p.text-xs.uppercase.tracking-wider(class="text-[#8c8f95]") Low Stock
      p.mt-2.text-3xl.font-bold(class="text-[#0d0d0d]") 21
      p.mt-2.text-xs(class="text-red-700") Can nhap them trong 24h

  .grid.grid-cols-1.gap-6(class="lg:grid-cols-5")
    .bg-white.p-6(class="lg:col-span-3")
      .flex.items-center.justify-between.mb-4
        h3.text-lg.font-semibold(class="text-[#0d0d0d]") Revenue pulse
        span.text-xs.uppercase.tracking-wider(class="text-[#8c8f95]") 30 days
      .h-64.flex.items-center.justify-center.border(class="border-dashed border-[#dee1e6] bg-[#fafafa]")
        .text-center
          i.fas.fa-chart-line.text-4xl.mb-2(class="text-[#f48525]")
          p.text-sm.font-medium(class="text-[#323842]") Chart area
          p.text-xs(class="text-[#8c8f95]") Co the tich hop Chart.js o buoc tiep theo
    .bg-white.p-6(class="lg:col-span-2")
      h3.text-lg.font-semibold.mb-4(class="text-[#0d0d0d]") Live activities
      .space-y-4
        .flex.items-start.gap-3
          .h-8.w-8.flex.items-center.justify-center(class="bg-[#fff2e6] text-[#f48525]")
            i.fas.fa-box-open.text-xs
          .flex-1
            p.text-sm.font-medium(class="text-[#0d0d0d]") New SKU created
            p.text-xs(class="text-[#8c8f95]") SKU-PT-2026-019 • 10 phut truoc
        .flex.items-start.gap-3
          .h-8.w-8.flex.items-center.justify-center(class="bg-[#edf7ff] text-[#1d70b8]")
            i.fas.fa-user-plus.text-xs
          .flex-1
            p.text-sm.font-medium(class="text-[#0d0d0d]") New user registered
            p.text-xs(class="text-[#8c8f95]") tran.an@example.com • 24 phut truoc
        .flex.items-start.gap-3
          .h-8.w-8.flex.items-center.justify-center(class="bg-[#eefbf3] text-[#0f9f53]")
            i.fas.fa-truck.text-xs
          .flex-1
            p.text-sm.font-medium(class="text-[#0d0d0d]") Shipment confirmed
            p.text-xs(class="text-[#8c8f95]") ORD-2026-1012 • 42 phut truoc