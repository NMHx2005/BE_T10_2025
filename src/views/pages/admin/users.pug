extends ../../layouts/admin

block content
  -
    var filt = filters || {};
    var pag = pagination || {};
    var curPage = (pag.current != null ? pag.current : pag.page) || 1;
    var q = '';
    if (filt.search && String(filt.search).trim()) {
      q += '&search=' + encodeURIComponent(String(filt.search).trim());
    }
    if (filt.role) {
      q += '&role=' + encodeURIComponent(String(filt.role));
    }
    if (filt.status) {
      q += '&status=' + encodeURIComponent(String(filt.status));
    }

  // Page Header
  .mb-8.border.bg-white.p-6(class="border-[#dee1e6]")
    .flex.flex-col
      p.text-xs.uppercase.tracking-widest(class="text-[#8c8f95]") Accounts
      h1.text-3xl.font-bold(class="text-[#0d0d0d]") Quản lý người dùng
      p.text-gray-600.mt-2
        | Tổng: 
        span.font-semibold #{totalUsers || 0}
        |  tài khoản

  // Filters & Search
  .bg-white.p-6.mb-6
    .grid.grid-cols-1(class="md:grid-cols-4 gap-4")
      .form-group
        input.form-input(
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
          type="text"
          placeholder="Tìm username hoặc email..."
          id="search-input"
          value=filt.search || ''
        )

      select.form-input(
        class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
        id="role-filter"
      )
        option(value="" selected=!filt.role) Mọi vai trò
        option(value="user" selected=filt.role==='user') User
        option(value="admin" selected=filt.role==='admin') Admin

      select.form-input(
        class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500"
        id="status-filter"
      )
        option(value="" selected=!filt.status) Mọi trạng thái
        option(value="active" selected=filt.status==='active') Active
        option(value="inactive" selected=filt.status==='inactive') Inactive

      button(
        class="bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-4 rounded-lg transition-colors"
        type="button"
        onclick="applyFilters()"
      )
        i.fas.fa-filter.mr-2
        | Lọc

  // Users Table
  if users && users.length > 0
    .bg-white.overflow-hidden
      .overflow-x-auto
        table.w-full
          thead.bg-gray-100.border-b.border-gray-200
            tr
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 User
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Email
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Role
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Status
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Đơn hàng
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Tham gia
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Cập nhật
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Thao tác

          tbody.divide-y.divide-gray-200
            each user in users
              tr(class="hover:bg-gray-50 transition-colors")
                td.px-6.py-4
                  .flex.items-center.gap-3
                    img.w-10.h-10.rounded-full.object-cover.bg-gray-200(
                      src=user.avatar || ('https://ui-avatars.com/api/?name=' + encodeURIComponent(user.username || ''))
                      alt=user.username
                    )
                    .flex.flex-col
                      p.font-medium.text-gray-900= user.username
                      if user.phone
                        p.text-xs.text-gray-500= user.phone
                      else
                        p.text-xs.text-gray-400= '—'

                td.px-6.py-4.text-sm.text-gray-600= user.email

                td.px-6.py-4
                  span.px-2.py-1.rounded-full.text-xs.font-semibold(class={
                    'bg-red-100 text-red-800': user.role === 'admin',
                    'bg-blue-100 text-blue-800': user.role === 'user'
                  })= user.role || 'user'

                td.px-6.py-4
                  span.px-2.py-1.rounded-full.text-xs.font-semibold.flex.items-center.gap-1.w-fit(class={
                    'bg-green-100 text-green-800': user.status === 'active',
                    'bg-gray-100 text-gray-800': user.status !== 'active'
                  })
                    if user.status === 'active'
                      i.fas.fa-circle.text-green-600.text-xs
                      | Active
                    else
                      i.fas.fa-circle.text-gray-400.text-xs
                      | Inactive

                td.px-6.py-4.text-sm.text-gray-600.text-center= user.orderCount || 0

                td.px-6.py-4.text-sm.text-gray-600
                  = user.createdAt ? new Date(user.createdAt).toLocaleDateString('vi-VN') : '—'

                td.px-6.py-4.text-sm.text-gray-600
                  = user.updatedAt ? new Date(user.updatedAt).toLocaleDateString('vi-VN') : '—'

                td.px-6.py-4.text-sm.flex.gap-2
                  a(
                    class="text-blue-600 hover:text-blue-700 transition-colors px-2 py-1"
                    href=`/admin/users/${user._id}`
                    title="Chi tiết / Sửa"
                  )
                    i.fas.fa-edit

                  button(
                    type="button"
                    class="text-orange-600 hover:text-orange-700 transition-colors px-2 py-1"
                    onclick=`changeUserRole('${user._id}', '${user.role}')`
                    title="Đổi role"
                  )
                    i.fas.fa-user-lock

                  button(
                    type="button"
                    class="text-red-600 hover:text-red-700 transition-colors px-2 py-1"
                    onclick=`deactivateUser('${user._id}')`
                    title="Vô hiệu hóa (soft delete)"
                  )
                    i.fas.fa-user-slash

      // Pagination
      if pag.pages > 1
        .bg-gray-50.px-6.py-4.flex.justify-between.items-center
          p.text-sm.text-gray-600
            | Hiển thị 
            span.font-semibold= (curPage - 1) * pag.limit + 1
            |  – 
            span.font-semibold= Math.min(curPage * pag.limit, pag.total)
            |  / 
            span.font-semibold= pag.total

          .flex.gap-2
            if curPage > 1
              a.px-3.py-2.border.border-gray-300.rounded.text-gray-700(
                class="hover:bg-gray-100"
                href=`/admin/users?page=${curPage - 1}${q}`
              )
                i.fas.fa-chevron-left

            - var pageNumsList = pag.pageNums || []
            each i in pageNumsList
              if i === curPage
                .px-3.py-2.bg-blue-600.text-white.rounded= i
              else
                a.px-3.py-2.border.border-gray-300.rounded.text-gray-700(
                  class="hover:bg-gray-100"
                  href=`/admin/users?page=${i}${q}`
                )= i

            if curPage < pag.pages
              a.px-3.py-2.border.border-gray-300.rounded.text-gray-700(
                class="hover:bg-gray-100"
                href=`/admin/users?page=${curPage + 1}${q}`
              )
                i.fas.fa-chevron-right
  else
    .bg-white.p-12.text-center
      i.fas.fa-users.text-gray-400.text-5xl.mb-4
      h3.text-xl.font-semibold.text-gray-900.mb-2 Không có người dùng
      p.text-gray-600 Thử đổi bộ lọc hoặc từ khóa tìm kiếm.

block scripts
  script.
    function getToken() {
      return localStorage.getItem('accessToken') || '';
    }

    async function deactivateUser(userId) {
      if (!confirm('Vô hiệu hóa tài khoản này? (Đặt trạng thái inactive — dữ liệu vẫn giữ trong hệ thống.)')) return;
      var token = getToken();
      if (!token) {
        if (window.AppNotify) window.AppNotify.warning('Vui lòng đăng nhập admin.');
        return;
      }
      try {
        var res = await fetch('/api/v1/users/' + encodeURIComponent(userId), {
          method: 'DELETE',
          headers: { Authorization: 'Bearer ' + token },
        });
        var data = await res.json().catch(function () {
          return {};
        });
        if (!res.ok) {
          throw new Error(data.message || 'Thao tác thất bại.');
        }
        if (window.AppNotify) window.AppNotify.success(data.message || 'Đã vô hiệu hóa.');
        location.reload();
      } catch (e) {
        if (window.AppNotify) window.AppNotify.error(e.message || 'Lỗi.');
      }
    }

    async function changeUserRole(userId, currentRole) {
      var newRole = currentRole === 'admin' ? 'user' : 'admin';
      if (!confirm('Đổi vai trò sang "' + newRole + '"? (Không thể tự đổi role chính mình; phải còn ít nhất một admin active.)')) return;
      var token = getToken();
      if (!token) {
        if (window.AppNotify) window.AppNotify.warning('Vui lòng đăng nhập admin.');
        return;
      }
      try {
        var res = await fetch('/api/v1/users/' + encodeURIComponent(userId), {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            Authorization: 'Bearer ' + token,
          },
          body: JSON.stringify({ role: newRole }),
        });
        var data = await res.json().catch(function () {
          return {};
        });
        if (!res.ok) {
          throw new Error(data.message || 'Cập nhật thất bại.');
        }
        if (window.AppNotify) window.AppNotify.success(data.message || 'Đã cập nhật role.');
        location.reload();
      } catch (e) {
        if (window.AppNotify) window.AppNotify.error(e.message || 'Lỗi.');
      }
    }

    function applyFilters() {
      var search = document.getElementById('search-input') && document.getElementById('search-input').value || '';
      var role = document.getElementById('role-filter') && document.getElementById('role-filter').value || '';
      var status = document.getElementById('status-filter') && document.getElementById('status-filter').value || '';
      var url = '/admin/users?page=1';
      if (search.trim()) url += '&search=' + encodeURIComponent(search.trim());
      if (role) url += '&role=' + encodeURIComponent(role);
      if (status) url += '&status=' + encodeURIComponent(status);
      window.location.href = url;
    }
