extends ../../layouts/admin

block content
  // Page Header
  .mb-8.border.bg-white.p-6(class="border-[#dee1e6]")
    .flex.items-center.justify-between
      .flex.flex-col
        p.text-xs.uppercase.tracking-widest(class="text-[#8c8f95]") Accounts
        h1.text-3xl.font-bold(class="text-[#0d0d0d]") Users Management
        p.text-gray-600.mt-2 Total: 
          span.font-semibold #{totalUsers || 0}
          |  users
      
      a.text-white.font-medium.py-2.px-6.transition-colors.flex.items-center.gap-2(class="bg-[#f48525] hover:bg-[#e07820]"
        href="/admin/users/new"
      )
        i.fas.fa-plus.mr-2
        | Add New User

  // Filters & Search
  .bg-white.p-6.mb-6
    .grid.grid-cols-1(class="md:grid-cols-4 gap-4")
      .form-group
        input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg.focus:ring-2.focus:ring-blue-500(
          type="text",
          placeholder="Search by username or email...",
          id="search-input"
        )
      
      select.form-input.px-4.py-2.border.border-gray-300.rounded-lg.focus:ring-2.focus:ring-blue-500(
        id="role-filter"
      )
        option(value="") All Roles
        option(value="user") User
        option(value="admin") Admin
      
      select.form-input.px-4.py-2.border.border-gray-300.rounded-lg.focus:ring-2.focus:ring-blue-500(
        id="status-filter"
      )
        option(value="") All Status
        option(value="active") Active
        option(value="inactive") Inactive
      
      button.bg-blue-600.hover:bg-blue-700.text-white.font-medium.py-2.px-4.rounded-lg.transition-colors(
        type="button",
        onclick="applyFilters()"
      )
        i.fas.fa-filter.mr-2
        | Apply Filters

  // Users Table
  if users && users.length > 0
    .bg-white.overflow-hidden
      .overflow-x-auto
        table.w-full
          thead.bg-gray-100.border-b.border-gray-200
            tr
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 User
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Email
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Role
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Status
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Orders
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Joined
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Last Activity
              th.px-6.py-4.text-left.text-sm.font-semibold.text-gray-900 Actions
          
          tbody.divide-y.divide-gray-200
            each user in users
              tr.hover:bg-gray-50.transition-colors
                // User Info
                td.px-6.py-4
                  .flex.items-center.gap-3
                    img.w-10.h-10.rounded-full.object-cover.bg-gray-200(
                      src=user.avatar || `https://ui-avatars.com/api/?name=${user.username}`,
                      alt=user.username
                    )
                    .flex.flex-col
                      p.font-medium.text-gray-900
                        = user.username
                      p.text-xs.text-gray-500
                        = user.fullName || 'No name'
                
                // Email
                td.px-6.py-4.text-sm.text-gray-600
                  = user.email
                
                // Role
                td.px-6.py-4
                  span.px-2.py-1.rounded-full.text-xs.font-semibold(class={
                    'bg-red-100 text-red-800': user.role === 'admin',
                    'bg-blue-100 text-blue-800': user.role === 'user'
                  })
                    = user.role || 'User'
                
                // Status
                td.px-6.py-4
                  span.px-2.py-1.rounded-full.text-xs.font-semibold.flex.items-center.gap-1.w-fit(class={
                    'bg-green-100 text-green-800': true,
                    'bg-gray-100 text-gray-800': false
                  })
                    i.fas.fa-circle.text-green-600.text-xs
                    | Active
                
                // Orders Count
                td.px-6.py-4.text-sm.text-gray-600.text-center
                  = user.orderCount || 0
                
                // Joined Date
                td.px-6.py-4.text-sm.text-gray-600
                  = new Date(user.createdAt).toLocaleDateString()
                
                // Last Activity
                td.px-6.py-4.text-sm.text-gray-600
                  if user.lastLogin
                    = new Date(user.lastLogin).toLocaleDateString()
                  else
                    span.text-gray-400 Never
                
                // Actions
                td.px-6.py-4.text-sm.flex.gap-2
                  a.text-blue-600.hover:text-blue-700.transition-colors.px-2.py-1(
                    href=`/admin/users/${user._id}`,
                    title="Edit"
                  )
                    i.fas.fa-edit
                  
                  button.text-orange-600.hover:text-orange-700.transition-colors.px-2.py-1(
                    type="button",
                    onclick=`changeUserRole('${user._id}', '${user.role}')`,
                    title="Change role"
                  )
                    i.fas.fa-user-lock
                  
                  button.text-red-600.hover:text-red-700.transition-colors.px-2.py-1(
                    type="button",
                    onclick=`deleteUser('${user._id}')`,
                    title="Delete"
                  )
                    i.fas.fa-trash

      // Pagination
      if pagination && pagination.pages > 1
        .bg-gray-50.px-6.py-4.flex.justify-between.items-center
          p.text-sm.text-gray-600
            | Showing 
            span.font-semibold= (pagination.page - 1) * pagination.limit + 1
            |  to 
            span.font-semibold= Math.min(pagination.page * pagination.limit, pagination.total)
            |  of 
            span.font-semibold= pagination.total
          
          .flex.gap-2
            if pagination.page > 1
              a.px-3.py-2.border.border-gray-300.rounded.text-gray-700.hover:bg-gray-100(
                href=`/admin/users?page=${pagination.page - 1}`
              )
                i.fas.fa-chevron-left
            
            each i in [...Array(Math.min(pagination.pages, 5)).keys()].map(x => Math.max(1, pagination.page - 2) + x)
              if i <= pagination.pages
                if i === pagination.page
                  .px-3.py-2.bg-blue-600.text-white.rounded
                    = i
                else
                  a.px-3.py-2.border.border-gray-300.rounded.text-gray-700.hover:bg-gray-100(
                    href=`/admin/users?page=${i}`
                  )
                    = i
            
            if pagination.page < pagination.pages
              a.px-3.py-2.border.border-gray-300.rounded.text-gray-700.hover:bg-gray-100(
                href=`/admin/users?page=${pagination.page + 1}`
              )
                i.fas.fa-chevron-right
  else
    // No Users
    .bg-white.p-12.text-center
      i.fas.fa-users.text-gray-400.text-5xl.mb-4
      h3.text-xl.font-semibold.text-gray-900.mb-2 No Users Found
      p.text-gray-600.mb-6 Start by inviting users to your platform
      a.inline-block.bg-blue-600.hover:bg-blue-700.text-white.font-medium.py-2.px-6.rounded-lg.transition-colors(
        href="/admin/users/new"
      )
        i.fas.fa-plus.mr-2
        | Add User

block scripts
  script.
    function deleteUser(userId) {
      if (confirm('Are you sure you want to delete this user? This action cannot be undone.')) {
        // TODO: Call API to delete user
        alert('User deleted!');
        location.reload();
      }
    }

    function changeUserRole(userId, currentRole) {
      const newRole = currentRole === 'admin' ? 'user' : 'admin';
      if (confirm(`Change role to ${newRole}?`)) {
        // TODO: Call API to change user role
        alert('User role updated!');
        location.reload();
      }
    }

    function applyFilters() {
      const search = document.getElementById('search-input')?.value || '';
      const role = document.getElementById('role-filter')?.value || '';
      const status = document.getElementById('status-filter')?.value || '';
      
      let url = '/admin/users?';
      if (search) url += `search=${encodeURIComponent(search)}&`;
      if (role) url += `role=${role}&`;
      if (status) url += `status=${status}`;
      
      window.location.href = url;
    }
