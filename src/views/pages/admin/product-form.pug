extends ../../layouts/admin

block content
  - const v0 = isEdit && product.variants && product.variants.length ? product.variants[0] : null
  - const primaryImage = isEdit && product.images && product.images.length ? product.images[0] : null
  // Page Header
  .mb-8.border.bg-white.p-6(class="border-[#dee1e6]")
    .flex.items-center.gap-4
      a.text-blue-600(class="hover:text-blue-700" href="/admin/products")
        i.fas.fa-arrow-left.text-xl
      .flex.flex-col
        p.text-xs.uppercase.tracking-widest(class="text-[#8c8f95]") Catalog Item
        h1.text-3xl.font-bold(class="text-[#0d0d0d]")
          if isEdit
            | Edit Product
          else
            | Create New Product
        p.text-gray-600.mt-2
          if isEdit
            = 'Product: ' + product.name
          else
            | Add a new product to your catalog

  // Main Form
  form.space-y-8(method="POST", action=isEdit ? `/admin/products/${product._id}` : "/admin/products", enctype="multipart/form-data", id="product-form")
    // Basic Information
    .bg-white.p-6
      h2.text-xl.font-semibold.text-gray-900.mb-6 Basic Information

      .grid.grid-cols-1(class="md:grid-cols-2 gap-6")
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="name") Product Name
          input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            type="text",
            id="name",
            name="name",
            placeholder="Enter product name",
            value=isEdit ? product.name : '',
            required
          )
        
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="variantSku") Variant SKU
          input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            type="text",
            id="variantSku",
            name="variantSku",
            placeholder="Để trống để hệ thống tự tạo",
            value=isEdit && v0 ? v0.sku : '',
            readonly=isEdit
          )
          p.text-xs.text-gray-500.mt-1 Theo model: SKU thuộc từng biến thể (variant), không lưu ở cấp sản phẩm.
        
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="category") Category
          select.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            id="category",
            name="category",
            required
          )
            option(value="") Select a category
            if categories && categories.length > 0
              each cat in categories
                option(value=cat._id, selected=isEdit && product.category && String(product.category._id || product.category) === String(cat._id))
                  = cat.name
        
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="brand") Brand
          input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            type="text",
            id="brand",
            name="brand",
            placeholder="Product brand",
            value=isEdit ? product.brand : ''
          )

    // Default variant (schema: giá & tồn kho trên variants[])
    .bg-white.p-6
      h2.text-xl.font-semibold.text-gray-900.mb-6 Biến thể mặc định (bắt buộc)
      p.text-sm.text-gray-600.mb-4
        | Model yêu cầu ít nhất một variant. Form quản trị hiện chỉnh sửa một variant mặc định (attributes có thể để trống).

      .grid.grid-cols-1(class="md:grid-cols-3 gap-6")
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="price") Giá variant ($)
          input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            type="number",
            id="price",
            name="price",
            placeholder="0.00",
            step="0.01",
            min="0",
            value=isEdit && v0 ? v0.price : '',
            required
          )
        
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="compareAtPrice") Giá so sánh ($)
          input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            type="number",
            id="compareAtPrice",
            name="compareAtPrice",
            placeholder="Tuỳ chọn, phải &gt; giá bán",
            step="0.01",
            min="0",
            value=isEdit && v0 && v0.compareAtPrice != null ? v0.compareAtPrice : ''
          )
        
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="stock") Tồn kho variant
          input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            type="number",
            id="stock",
            name="stock",
            placeholder="0",
            min="0",
            step="1",
            value=isEdit && v0 ? v0.stock : '',
            required
          )

    // Description
    .bg-white.p-6
      h2.text-xl.font-semibold.text-gray-900.mb-6 Description

      .form-group
        label.block.text-sm.font-medium.text-gray-700.mb-2(for="description") Product Description
        textarea.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
          class="focus:ring-2 focus:ring-blue-500"
          id="description",
          name="description",
          rows="6",
          placeholder="Enter detailed product description...",
          required
        )
          = isEdit ? product.description : ''
        
        p.text-xs.text-gray-500.mt-2 Supports Markdown formatting

      .grid.grid-cols-1(class="md:grid-cols-2 gap-6 mt-6")
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="shortDescription") Mô tả ngắn (tối đa 200 ký tự)
          input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            type="text",
            id="shortDescription",
            name="shortDescription",
            maxlength="200",
            placeholder="Hiển thị preview, card...",
            value=isEdit ? (product.shortDescription || '') : ''
          )
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="tags") Tags
          input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            type="text",
            id="tags",
            name="tags",
            placeholder="vd: summer, sale (phân tách bằng dấu phẩy)",
            value=isEdit && product.tags && product.tags.length ? product.tags.join(', ') : ''
          )

    // Images
    .bg-white.p-6
      h2.text-xl.font-semibold.text-gray-900.mb-6 Images

      .form-group
        label.block.text-sm.font-medium.text-gray-700.mb-2(for="thumbnail") Ảnh chính (lưu vào mảng images của sản phẩm)
        .flex.items-center.gap-4
          if isEdit && primaryImage
            img.w-20.h-20.rounded.object-cover(src=primaryImage, alt="Primary")
          else
            .w-20.h-20.rounded.bg-gray-200.flex.items-center.justify-center
              i.fas.fa-image.text-gray-400.text-2xl
          
          input.block.flex-1.text-sm.text-gray-500(
            class="file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100"
            type="file",
            id="thumbnail",
            name="thumbnail",
            accept="image/*"
          )
        p.text-xs.text-gray-500.mt-2 JPG, PNG, GIF (Max 5MB)

    // Status & SEO
    .bg-white.p-6
      h2.text-xl.font-semibold.text-gray-900.mb-6 Status & SEO

      .grid.grid-cols-1(class="md:grid-cols-2 gap-6")
        .form-group
          label.block.text-sm.font-medium.text-gray-700.mb-2(for="status") Status
          select.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg(
            class="focus:ring-2 focus:ring-blue-500"
            id="status",
            name="status"
          )
            option(value="draft", selected=isEdit ? product.status === 'draft' : true) Draft
            option(value="active", selected=isEdit && product.status === 'active') Active
            option(value="inactive", selected=isEdit && product.status === 'inactive') Inactive
            option(value="archived", selected=isEdit && product.status === 'archived') Archived
        
        .form-group
          .flex.items-center.gap-3
            input.w-4.h-4.rounded.border-gray-300(
              type="checkbox",
              id="featured",
              name="featured",
              checked=isEdit && product.featured
            )
            label.text-sm.font-medium.text-gray-700(for="featured") Mark as Featured Product

    // Submit Buttons
    .flex.gap-3.justify-end
      a.px-6.py-3.border.border-gray-300.rounded-lg.text-gray-700.font-medium.transition-colors(
        class="hover:bg-gray-50"
        href="/admin/products"
      )
        i.fas.fa-times.mr-2
        | Cancel
      
      button.px-6.py-3.text-white.rounded-lg.font-medium.transition-colors(class="bg-[#f48525] hover:bg-[#e07820]"
        type="submit"
      )
        i.fas.fa-save.mr-2
        if isEdit
          | Update Product
        else
          | Create Product

block scripts
  script.
    (function () {
      var form = document.getElementById('product-form');
      if (!form) return;

      function getToken() {
        return localStorage.getItem('accessToken') || '';
      }

      async function uploadProductImageToCloudinary(file) {
        var formData = new FormData();
        formData.append('image', file);
        var res = await fetch('/api/v1/upload/product-image', {
          method: 'POST',
          headers: {
            Authorization: 'Bearer ' + getToken(),
          },
          body: formData,
        });
        var data = await res.json().catch(function () {
          return {};
        });
        if (!res.ok) {
          throw new Error(data.message || 'Upload ảnh lên Cloudinary thất bại.');
        }
        if (!data.data || !data.data.url) {
          throw new Error('Phản hồi upload không hợp lệ.');
        }
        return data.data.url;
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();

        var token = getToken();
        if (!token) {
          if (window.AppNotify) window.AppNotify.warning('Vui lòng đăng nhập admin.');
          window.location.href = '/auth/login';
          return;
        }

        var isEdit = !{JSON.stringify(!!isEdit)};
        var productId = !{JSON.stringify(product && product._id ? String(product._id) : '')};
        var name = (document.getElementById('name')?.value || '').trim();
        var category = (document.getElementById('category')?.value || '').trim();
        var brand = (document.getElementById('brand')?.value || '').trim();
        var description = (document.getElementById('description')?.value || '').trim();
        var shortDescription = (document.getElementById('shortDescription')?.value || '').trim();
        var tagsStr = (document.getElementById('tags')?.value || '').trim();
        var price = Number(document.getElementById('price')?.value || 0);
        var stock = Number(document.getElementById('stock')?.value || 0);
        var capRaw = document.getElementById('compareAtPrice')?.value;
        var compareAtPriceNum = capRaw === '' || capRaw == null ? NaN : Number(capRaw);
        var status = (document.getElementById('status')?.value || 'draft').trim();
        var featured = !!document.getElementById('featured')?.checked;
        var variantSku = (document.getElementById('variantSku')?.value || '').trim();
        var existingVariantSku = !{JSON.stringify(isEdit && v0 && v0.sku ? String(v0.sku) : '')};
        var existingImages = !{JSON.stringify(isEdit && product && product.images ? product.images : [])};
        var thumbInput = document.getElementById('thumbnail');
        var thumbFile = thumbInput && thumbInput.files && thumbInput.files[0] ? thumbInput.files[0] : null;
        var primaryImageUrl = '';

        if (!name || !category || !description || !Number.isFinite(price) || price < 0 || !Number.isFinite(stock) || stock < 0) {
          if (window.AppNotify) window.AppNotify.error('Vui lòng nhập đầy đủ thông tin hợp lệ.');
          return;
        }
        if (Number.isFinite(compareAtPriceNum) && compareAtPriceNum > 0 && compareAtPriceNum <= price) {
          if (window.AppNotify) window.AppNotify.error('Giá so sánh phải lớn hơn giá bán (theo validate schema).');
          return;
        }

        if (thumbFile) {
          try {
            primaryImageUrl = await uploadProductImageToCloudinary(thumbFile);
          } catch (err) {
            if (window.AppNotify) window.AppNotify.error(err.message || 'Ảnh không hợp lệ.');
            return;
          }
        }

        var imagesPayload;
        if (primaryImageUrl) {
          imagesPayload = [primaryImageUrl].concat(existingImages.slice(1));
        } else if (isEdit) {
          imagesPayload = existingImages;
        } else {
          imagesPayload = [];
        }

        var variantLine = {
          price: price,
          stock: Math.max(0, Math.floor(stock)),
          attributes: {}
        };
        var skuToSend = variantSku || existingVariantSku;
        if (skuToSend) variantLine.sku = skuToSend;
        if (Number.isFinite(compareAtPriceNum) && compareAtPriceNum > 0) {
          variantLine.compareAtPrice = compareAtPriceNum;
        }

        var payload = {
          name: name,
          category: category,
          brand: brand || undefined,
          description: description,
          shortDescription: shortDescription || undefined,
          tags: tagsStr,
          price: price,
          stock: Math.max(0, Math.floor(stock)),
          variants: [variantLine],
          status: status,
          featured: featured
        };
        if (imagesPayload.length) payload.images = imagesPayload;

        var endpoint = isEdit && productId ? '/api/v1/products/' + encodeURIComponent(productId) : '/api/v1/products';
        var method = isEdit ? 'PUT' : 'POST';

        var submitBtn = form.querySelector('button[type="submit"]');
        if (submitBtn) submitBtn.disabled = true;
        try {
          var res = await fetch(endpoint, {
            method: method,
            headers: {
              'Content-Type': 'application/json',
              Authorization: 'Bearer ' + token
            },
            body: JSON.stringify(payload)
          });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) throw new Error(data.message || 'Không thể lưu sản phẩm.');
          if (window.AppNotify) window.AppNotify.success(data.message || 'Lưu sản phẩm thành công.');
          setTimeout(function () {
            window.location.href = '/admin/products';
          }, 600);
        } catch (err) {
          if (window.AppNotify) window.AppNotify.error(err.message || 'Có lỗi xảy ra.');
        } finally {
          if (submitBtn) submitBtn.disabled = false;
        }
      });
    })();
