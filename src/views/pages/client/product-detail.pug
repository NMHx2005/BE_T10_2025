extends ../../../layouts/main

block content
  .max-w-7xl.mx-auto.px-4(class="sm:px-6 lg:px-8 py-12")
    // Breadcrumb
    if breadcrumb && breadcrumb.length > 0
      .flex.items-center.gap-2.mb-8.text-sm
        a.text-blue-600.hover:text-blue-700(href="/") Home
        i.fas.fa-chevron-right.text-gray-400
        each item, idx in breadcrumb
          if idx < breadcrumb.length - 1
            a.text-blue-600.hover:text-blue-700(href=`/products?category=${item.id}`)
              = item.name
          else
            span.text-gray-700
              = item.name
          if idx < breadcrumb.length - 1
            i.fas.fa-chevron-right.text-gray-400

    if product
      .grid.grid-cols-1(class="lg:grid-cols-2 gap-12")
        // Product Images
        .col-span-1
          .mb-6
            .bg-gray-100.rounded-lg.overflow-hidden.h-96.flex.items-center.justify-center.mb-4
              if product.thumbnail
                img.w-full.h-full.object-cover(src=product.thumbnail, alt=product.name, id="main-image")
              else if product.images && product.images.length > 0
                img.w-full.h-full.object-cover(src=product.images[0], alt=product.name, id="main-image")
              else
                i.fas.fa-image.text-gray-400.text-6xl
            
            // Thumbnail Gallery
            if product.images && product.images.length > 1
              .flex.gap-2
                each img, idx in product.images.slice(0, 5)
                  img.w-20.h-20.object-cover.rounded.border-2.border-gray-300.cursor-pointer.hover:border-blue-600.transition-colors(
                    src=img,
                    alt=`${product.name} ${idx}`,
                    onclick=`document.getElementById('main-image').src = '${img}'`
                  )

        // Product Details
        .col-span-1
          // Category & Status
          .flex.items-center.gap-3.mb-4
            a.bg-blue-100.text-blue-800.px-3.py-1.rounded-full.text-sm.font-medium(href=`/products?category=${product.category?._id}`)
              = product.category?.name || 'Uncategorized'
            if product.stock > 0
              span.bg-green-100.text-green-800.px-3.py-1.rounded-full.text-sm.font-medium In Stock
            else
              span.bg-red-100.text-red-800.px-3.py-1.rounded-full.text-sm.font-medium Out of Stock

          // Title
          h1.text-4xl.font-bold.text-gray-900.mb-4
            = product.name

          // Rating
          if product.rating
            .flex.items-center.gap-2.mb-6
              .flex.text-yellow-400
                - let stars = Math.round(product.rating.average || 0)
                - for (let i = 0; i < 5; i++) {
                  if i < stars
                    i.fas.fa-star
                  else
                    i.far.fa-star
                - }
              span.text-gray-700
                = `${product.rating.average || 0}/5 (${product.rating.count || 0} customer reviews)`

          // Brand
          if product.brand
            p.text-gray-600.mb-6
              span.font-semibold Brand:
              |  #{product.brand}

          // Description
          .bg-gray-50.rounded-lg.p-6.mb-6
            h3.font-semibold.text-gray-900.mb-3 Description
            p.text-gray-700.whitespace-pre-wrap
              = product.description

          // Price Section
          .border-t.border-b.border-gray-200.py-6.mb-6
            .flex.items-baseline.gap-4.mb-4
              span.text-5xl.font-bold.text-blue-600
                = '$' + product.price
              if product.compareAtPrice
                .flex.flex-col.text-sm
                  span.text-gray-500.line-through
                    = '$' + product.compareAtPrice
                  - let discount = Math.round(((product.compareAtPrice - product.price) / product.compareAtPrice) * 100)
                  span.text-green-600.font-semibold.text-lg
                    = 'Save ' + discount + '%'

          // Stock Info
          .bg-gray-50.rounded-lg.p-4.mb-6
            p.text-sm.text-gray-700
              span.font-semibold Available:
              span.ml-2
                if product.stock > 0
                  = product.stock + ' units'
                  span.text-green-600.ml-1 Available now
                else
                  | Out of stock

          // Purchase Section
          form.space-y-4(id="purchase-form")
            // Quantity
            .flex.items-center.gap-4
              label.font-medium.text-gray-700(for="quantity") Quantity:
              .flex.items-center.border.border-gray-300.rounded-lg.w-fit
                button.px-4.py-2.text-gray-600.hover:bg-gray-100.transition-colors(
                  type="button",
                  onclick="updateQuantity(-1)"
                )
                  i.fas.fa-minus
                input.w-16.text-center.py-2.border-x.border-gray-300(
                  type="number",
                  id="quantity",
                  name="quantity",
                  value="1",
                  min="1",
                  max=product.stock || 1,
                  readonly
                )
                button.px-4.py-2.text-gray-600.hover:bg-gray-100.transition-colors(
                  type="button",
                  onclick="updateQuantity(1)"
                )
                  i.fas.fa-plus

            // Add to Cart Button
            if product.stock > 0
              button.w-full.bg-blue-600.hover:bg-blue-700.text-white.font-bold.py-4.px-6.rounded-lg.transition-colors.text-lg(
                type="submit"
              )
                i.fas.fa-shopping-cart.mr-2
                | Add to Cart
            else
              button.w-full.bg-gray-400.cursor-not-allowed.text-white.font-bold.py-4.px-6.rounded-lg.text-lg(
                disabled
              )
                i.fas.fa-ban.mr-2
                | Out of Stock

            // Wishlist Button
            a.w-full.border-2.border-gray-300.text-gray-700.font-bold.py-3.px-6.rounded-lg.hover:border-red-600.hover:text-red-600.transition-colors.text-center.block(
              href="javascript:void(0)"
            )
              i.fas.fa-heart.mr-2
              | Add to Wishlist

          // Share Section
          .pt-6.border-t.border-gray-200
            p.text-sm.font-semibold.text-gray-700.mb-3 Share this product:
            .flex.gap-3
              a.w-10.h-10.flex.items-center.justify-center.bg-blue-600.text-white.rounded-full.hover:bg-blue-700.transition-colors(
                href=`https://facebook.com/sharer/sharer.php?u=${encodeURIComponent(product._id)}`,
                target="_blank"
              )
                i.fab.fa-facebook-f
              a.w-10.h-10.flex.items-center.justify-center.bg-sky-400.text-white.rounded-full.hover:bg-sky-500.transition-colors(
                href=`https://twitter.com/intent/tweet?text=${encodeURIComponent(product.name)}`,
                target="_blank"
              )
                i.fab.fa-twitter
              a.w-10.h-10.flex.items-center.justify-center.bg-red-600.text-white.rounded-full.hover:bg-red-700.transition-colors(
                href="#",
                onclick="copyToClipboard()"
              )
                i.fas.fa-link

      // Variants Section
      if product.variants && product.variants.length > 1
        .mt-16.border-t.border-gray-200.pt-12
          h2.text-2xl.font-bold.text-gray-900.mb-6 Available Variants
          .grid.grid-cols-1(class="md:grid-cols-2 lg:grid-cols-3 gap-6")
            each variant in product.variants
              .border.border-gray-300.rounded-lg.p-4.hover:shadow-lg.transition-shadow
                h4.font-semibold.text-gray-900.mb-2
                  = variant.name
                .flex.justify-between.items-center.mb-3
                  span.text-2xl.font-bold.text-blue-600
                    = '$' + variant.price
                  if variant.stock > 0
                    span.text-xs.text-green-600.font-medium
                      = variant.stock + ' available'
                  else
                    span.text-xs.text-red-600.font-medium Out of stock
                
                if variant.attributes && Object.keys(variant.attributes).length > 0
                  .text-sm.text-gray-600.mb-3
                    each val, key in variant.attributes
                      p
                        span.font-medium= key + ':'
                        |  #{val}

      // Reviews Section
      .mt-16.border-t.border-gray-200.pt-12
        .grid.grid-cols-1(class="lg:grid-cols-3 gap-8")
          .col-span-1
            h2.text-2xl.font-bold.text-gray-900.mb-6 Customer Reviews

            // Overall Rating
            .bg-gray-50.rounded-lg.p-6.mb-6
              .text-center
                h3.text-5xl.font-bold.text-gray-900
                  = product.rating?.average?.toFixed(1) || 'N/A'
                .flex.justify-center.text-yellow-400.my-2
                  - let stars = Math.round(product.rating?.average || 0)
                  - for (let i = 0; i < 5; i++) {
                    if i < stars
                      i.fas.fa-star
                    else
                      i.far.fa-star
                  - }
                p.text-gray-600.text-sm
                  = `Based on ${product.rating?.count || 0} reviews`

          // Review Form (placeholder)
          .col-span-1(class="lg:col-span-2")
            h3.text-lg.font-semibold.text-gray-900.mb-4 Leave a Review

            .bg-blue-50.rounded-lg.p-6.border.border-blue-200.text-center
              i.fas.fa-info-circle.text-blue-600.text-2xl.mb-3
              p.text-gray-700 Sign in to your account to leave a review
              a.inline-block.mt-4.bg-blue-600.hover:bg-blue-700.text-white.font-medium.py-2.px-6.rounded-lg.transition-colors(
                href="/auth/login"
              )
                | Sign In

    else
      // Product Not Found
      .text-center.py-24
        i.fas.fa-inbox.text-gray-400.text-6xl.mb-4
        h1.text-3xl.font-bold.text-gray-900.mb-2 Product Not Found
        p.text-gray-600.mb-8 The product you're looking for doesn't exist.
        a.bg-blue-600.hover:bg-blue-700.text-white.font-medium.py-2.px-6.rounded-lg.transition-colors(
          href="/products"
        )
          i.fas.fa-arrow-left.mr-2
          | Back to Products

block scripts
  script.
    function updateQuantity(change) {
      const input = document.getElementById('quantity');
      let current = parseInt(input.value) || 1;
      let newValue = current + change;
      const max = parseInt(input.max) || 999;
      
      if (newValue >= 1 && newValue <= max) {
        input.value = newValue;
      }
    }

    function copyToClipboard() {
      const url = window.location.href;
      navigator.clipboard.writeText(url).then(() => {
        alert('Link copied to clipboard!');
      });
    }

    // Handle purchase form submission
    document.getElementById('purchase-form')?.addEventListener('submit', function(e) {
      e.preventDefault();
      const quantity = document.getElementById('quantity').value;
      // TODO: Add product to cart (integrate with cart service)
      alert(`Added ${quantity} item(s) to cart!`);
    });
