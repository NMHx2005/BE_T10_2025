extends ../../layouts/main

block content
  -
    var __p = typeof product !== 'undefined' ? product : null
    var __related = typeof relatedProducts !== 'undefined' && relatedProducts ? relatedProducts : []
    function __vnd(n) {
      if (n == null || Number.isNaN(Number(n))) return '—'
      return new Intl.NumberFormat('vi-VN').format(Math.round(Number(n))) + '₫'
    }
    function __stock(p) {
      if (!p) return 0
      if (p.stockTotal != null) return Number(p.stockTotal) || 0
      if (p.totalStock != null) return Number(p.totalStock) || 0
      if (p.variants && p.variants.length) {
        return p.variants.reduce(function (sum, v) {
          if (!v || v.isActive === false) return sum
          var n = Number(v.stock)
          return Number.isFinite(n) ? sum + n : sum
        }, 0)
      }
      return 0
    }
    function __price(p) {
      if (!p) return '—'
      if (p.displayPrice != null) return __vnd(p.displayPrice)
      if (p.minPrice != null) return __vnd(p.minPrice)
      if (p.variantMinPrice != null) return __vnd(p.variantMinPrice)
      if (p.variants && p.variants.length) {
        var nums = p.variants
          .map(function (v) { return Number(v && v.price) })
          .filter(function (n) { return Number.isFinite(n) })
        if (nums.length) return __vnd(Math.min.apply(null, nums))
      }
      return '—'
    }
    function __comparePrice(p) {
      if (!p) return null
      if (p.displayCompareAtPrice != null && Number.isFinite(Number(p.displayCompareAtPrice))) return Number(p.displayCompareAtPrice)
      if (p.variants && p.variants.length) {
        var nums = p.variants
          .map(function (v) { return Number(v && v.compareAtPrice) })
          .filter(function (n) { return Number.isFinite(n) })
        if (nums.length) return Math.max.apply(null, nums)
      }
      return null
    }
    function __normImg(u) {
      if (u == null) return null
      if (typeof u === 'string') {
        var t = u.trim()
        return t || null
      }
      if (typeof u === 'object' && u.url) {
        var s = String(u.url).trim()
        return s || null
      }
      if (typeof u === 'object' && u.secure_url) {
        var z = String(u.secure_url).trim()
        return z || null
      }
      return null
    }
    function __img(p) {
      if (!p) return null
      var i
      if (p.galleryImages && p.galleryImages.length) {
        i = __normImg(p.galleryImages[0])
        if (i) return i
      }
      if (p.images && p.images.length) {
        i = __normImg(p.images[0])
        if (i) return i
      }
      if (p.variants && p.variants.length) {
        var withImg = p.variants.find(function (v) { return v && v.images && v.images.length })
        if (withImg) {
          i = __normImg(withImg.images[0])
          if (i) return i
        }
      }
      return null
    }
    function __gallery(p) {
      if (!p) return []
      var list = []
      if (p.galleryImages && p.galleryImages.length) list = p.galleryImages
      else if (p.images && p.images.length) list = p.images
      return list.map(__normImg).filter(Boolean)
    }

  if __p
    section(class="bg-[#0d0d0d]")
      div(class="mx-auto max-w-[1440px] px-4 py-12 sm:px-8 lg:px-[128px] lg:py-16")
        div(class="flex items-center gap-2 text-xs uppercase tracking-wider text-[#cbd6e2]")
          a(class="transition-colors hover:text-white" href="/") Trang chủ
          i.fa-solid.fa-chevron-right(class="text-[10px]" aria-hidden="true")
          a(class="transition-colors hover:text-white" href="/products") Sản phẩm
          if __p.category && __p.category.name
            i.fa-solid.fa-chevron-right(class="text-[10px]" aria-hidden="true")
            a(class="transition-colors hover:text-white" href=`/products?category=${__p.category._id}`)= __p.category.name
          i.fa-solid.fa-chevron-right(class="text-[10px]" aria-hidden="true")
          span(class="text-[#f48525]")= __p.name

        h1(class="mt-5 max-w-3xl text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-[2.5rem] lg:leading-tight")= __p.name
        if __p.shortDescription || __p.description
          p(class="mt-4 max-w-3xl text-base leading-relaxed text-[#cbd6e2] sm:text-lg")= __p.shortDescription || __p.description

    div(class="bg-[#f4f5f7] pb-16 pt-10 lg:pb-20 lg:pt-12")
      div(class="mx-auto max-w-[1440px] px-4 sm:px-8 lg:px-[128px]")
        div(class="grid grid-cols-1 gap-10 lg:grid-cols-12 lg:gap-12")
          //- Gallery
          section(class="lg:col-span-7")
            div#main-image-stage(
              class="group relative overflow-hidden border border-[#dee1e6] bg-white shadow-[0_2px_4px_rgba(34,37,42,0.08)]"
            )
              if __img(__p)
                img#main-image(
                  class="h-[340px] w-full cursor-zoom-in object-cover transition-transform duration-150 ease-out sm:h-[420px] lg:h-[520px]"
                  src=__img(__p)
                  alt=__p.name
                )
              else
                div(class="flex h-[340px] w-full items-center justify-center bg-[#f3f4f6] sm:h-[420px] lg:h-[520px]")
                  i.fa-solid.fa-image(class="text-6xl text-[#dee1e6]" aria-hidden="true")
              if __img(__p)
                span(
                  class="pointer-events-none absolute bottom-3 right-3 inline-flex items-center gap-1 bg-black/55 px-2 py-1 text-[11px] font-medium text-white opacity-0 transition-opacity group-hover:opacity-100"
                )
                  i.fa-solid.fa-magnifying-glass-plus(aria-hidden="true")
                  | Zoom
            - var g = __gallery(__p)
            if g.length > 1
              div#product-thumbnails(class="mt-4 grid grid-cols-4 gap-3 sm:grid-cols-6")
                each gi, idx in g.slice(0, 6)
                  button(
                    type="button"
                    class=`product-thumb group overflow-hidden border bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-[#f48525] ${idx === 0 ? 'border-[#f48525]' : 'border-[#dee1e6]'}`
                    data-image=gi
                    data-index=idx
                    aria-label=`Xem ảnh ${idx + 1}`
                  )
                    img(
                      class="h-20 w-full object-cover transition group-hover:scale-105"
                      src=gi
                      alt=`${__p.name} ${idx + 1}`
                    )

          //- Info panel
          aside(class="lg:col-span-5")
            div(class="space-y-6 border border-[#dee1e6] bg-white p-6 shadow-[0_2px_4px_rgba(34,37,42,0.08)] sm:p-8")
              div(class="flex flex-wrap items-center gap-2")
                if __p.category && __p.category.name
                  a(
                    class="inline-flex items-center bg-[#0d0d0d] px-3 py-1 text-xs font-medium text-white transition-colors hover:bg-[#1b1b1b]"
                    href=`/products?category=${__p.category._id}`
                  )= __p.category.name
                if __stock(__p) > 0
                  span(class="inline-flex items-center bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700") Còn hàng
                else
                  span(class="inline-flex items-center bg-red-100 px-3 py-1 text-xs font-semibold text-red-700") Hết hàng

              if __p.rating
                div(class="flex items-center gap-3")
                  div(class="flex gap-0.5")
                    - var stars = Math.round(__p.rating.average || 0)
                    - for (var i = 1; i <= 5; i++)
                      if i <= stars
                        i.fa-solid.fa-star.text-sm(class="text-[#181b20]" aria-hidden="true")
                      else
                        i.fa-solid.fa-star.text-sm(class="text-[#dee1e6]" aria-hidden="true")
                  span(class="text-sm text-[#323842]")= `${(__p.rating.average || 0).toFixed(1)} / 5 (${__p.rating.count || 0} đánh giá)`

              div(class="border-y border-[#eef0f3] py-5")
                - var cp = __comparePrice(__p)
                p(class="text-3xl font-bold text-[#0d0d0d] sm:text-4xl")= __price(__p)
                if cp && Number(cp) > 0 && Number(cp) > Number(__p.displayPrice || __p.minPrice || 0)
                  p(class="mt-2 flex items-center gap-3 text-sm")
                    span(class="text-[#8c8f95] line-through")= __vnd(cp)
                    - var salePct = Math.round(((cp - Number(__p.displayPrice || __p.minPrice || 0)) / cp) * 100)
                    span(class="font-semibold text-emerald-700")= `Tiết kiệm ${salePct}%`

              div(class="space-y-2 text-sm text-[#323842]")
                if __p.brand
                  p
                    span.font-semibold Thương hiệu:
                    |  #{__p.brand}
                p
                  span.font-semibold Tồn kho:
                  |  #{__stock(__p)} sản phẩm

              if __p.description
                div
                  h2(class="mb-2 text-base font-semibold text-[#181b20]") Mô tả sản phẩm
                  p(class="whitespace-pre-wrap text-sm leading-relaxed text-[#323842]")= __p.description

              form#purchase-form(class="space-y-4")
                if __p.variants && __p.variants.length > 1
                  div
                    label(for="variant-select" class="mb-2 block text-sm font-medium text-[#181b20]") Chọn biến thể
                    select#variant-select.w-full.border.px-3.text-sm(
                      required
                      class="py-2 border-[#dee1e6] text-[#181b20] outline-none focus:border-[#f48525] focus:ring-1 focus:ring-[#f48525]"
                    )
                      option(value="" disabled selected) — Chọn —
                      each v in __p.variants
                        if v.isActive !== false
                          option(
                            value=String(v._id)
                            data-price=v.price
                            data-stock=v.stock
                            data-sku=v.sku
                          )= (v.sku || 'SKU') + ' — ' + __vnd(v.price) + ' (còn ' + v.stock + ')'
                else if __p.variants && __p.variants.length === 1
                  input#variant-id(type="hidden" value=String(__p.variants[0]._id))
                else
                  p.text-sm.font-medium.text-red-600 Sản phẩm chưa có biến thể để bán.

                .flex.items-center.gap-3
                  label(for="quantity" class="text-sm font-medium text-[#181b20]") Số lượng
                  .inline-flex.items-center.border(class="border-[#dee1e6]")
                    button(
                      type="button"
                      class="h-10 w-10 text-[#323842] transition-colors hover:bg-[#f4f5f7]"
                      onclick="updateQuantity(-1)"
                    )
                      i.fa-solid.fa-minus.text-xs(aria-hidden="true")
                    input#quantity(
                      type="number"
                      value="1"
                      min="1"
                      max=__stock(__p) > 0 ? __stock(__p) : 1
                      readonly
                      class="h-10 w-14 border-x border-[#dee1e6] text-center text-sm text-[#181b20]"
                    )
                    button(
                      type="button"
                      class="h-10 w-10 text-[#323842] transition-colors hover:bg-[#f4f5f7]"
                      onclick="updateQuantity(1)"
                    )
                      i.fa-solid.fa-plus.text-xs(aria-hidden="true")

                if __stock(__p) > 0 && __p.variants && __p.variants.length
                  button#btn-add-cart(
                    type="submit"
                    class="inline-flex h-12 w-full items-center justify-center gap-2 bg-[#f48525] px-6 text-sm font-semibold text-white transition-colors hover:bg-[#e07820] focus:outline-none focus-visible:ring-2 focus-visible:ring-[#f48525] focus-visible:ring-offset-2"
                  )
                    i.fa-solid.fa-bag-shopping(aria-hidden="true")
                    | Thêm vào giỏ hàng
                  button#btn-wishlist.inline-flex.h-12.w-full.items-center.justify-center.gap-2.border.px-6.text-sm.font-semibold(
                    type="button"
                    class="border-[#dee1e6] text-[#181b20] hover:border-[#f48525] hover:text-[#f48525]"
                  )
                    i.fa-regular.fa-heart(aria-hidden="true")
                    span#wishlist-label Yêu thích
                else
                  button(
                    type="button"
                    disabled
                    class="inline-flex h-12 w-full cursor-not-allowed items-center justify-center gap-2 bg-[#dee1e6] px-6 text-sm font-semibold text-[#323842]"
                  )
                    i.fa-solid.fa-ban(aria-hidden="true")
                    | Tạm hết hàng

              div(class="flex items-center gap-3 pt-2")
                a(
                  class="inline-flex h-10 w-10 items-center justify-center border border-[#dee1e6] text-[#181b20] transition-colors hover:border-[#f48525] hover:text-[#f48525]"
                  href=`https://facebook.com/sharer/sharer.php?u=${encodeURIComponent('http://localhost:3000/products/' + __p._id)}`
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label="Chia sẻ Facebook"
                )
                  i.fa-brands.fa-facebook-f(aria-hidden="true")
                button(
                  type="button"
                  class="inline-flex h-10 w-10 items-center justify-center border border-[#dee1e6] text-[#181b20] transition-colors hover:border-[#f48525] hover:text-[#f48525]"
                  onclick="copyToClipboard()"
                  aria-label="Sao chép liên kết"
                )
                  i.fa-solid.fa-link(aria-hidden="true")

        if __p.variants && __p.variants.length > 1
          section(class="mt-12 border border-[#dee1e6] bg-white p-6 shadow-[0_2px_4px_rgba(34,37,42,0.06)] sm:p-8")
            h3(class="mb-6 text-xl font-bold text-[#0d0d0d]") Biến thể sản phẩm
            ul.grid.gap-4(class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-3")
              each v in __p.variants
                li(class="border border-[#eef0f3] p-4")
                  p(class="text-sm font-semibold text-[#181b20]")= v.sku
                  p(class="mt-2 text-sm text-[#323842]")= __vnd(v.price)
                  if v.attributes
                    div(class="mt-2 space-y-1 text-xs text-[#323842]")
                      each val, key in v.attributes
                        p
                          span.font-semibold= `${key}: `
                          span= val

        if __related.length
          section(class="mt-12")
            div(class="mb-6 flex items-center justify-between")
              h3(class="text-xl font-bold text-[#0d0d0d] sm:text-2xl") Sản phẩm liên quan
              a(class="text-sm font-medium text-[#f48525] hover:opacity-90" href="/products") Xem thêm
            ul.grid.gap-6(class="grid-cols-1 sm:grid-cols-2 lg:grid-cols-4")
              each rp in __related
                li
                  - var rpImg = (rp.images && rp.images.length) ? __normImg(rp.images[0]) : null
                  article(class="overflow-hidden border border-[#eef0f3] bg-white shadow-[0_2px_4px_rgba(34,37,42,0.08)]")
                    a.block(class="h-48 bg-[#f3f4f6]" href=`/products/${rp._id}`)
                      if rpImg
                        img(class="h-full w-full object-cover" src=rpImg alt=rp.name loading="lazy")
                      else
                        div(class="flex h-full items-center justify-center")
                          i.fa-solid.fa-image(class="text-4xl text-[#dee1e6]" aria-hidden="true")
                    div(class="p-4")
                      a(class="line-clamp-2 text-sm font-semibold text-[#181b20] hover:text-[#f48525]" href=`/products/${rp._id}`)= rp.name
  else
    section(class="bg-[#f4f5f7] py-20")
      div(class="mx-auto max-w-[1440px] px-4 text-center sm:px-8 lg:px-[128px]")
        i.fa-solid.fa-inbox(class="mb-4 text-5xl text-[#dee1e6]" aria-hidden="true")
        h1(class="text-3xl font-bold text-[#0d0d0d]") Không tìm thấy sản phẩm
        p(class="mt-3 text-[#323842]") Sản phẩm có thể đã bị xóa hoặc chưa được kích hoạt.
        a(
          class="mt-8 inline-flex h-12 items-center justify-center border border-[#0d0d0d] bg-white px-8 text-sm font-semibold text-[#0d0d0d] transition-colors hover:bg-[#0d0d0d] hover:text-white"
          href="/products"
        ) Quay lại danh sách sản phẩm

  - var __pdpJson = JSON.stringify(__p ? { id: String(__p._id), name: __p.name, image: __img(__p), variants: (__p.variants || []).filter(function (v) { return v && v.isActive !== false; }).map(function (v) { return { id: String(v._id), price: Number(v.price), sku: v.sku || '', stock: Number(v.stock) }; }) } : null)

block scripts
  script.
    var PDP = !{__pdpJson};

    function initProductGallery() {
      const main = document.getElementById('main-image');
      const stage = document.getElementById('main-image-stage');
      const thumbs = Array.from(document.querySelectorAll('.product-thumb'));
      if (!main || !stage) return;

      function setActiveThumb(src) {
        thumbs.forEach(function (btn) {
          if (btn.dataset.image === src) {
            btn.classList.add('border-[#f48525]');
            btn.classList.remove('border-[#dee1e6]');
          } else {
            btn.classList.remove('border-[#f48525]');
            btn.classList.add('border-[#dee1e6]');
          }
        });
      }

      function setMainImage(src) {
        if (!src) return;
        main.src = src;
        main.style.transform = 'scale(1)';
        main.style.transformOrigin = 'center center';
        setActiveThumb(src);
      }

      thumbs.forEach(function (btn) {
        btn.addEventListener('click', function () {
          setMainImage(btn.dataset.image);
        });
      });

      // Zoom theo vị trí chuột khi hover ảnh chính
      stage.addEventListener('mousemove', function (e) {
        const rect = stage.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width) * 100;
        const y = ((e.clientY - rect.top) / rect.height) * 100;
        main.style.transformOrigin = x + '% ' + y + '%';
        main.style.transform = 'scale(1.8)';
      });

      stage.addEventListener('mouseleave', function () {
        main.style.transform = 'scale(1)';
        main.style.transformOrigin = 'center center';
      });
    }

    function getSelectedVariantMeta() {
      var hidden = document.getElementById('variant-id');
      if (hidden && hidden.value) {
        var one = PDP && PDP.variants && PDP.variants[0];
        if (one && one.id === hidden.value) return one;
        return PDP && PDP.variants ? PDP.variants.find(function (v) { return v.id === hidden.value; }) : null;
      }
      var sel = document.getElementById('variant-select');
      if (!sel || !sel.value) return null;
      var opt = sel.selectedOptions[0];
      return {
        id: sel.value,
        price: Number(opt && opt.dataset ? opt.dataset.price : 0),
        sku: opt && opt.dataset ? opt.dataset.sku : '',
        stock: Number(opt && opt.dataset ? opt.dataset.stock : 0),
      };
    }

    function updateQuantity(change) {
      const input = document.getElementById('quantity');
      if (!input) return;
      const meta = getSelectedVariantMeta();
      var max = meta && meta.stock ? meta.stock : parseInt(input.max || '999', 10);
      const current = parseInt(input.value || '1', 10);
      const next = current + change;
      if (next >= 1 && next <= max) input.value = String(next);
    }

    document.getElementById('variant-select')?.addEventListener('change', function () {
      var meta = getSelectedVariantMeta();
      var input = document.getElementById('quantity');
      if (!input || !meta) return;
      input.max = String(Math.max(1, meta.stock || 1));
      if (parseInt(input.value, 10) > meta.stock) input.value = String(Math.max(1, meta.stock));
    });

    function copyToClipboard() {
      navigator.clipboard.writeText(window.location.href).then(function () {
        alert('Da sao chep link san pham.');
      });
    }

    document.getElementById('purchase-form')?.addEventListener('submit', function (e) {
      e.preventDefault();
      if (!PDP || !window.ProToolsStore) return;
      var meta = getSelectedVariantMeta();
      if (!meta || !meta.id) {
        if (window.AppNotify) window.AppNotify.warning('Vui lòng chọn biến thể.');
        return;
      }
      var qty = parseInt(document.getElementById('quantity')?.value || '1', 10);
      if (qty < 1 || qty > meta.stock) {
        if (window.AppNotify) window.AppNotify.error('Số lượng không hợp lệ.');
        return;
      }
      window.ProToolsStore.cartAdd({
        productId: PDP.id,
        variantId: meta.id,
        quantity: qty,
        name: PDP.name,
        price: meta.price,
        image: PDP.image || '',
        sku: meta.sku || '',
      });
      if (window.AppNotify) window.AppNotify.success('Đã thêm vào giỏ hàng.');
    });

    document.getElementById('btn-wishlist')?.addEventListener('click', function () {
      if (!PDP || !window.ProToolsStore) return;
      var on = window.ProToolsStore.wishToggle(PDP.id);
      var lbl = document.getElementById('wishlist-label');
      if (lbl) lbl.textContent = on ? 'Đã lưu yêu thích' : 'Yêu thích';
      if (window.AppNotify) window.AppNotify.success(on ? 'Đã thêm vào yêu thích.' : 'Đã bỏ khỏi yêu thích.');
    });

    (function syncWishLabel() {
      if (!PDP || !window.ProToolsStore) return;
      var lbl = document.getElementById('wishlist-label');
      if (lbl && window.ProToolsStore.wishHas(PDP.id)) lbl.textContent = 'Đã lưu yêu thích';
    })();

    initProductGallery();
