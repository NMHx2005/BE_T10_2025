extends ../../layouts/main

block content
  section(class="bg-[#0d0d0d]")
    div(class="mx-auto max-w-[1440px] px-4 py-12 sm:px-8 lg:px-[128px] lg:py-16")
      p(class="mb-3 text-xs font-semibold uppercase tracking-wider text-[#f48525]") Tài khoản
      h1(class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-[2.5rem] lg:leading-tight") Hồ sơ cá nhân
      p(class="mt-4 max-w-2xl text-base leading-relaxed text-[#cbd6e2] sm:text-lg")
        | Quản lý thông tin cá nhân, avatar và cài đặt tài khoản của bạn.

  div(class="bg-[#f4f5f7] pb-16 pt-10 lg:pb-20 lg:pt-12")
    div(class="mx-auto max-w-[1440px] px-4 sm:px-8 lg:px-[128px]")
      #profile-alert.hidden.mb-6.rounded-lg.px-4.py-3.text-sm.font-medium(role="alert")

      .grid.grid-cols-1.gap-8(class="lg:grid-cols-12")
        aside(class="lg:col-span-3")
          nav(class="overflow-hidden border border-[#dee1e6] bg-white shadow-[0_2px_4px_rgba(34,37,42,0.06)]")
            a.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/profile"
              class="border-l-[#f48525] bg-[#fff7ef] text-[#181b20]"
            )
              i.fa-regular.fa-user(aria-hidden="true")
              span Hồ sơ
            a.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/profile/addresses"
              class="border-l-transparent text-[#323842] transition-colors hover:bg-[#f9fafb] hover:text-[#181b20]"
            )
              i.fa-solid.fa-location-dot(aria-hidden="true")
              span Địa chỉ
            a.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/profile/orders"
              class="border-l-transparent text-[#323842] transition-colors hover:bg-[#f9fafb] hover:text-[#181b20]"
            )
              i.fa-solid.fa-bag-shopping(aria-hidden="true")
              span Đơn hàng
            a.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/profile/settings"
              class="border-l-transparent text-[#323842] transition-colors hover:bg-[#f9fafb] hover:text-[#181b20]"
            )
              i.fa-solid.fa-gear(aria-hidden="true")
              span Cài đặt
            a#logout-link.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/auth/logout"
              class="border-l-transparent text-[#323842] transition-colors hover:bg-[#fff5f5] hover:text-red-700"
            )
              i.fa-solid.fa-right-from-bracket(aria-hidden="true")
              span Đăng xuất

        section(class="space-y-8 lg:col-span-9")
          .overflow-hidden.border.bg-white(class="border-[#dee1e6] shadow-[0_2px_4px_rgba(34,37,42,0.08)]")
            .flex.flex-col.gap-6.border-b.p-6(class="border-[#eef0f3] sm:flex-row sm:items-center sm:justify-between sm:p-8")
              .flex.items-center.gap-4
                img#profile-avatar.h-20.w-20.object-cover(
                  src="https://placehold.co/160x160/eef0f3/8c8f95?text=User"
                  alt="Avatar"
                  class="bg-[#f3f4f6]"
                )
                div
                  h2#profile-name.text-2xl.font-bold(class="text-[#0d0d0d]") Người dùng
                  p#profile-email(class="text-sm text-[#323842]") user@example.com
                  p#profile-meta.mt-1.text-xs(class="text-[#8c8f95]") Vai trò: user
              button#refresh-profile.inline-flex.h-10.items-center.justify-center.border.px-4.text-sm.font-semibold.transition-colors(
                type="button"
                class="border-[#0d0d0d] text-[#0d0d0d] hover:bg-[#0d0d0d] hover:text-white"
              )
                i.fa-solid.fa-rotate.mr-2(aria-hidden="true")
                | Tải lại dữ liệu

            .p-6(class="sm:p-8")
              form#profile-form.space-y-6
                .grid.grid-cols-1.gap-6(class="md:grid-cols-2")
                  div
                    label.block.text-sm.font-semibold.mb-2(for="username" class="text-[#181b20]") Tên người dùng
                    input#username.w-full.border.px-4.text-sm(
                      type="text"
                      name="username"
                      placeholder="Tên hiển thị"
                      class="py-2.5 border-[#dee1e6] text-[#181b20] outline-none focus:border-[#f48525] focus:ring-1 focus:ring-[#f48525]"
                    )
                  div
                    label.block.text-sm.font-semibold.mb-2(for="email" class="text-[#181b20]") Email
                    input#email.w-full.border.px-4.text-sm(
                      type="email"
                      name="email"
                      readonly
                      class="py-2.5 border-[#dee1e6] bg-[#f9fafb] text-[#323842]"
                    )

                div
                  label.block.text-sm.font-semibold.mb-2(for="avatar" class="text-[#181b20]") Cập nhật avatar
                  .flex.flex-col.gap-3(class="sm:flex-row sm:items-center")
                    input#avatar.block.w-full.text-sm(
                      type="file"
                      name="avatar"
                      accept="image/*"
                      class="text-[#323842] file:mr-4 file:border-0 file:bg-[#fff7ef] file:px-4 file:py-2 file:text-sm file:font-semibold file:text-[#f48525] hover:file:bg-[#ffe8cf]"
                    )
                    button#upload-avatar-btn.inline-flex.h-10.items-center.justify-center.gap-2.px-4.text-sm.font-semibold.text-white.transition-colors(
                      type="button"
                      class="bg-[#f48525] hover:bg-[#e07820]"
                    )
                      i.fa-solid.fa-upload(aria-hidden="true")
                      | Tải ảnh lên

                .flex.flex-col.gap-3.pt-2(class="sm:flex-row")
                  button#save-profile.inline-flex.h-11.items-center.justify-center.gap-2.px-6.text-sm.font-semibold.text-white.transition-colors(
                    type="submit"
                    class="bg-[#f48525] hover:bg-[#e07820]"
                  )
                    i.fa-solid.fa-floppy-disk(aria-hidden="true")
                    span#save-profile-text Lưu thay đổi
                    span#save-profile-loading.hidden.items-center.gap-2
                      i.fa-solid.fa-circle-notch.fa-spin(aria-hidden="true")
                      | Đang lưu...
                  a.inline-flex.h-11.items-center.justify-center.border.px-6.text-sm.font-semibold.transition-colors(
                    href="/profile/settings#mat-khau"
                    class="border-[#0d0d0d] text-[#0d0d0d] hover:bg-[#0d0d0d] hover:text-white"
                  )
                    i.fa-solid.fa-key.mr-2(aria-hidden="true")
                    | Đổi mật khẩu

          .grid.grid-cols-2.gap-4(class="sm:grid-cols-4")
            .border.bg-white.p-4.text-center(class="border-[#dee1e6]")
              p#stat-orders.text-2xl.font-bold(class="text-[#0d0d0d]") —
              p.text-xs.mt-1(class="text-[#323842]") Đơn hàng
            .border.bg-white.p-4.text-center(class="border-[#dee1e6]")
              p#stat-addresses.text-2xl.font-bold(class="text-[#0d0d0d]") —
              p.text-xs.mt-1(class="text-[#323842]") Địa chỉ
            .border.bg-white.p-4.text-center(class="border-[#dee1e6]")
              p#stat-role.text-lg.font-bold.uppercase(class="text-[#0d0d0d]") —
              p.text-xs.mt-1(class="text-[#323842]") Vai trò
            .border.bg-white.p-4.text-center(class="border-[#dee1e6]")
              p#stat-member-since.text-sm.font-bold(class="text-[#0d0d0d]") —
              p.text-xs.mt-1(class="text-[#323842]") Thành viên từ

block scripts
  script.
    (function () {
      var API_PROFILE = '/api/v1/users/profile';
      var API_UPLOAD_AVATAR = '/api/v1/users/upload-avatar';
      var token = localStorage.getItem('accessToken');

      var nameEl = document.getElementById('profile-name');
      var emailEl = document.getElementById('profile-email');
      var metaEl = document.getElementById('profile-meta');
      var avatarEl = document.getElementById('profile-avatar');
      var form = document.getElementById('profile-form');
      var usernameInput = document.getElementById('username');
      var emailInput = document.getElementById('email');
      var saveBtn = document.getElementById('save-profile');
      var saveText = document.getElementById('save-profile-text');
      var saveLoading = document.getElementById('save-profile-loading');
      var uploadBtn = document.getElementById('upload-avatar-btn');
      var avatarInput = document.getElementById('avatar');
      var refreshBtn = document.getElementById('refresh-profile');
      var logoutLink = document.getElementById('logout-link');

      function showAlert(type, message) {
        if (!window.AppNotify) return;
        if (type === 'error') return window.AppNotify.error(message);
        if (type === 'warn') return window.AppNotify.warning(message);
        return window.AppNotify.success(message);
      }

      function setSaveLoading(loading) {
        saveBtn.disabled = loading;
        if (loading) {
          saveText.classList.add('hidden');
          saveLoading.classList.remove('hidden');
          saveLoading.classList.add('inline-flex');
        } else {
          saveText.classList.remove('hidden');
          saveLoading.classList.add('hidden');
          saveLoading.classList.remove('inline-flex');
        }
      }

      function authHeaders(extra) {
        var headers = extra || {};
        if (token) headers.Authorization = 'Bearer ' + token;
        return headers;
      }

      function toDateText(v) {
        if (!v) return '—';
        var d = new Date(v);
        if (isNaN(d.getTime())) return '—';
        return d.toLocaleDateString('vi-VN');
      }

      function bindUser(user) {
        if (!user) return;
        nameEl.textContent = user.username || 'Người dùng';
        emailEl.textContent = user.email || '—';
        metaEl.textContent = 'Vai trò: ' + (user.role || 'user') + ' • Trạng thái: ' + (user.status || 'active');
        usernameInput.value = user.username || '';
        emailInput.value = user.email || '';
        if (user.avatar) avatarEl.src = user.avatar;

        document.getElementById('stat-role').textContent = (user.role || 'user');
        document.getElementById('stat-member-since').textContent = toDateText(user.createdAt);
      }

      async function loadStats() {
        if (!token) return;
        try {
          var r1 = await fetch('/api/v1/orders?limit=1', { headers: authHeaders() });
          var d1 = await r1.json().catch(function () { return {}; });
          if (d1.pagination && document.getElementById('stat-orders')) {
            document.getElementById('stat-orders').textContent = String(d1.pagination.total);
          }
          var r2 = await fetch('/api/v1/users/addresses', { headers: authHeaders() });
          var d2 = await r2.json().catch(function () { return {}; });
          var list = (d2.data && d2.data.addresses) || [];
          if (document.getElementById('stat-addresses')) {
            document.getElementById('stat-addresses').textContent = String(list.length);
          }
        } catch (e) {}
      }

      async function loadProfile() {
        if (!token) {
          showAlert('warn', 'Bạn chưa đăng nhập. Vui lòng đăng nhập để xem hồ sơ.');
          return;
        }
        try {
          var res = await fetch(API_PROFILE, { headers: authHeaders() });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) throw new Error(data.message || 'Không thể tải hồ sơ.');
          bindUser(data?.data?.user || data.user);
          loadStats();
          showAlert('success', 'Đã tải hồ sơ thành công.');
        } catch (err) {
          showAlert('error', err.message || 'Có lỗi khi tải hồ sơ.');
        }
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (!token) {
          showAlert('warn', 'Bạn cần đăng nhập trước khi cập nhật hồ sơ.');
          return;
        }
        var username = usernameInput.value.trim();
        if (!username) {
          showAlert('error', 'Tên người dùng không được để trống.');
          return;
        }
        setSaveLoading(true);
        try {
          var res = await fetch(API_PROFILE, {
            method: 'PUT',
            headers: authHeaders({ 'Content-Type': 'application/json' }),
            body: JSON.stringify({ username: username })
          });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) throw new Error(data.message || 'Cập nhật hồ sơ thất bại.');
          bindUser(data?.data?.user || data.user);
          showAlert('success', data.message || 'Cập nhật hồ sơ thành công.');
        } catch (err) {
          showAlert('error', err.message || 'Có lỗi xảy ra.');
        } finally {
          setSaveLoading(false);
        }
      });

      uploadBtn.addEventListener('click', async function () {
        if (!token) {
          showAlert('warn', 'Bạn cần đăng nhập trước khi tải avatar.');
          return;
        }
        if (!avatarInput.files || !avatarInput.files.length) {
          showAlert('error', 'Vui lòng chọn ảnh trước khi tải lên.');
          return;
        }
        var fd = new FormData();
        fd.append('avatar', avatarInput.files[0]);
        uploadBtn.disabled = true;
        try {
          var res = await fetch(API_UPLOAD_AVATAR, {
            method: 'POST',
            headers: authHeaders(),
            body: fd
          });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) throw new Error(data.message || 'Upload avatar thất bại.');
          if (data?.data?.avatar) avatarEl.src = data.data.avatar;
          showAlert('success', data.message || 'Cập nhật avatar thành công.');
        } catch (err) {
          showAlert('error', err.message || 'Có lỗi khi upload avatar.');
        } finally {
          uploadBtn.disabled = false;
        }
      });

      refreshBtn.addEventListener('click', function () {
        loadProfile();
      });

      logoutLink.addEventListener('click', function () {
        localStorage.removeItem('accessToken');
        localStorage.removeItem('refreshToken');
        localStorage.removeItem('user');
      });

      loadProfile();
    })();
