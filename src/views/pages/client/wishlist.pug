extends ../../layouts/main

block content
  section(class="bg-[#0d0d0d]")
    div(class="mx-auto max-w-[1440px] px-4 py-10 sm:px-8 lg:px-[128px]")
      p(class="text-xs font-semibold uppercase tracking-wider text-[#f48525]") Yêu thích
      h1(class="text-3xl font-bold text-white") Sản phẩm đã lưu

  div(class="bg-[#f4f5f7] pb-16 pt-8")
    div(class="mx-auto max-w-[1440px] px-4 sm:px-8 lg:px-[128px]")
      #wishlist-root.grid.gap-6(class="sm:grid-cols-2 lg:grid-cols-4")
      #wishlist-empty.hidden.border.bg-white.p-12.text-center(class="border-[#dee1e6]")
        p(class="text-[#181b20]") Chưa có sản phẩm yêu thích.
        a.mt-4.inline-block.text-sm.font-semibold(class="text-[#f48525]" href="/products") Khám phá sản phẩm

block scripts
  script.
    (function () {
      var root = document.getElementById('wishlist-root');
      var emptyEl = document.getElementById('wishlist-empty');

      function vnd(n) {
        return new Intl.NumberFormat('vi-VN').format(Math.round(Number(n) || 0)) + '₫';
      }

      async function loadOne(id) {
        var res = await fetch('/api/v1/products/' + encodeURIComponent(id));
        var data = await res.json().catch(function () { return {}; });
        if (!res.ok) return null;
        return data.data || data.product || data;
      }

      async function render() {
        var ids = window.ProToolsStore ? window.ProToolsStore.wishGet().map(String) : [];
        root.innerHTML = '';
        if (!ids.length) {
          emptyEl.classList.remove('hidden');
          root.classList.add('hidden');
          return;
        }
        emptyEl.classList.add('hidden');
        root.classList.remove('hidden');
        for (var i = 0; i < ids.length; i++) {
          var p = await loadOne(ids[i]);
          if (!p) continue;
          var card = document.createElement('article');
          card.className = 'overflow-hidden border border-[#dee1e6] bg-white shadow-sm';
          var imgU = (p.images && p.images[0]) || (p.thumbnail || '');
          if (typeof imgU === 'object' && imgU.url) imgU = imgU.url;
          var v0 = p.variants && p.variants[0];
          var price = v0 ? v0.price : p.minPrice;
          var link = '/products/' + encodeURIComponent(p._id || ids[i]);
          card.innerHTML =
            '<a class="block h-44 bg-[#f3f4f6]" href="' + link + '">' +
            (imgU
              ? '<img class="h-full w-full object-cover" src="' + imgU + '" alt="">'
              : '<div class="flex h-full items-center justify-center text-[#dee1e6]"><i class="fa-solid fa-image text-3xl"></i></div>') +
            '</a>' +
            '<div class="p-4">' +
            '<a class="line-clamp-2 text-sm font-semibold text-[#181b20] hover:text-[#f48525]" href="' + link + '">' +
            (p.name || '') +
            '</a>' +
            '<p class="mt-2 text-sm font-bold text-[#0d0d0d]">' + vnd(price) + '</p>' +
            '<div class="mt-3 flex gap-2">' +
            '<button type="button" class="flex-1 border border-[#dee1e6] py-2 text-xs font-semibold text-red-600 hover:bg-red-50 btn-rm" data-id="' +
            (p._id || ids[i]) +
            '">Xóa</button>' +
            '<a class="flex-1 bg-[#f48525] py-2 text-center text-xs font-semibold text-white hover:bg-[#e07820]" href="' +
            link +
            '">Xem</a>' +
            '</div></div>';
          root.appendChild(card);
        }
        root.querySelectorAll('.btn-rm').forEach(function (b) {
          b.addEventListener('click', function () {
            window.ProToolsStore.wishToggle(b.getAttribute('data-id'));
            render();
          });
        });
      }

      window.addEventListener('protools-wishlist-updated', render);
      render();
    })();
