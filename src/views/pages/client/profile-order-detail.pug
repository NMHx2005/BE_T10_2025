extends ../../layouts/main

block content
  section(class="bg-[#0d0d0d]")
    div(class="mx-auto max-w-[1440px] px-4 py-12 sm:px-8 lg:px-[128px] lg:py-16")
      p(class="mb-3 text-xs font-semibold uppercase tracking-wider text-[#f48525]") Tài khoản
      h1(class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-[2.5rem] lg:leading-tight") Chi tiết đơn hàng
      p(class="mt-4 max-w-2xl text-base leading-relaxed text-[#cbd6e2] sm:text-lg")
        | Thông tin sản phẩm, giao hàng và thanh toán.

  div(class="bg-[#f4f5f7] pb-16 pt-10 lg:pb-20 lg:pt-12")
    div(class="mx-auto max-w-[1440px] px-4 sm:px-8 lg:px-[128px]")
      .grid.grid-cols-1.gap-8(class="lg:grid-cols-12")
        aside(class="lg:col-span-3")
          nav(class="overflow-hidden border border-[#dee1e6] bg-white shadow-[0_2px_4px_rgba(34,37,42,0.06)]")
            a.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/profile"
              class="border-l-transparent text-[#323842] transition-colors hover:bg-[#f9fafb] hover:text-[#181b20]"
            )
              i.fa-regular.fa-user(aria-hidden="true")
              span Hồ sơ
            a.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/profile/addresses"
              class="border-l-transparent text-[#323842] transition-colors hover:bg-[#f9fafb] hover:text-[#181b20]"
            )
              i.fa-solid.fa-location-dot(aria-hidden="true")
              span Địa chỉ
            a.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/profile/orders"
              class="border-l-[#f48525] bg-[#fff7ef] text-[#181b20]"
            )
              i.fa-solid.fa-bag-shopping(aria-hidden="true")
              span Đơn hàng
            a.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/profile/settings"
              class="border-l-transparent text-[#323842] transition-colors hover:bg-[#f9fafb] hover:text-[#181b20]"
            )
              i.fa-solid.fa-gear(aria-hidden="true")
              span Cài đặt
            a#logout-link.flex.items-center.gap-3.border-l-4.px-5.py-4.text-sm.font-medium(
              href="/auth/logout"
              class="border-l-transparent text-[#323842] transition-colors hover:bg-[#fff5f5] hover:text-red-700"
            )
              i.fa-solid.fa-right-from-bracket(aria-hidden="true")
              span Đăng xuất

        section(class="space-y-6 lg:col-span-9")
          a.inline-flex.items-center.gap-2.text-sm.font-semibold(
            href="/profile/orders"
            class="text-[#f48525] hover:text-[#c45a0f]"
          )
            i.fa-solid.fa-arrow-left(aria-hidden="true")
            | Quay lại danh sách

          #order-detail-loading.overflow-hidden.border.bg-white.p-10.text-center(class="border-[#dee1e6]")
            i.fa-solid.fa-spinner.fa-spin.text-2xl(class="text-[#8c8f95]")
            p.mt-3.text-sm(class="text-[#323842]") Đang tải đơn hàng…

          #order-detail-error.hidden.overflow-hidden.border.bg-white.p-10.text-center(class="border-[#dee1e6]")
            p.font-semibold.text-red-700#order-detail-error-msg Có lỗi xảy ra.

          #order-detail-root.hidden.overflow-hidden.border.bg-white(class="border-[#dee1e6]")
            .border-b.p-6(class="border-[#eef0f3]")
              .flex.flex-col.gap-4(class="sm:flex-row sm:items-start sm:justify-between")
                div
                  p.text-sm(class="text-[#323842]") Mã đơn
                  p#od-number.text-xl.font-bold(class="text-[#0d0d0d]") —
                  p#od-date.mt-1.text-xs(class="text-[#8c8f95]")
                div.text-left(class="sm:text-right")
                  span#od-status.inline-block.rounded-full.px-3.py-1.text-xs.font-semibold —
                  p#od-total.mt-3.text-2xl.font-bold(class="text-[#0d0d0d]") —
            .p-6
              h3.mb-4.text-sm.font-bold.uppercase.tracking-wide(class="text-[#323842]") Sản phẩm
              #od-items.space-y-3
            .grid.grid-cols-1.gap-6.border-t.p-6(class="border-[#eef0f3] md:grid-cols-2")
              div
                h3.mb-3.text-sm.font-bold.uppercase.tracking-wide(class="text-[#323842]") Giao hàng
                #od-shipping.space-y-1.text-sm(class="text-[#181b20]")
              div
                h3.mb-3.text-sm.font-bold.uppercase.tracking-wide(class="text-[#323842]") Thanh toán
                #od-payment.space-y-1.text-sm(class="text-[#181b20]")
            #od-actions.hidden.border-t.p-6(class="border-[#eef0f3]")
              button#od-cancel-btn.inline-flex.h-10.items-center.justify-center.border.px-4.text-sm.font-semibold(
                type="button"
                class="border-red-200 text-red-700 hover:bg-red-50"
              ) Hủy đơn hàng

block scripts
  script.
    (function () {
      var ORDER_ID = !{JSON.stringify(orderId)};
      var API = '/api/v1/orders/' + encodeURIComponent(ORDER_ID);
      var token = localStorage.getItem('accessToken');
      var loadingEl = document.getElementById('order-detail-loading');
      var errorEl = document.getElementById('order-detail-error');
      var errorMsgEl = document.getElementById('order-detail-error-msg');
      var rootEl = document.getElementById('order-detail-root');
      var logoutLink = document.getElementById('logout-link');

      function showAlert(type, message) {
        if (!window.AppNotify) return;
        if (type === 'error') return window.AppNotify.error(message);
        if (type === 'warn') return window.AppNotify.warning(message);
        return window.AppNotify.success(message);
      }

      function authHeaders(extra) {
        var headers = Object.assign({}, extra || {});
        if (token) headers.Authorization = 'Bearer ' + token;
        return headers;
      }

      function jsonAuthHeaders() {
        return authHeaders({ 'Content-Type': 'application/json' });
      }

      function parseErr(data) {
        if (data && data.errors && data.errors.length) {
          return data.errors.map(function (e) { return e.message; }).join(' ');
        }
        return (data && data.message) || 'Có lỗi xảy ra.';
      }

      function formatMoney(n) {
        return new Intl.NumberFormat('vi-VN').format(Math.round(Number(n) || 0)) + '₫';
      }

      function statusLabel(s) {
        var m = {
          pending: 'Chờ xác nhận',
          confirmed: 'Đã xác nhận',
          processing: 'Đang xử lý',
          shipped: 'Đang giao',
          delivered: 'Đã giao',
          cancelled: 'Đã hủy',
          refunded: 'Hoàn tiền'
        };
        return m[s] || s || '—';
      }

      function statusBadgeClass(s) {
        var m = {
          pending: 'bg-amber-50 text-amber-900',
          confirmed: 'bg-sky-50 text-sky-900',
          processing: 'bg-violet-50 text-violet-900',
          shipped: 'bg-indigo-50 text-indigo-900',
          delivered: 'bg-emerald-50 text-emerald-900',
          cancelled: 'bg-red-50 text-red-800',
          refunded: 'bg-zinc-100 text-zinc-800'
        };
        return m[s] || 'bg-[#f4f5f7] text-[#181b20]';
      }

      function paymentMethodLabel(m) {
        var map = { cod: 'COD', bank_transfer: 'Chuyển khoản', credit_card: 'Thẻ', momo: 'MoMo', zalopay: 'ZaloPay' };
        return map[m] || m || '—';
      }

      function paymentStatusLabel(s) {
        var map = { pending: 'Chưa thanh toán', paid: 'Đã thanh toán', failed: 'Thất bại', refunded: 'Hoàn tiền' };
        return map[s] || s || '—';
      }

      function shippingMethodLabel(m) {
        var map = { standard: 'Tiêu chuẩn', express: 'Nhanh', overnight: 'Trong ngày' };
        return map[m] || m || '—';
      }

      function pLine(label, value) {
        var p = document.createElement('p');
        var s = document.createElement('span');
        s.className = 'font-semibold text-[#181b20]';
        s.textContent = label + ': ';
        p.appendChild(s);
        p.appendChild(document.createTextNode(value == null || value === '' ? '—' : String(value)));
        return p;
      }

      function showState(which) {
        loadingEl.classList.toggle('hidden', which !== 'loading');
        errorEl.classList.toggle('hidden', which !== 'error');
        rootEl.classList.toggle('hidden', which !== 'ok');
      }

      function renderOrder(o) {
        document.getElementById('od-number').textContent = o.orderNumber || '—';
        document.getElementById('od-date').textContent = o.createdAt
          ? 'Đặt lúc ' + new Date(o.createdAt).toLocaleString('vi-VN')
          : '';
        document.getElementById('od-total').textContent = formatMoney(o.total);
        var st = document.getElementById('od-status');
        st.textContent = statusLabel(o.status);
        st.className = 'inline-block rounded-full px-3 py-1 text-xs font-semibold ' + statusBadgeClass(o.status);

        var itemsRoot = document.getElementById('od-items');
        itemsRoot.innerHTML = '';
        (o.items || []).forEach(function (it) {
          var row = document.createElement('div');
          row.className = 'flex flex-wrap items-start justify-between gap-3 border-b py-3 last:border-0 border-[#f0f1f3]';
          var left = document.createElement('div');
          var name = (it.product && it.product.name) || it.productName || 'Sản phẩm';
          var nameEl = document.createElement('p');
          nameEl.className = 'font-medium text-[#181b20]';
          nameEl.textContent = name;
          left.appendChild(nameEl);
          if (it.variant && it.variant.name) {
            var v = document.createElement('p');
            v.className = 'text-xs text-[#8c8f95]';
            v.textContent = 'Phân loại: ' + it.variant.name;
            left.appendChild(v);
          }
          var right = document.createElement('div');
          right.className = 'text-right text-sm text-[#323842]';
          var line1 = document.createElement('div');
          line1.textContent = 'SL: ' + (it.quantity || 0) + ' × ' + formatMoney(it.price);
          var line2 = document.createElement('div');
          line2.className = 'mt-1 font-semibold text-[#0d0d0d]';
          line2.textContent = formatMoney(it.subtotal);
          right.appendChild(line1);
          right.appendChild(line2);
          row.appendChild(left);
          row.appendChild(right);
          itemsRoot.appendChild(row);
        });

        var ship = o.shippingAddress || {};
        var shipRoot = document.getElementById('od-shipping');
        shipRoot.innerHTML = '';
        ;[
          pLine('Người nhận', ship.fullName),
          pLine('Điện thoại', ship.phone),
          pLine('Địa chỉ', ship.address),
          pLine('Phường/Xã', ship.ward),
          pLine('Quận/Huyện', ship.district),
          pLine('Tỉnh/TP', ship.city),
          pLine('Ghi chú', ship.note)
        ].forEach(function (node) { shipRoot.appendChild(node); });
        var shipMeta = document.createElement('div');
        shipMeta.className = 'mt-3 space-y-1 border-t pt-3 border-[#eef0f3]';
        shipMeta.appendChild(pLine('Hình thức', shippingMethodLabel(o.shipping && o.shipping.method)));
        shipMeta.appendChild(pLine('Vận đơn', (o.shipping && o.shipping.trackingNumber) || '—'));
        shipRoot.appendChild(shipMeta);

        var payRoot = document.getElementById('od-payment');
        payRoot.innerHTML = '';
        payRoot.appendChild(pLine('Phương thức', paymentMethodLabel(o.payment && o.payment.method)));
        payRoot.appendChild(pLine('Trạng thái', paymentStatusLabel(o.payment && o.payment.status)));
        payRoot.appendChild(pLine('Tạm tính', formatMoney(o.subtotal)));
        payRoot.appendChild(pLine('Phí ship', formatMoney(o.shippingFee)));
        payRoot.appendChild(pLine('Giảm giá', formatMoney(o.discount)));
        if (o.notes) payRoot.appendChild(pLine('Ghi chú đơn', o.notes));

        var actions = document.getElementById('od-actions');
        var cancelBtn = document.getElementById('od-cancel-btn');
        if (o.status === 'pending' || o.status === 'confirmed') {
          actions.classList.remove('hidden');
          cancelBtn.onclick = async function () {
            if (!confirm('Hủy đơn hàng này?')) return;
            try {
              var res = await fetch(API + '/cancel', {
                method: 'PATCH',
                headers: jsonAuthHeaders(),
                body: JSON.stringify({ reason: 'Khách hàng hủy từ chi tiết đơn' })
              });
              var data = await res.json().catch(function () { return {}; });
              if (!res.ok) throw new Error(parseErr(data));
              showAlert('success', data.message || 'Đã hủy đơn hàng.');
              window.location.href = '/profile/orders';
            } catch (err) {
              showAlert('error', err.message || 'Không hủy được đơn.');
            }
          };
        } else {
          actions.classList.add('hidden');
        }
      }

      async function load() {
        if (!token) {
          showState('error');
          errorMsgEl.textContent = 'Bạn cần đăng nhập để xem đơn hàng.';
          showAlert('warn', 'Bạn chưa đăng nhập.');
          return;
        }
        showState('loading');
        try {
          var res = await fetch(API, { headers: authHeaders() });
          var data = await res.json().catch(function () { return {}; });
          if (res.status === 401) throw new Error('Phiên đăng nhập hết hạn.');
          if (!res.ok) throw new Error(parseErr(data));
          var o = data.data;
          if (!o) throw new Error('Không có dữ liệu đơn hàng.');
          renderOrder(o);
          showState('ok');
        } catch (err) {
          errorMsgEl.textContent = err.message || 'Không tải được đơn hàng.';
          showState('error');
          showAlert('error', err.message || '');
        }
      }

      if (logoutLink) {
        logoutLink.addEventListener('click', function () {
          localStorage.removeItem('accessToken');
          localStorage.removeItem('refreshToken');
          localStorage.removeItem('user');
        });
      }

      load();
    })();
