extends ../../layouts/main

block content
  section(class="bg-[#0d0d0d]")
    div(class="mx-auto max-w-[1440px] px-4 py-10 sm:px-8 lg:px-[128px]")
      p(class="text-xs font-semibold uppercase tracking-wider text-[#f48525]") Giỏ hàng
      h1(class="text-3xl font-bold text-white") Sản phẩm đã chọn

  div(class="bg-[#f4f5f7] pb-16 pt-8")
    div(class="mx-auto max-w-[1440px] px-4 sm:px-8 lg:px-[128px]")
      #cart-root.grid.grid-cols-1.gap-8(class="lg:grid-cols-12")
        #cart-lines.space-y-4(class="lg:col-span-8")
        aside(class="lg:col-span-4")
          .border.bg-white.p-6(class="border-[#dee1e6]")
            h2.text-lg.font-bold(class="text-[#0d0d0d]") Tóm tắt
            .mt-4.space-y-2.text-sm(class="text-[#323842]")
              .flex.justify-between
                span Tạm tính
                span#cart-sub.font-semibold(class="text-[#181b20]") 0₫
              .flex.justify-between
                span Phí vận chuyển
                span Ước tính khi thanh toán
            .mt-6.flex.flex-col.gap-3
              a#cart-checkout.inline-flex.h-11.items-center.justify-center.text-sm.font-semibold.text-white(
                href="/checkout"
                class="bg-[#f48525] hover:bg-[#e07820]"
              ) Tiến hành thanh toán
              button#cart-clear.inline-flex.h-10.items-center.justify-center.border.text-sm.font-semibold(
                type="button"
                class="border-[#dee1e6] text-[#181b20] hover:bg-[#f9fafb]"
              ) Xóa giỏ hàng
      #cart-empty.hidden.border.bg-white.p-12.text-center(class="border-[#dee1e6]")
        p.font-semibold(class="text-[#181b20]") Giỏ hàng trống
        a.mt-6.inline-flex.items-center.text-sm.font-semibold.text-white(
          href="/products"
          class="bg-[#0d0d0d] px-6 py-3 hover:bg-[#323842]"
        ) Mua sắm ngay

block scripts
  script.
    (function () {
      var root = document.getElementById('cart-root');
      var linesEl = document.getElementById('cart-lines');
      var subEl = document.getElementById('cart-sub');
      var emptyEl = document.getElementById('cart-empty');
      var clearBtn = document.getElementById('cart-clear');
      var checkoutBtn = document.getElementById('cart-checkout');

      function vnd(n) {
        return new Intl.NumberFormat('vi-VN').format(Math.round(Number(n) || 0)) + '₫';
      }

      function render() {
        var items = window.ProToolsStore ? window.ProToolsStore.cartGet() : [];
        if (!items.length) {
          root.classList.add('hidden');
          emptyEl.classList.remove('hidden');
          return;
        }
        root.classList.remove('hidden');
        emptyEl.classList.add('hidden');
        linesEl.innerHTML = '';
        var sub = 0;
        items.forEach(function (it) {
          var line = (Number(it.price) || 0) * (Number(it.quantity) || 0);
          sub += line;
          var card = document.createElement('div');
          card.className = 'flex flex-col gap-4 border border-[#dee1e6] bg-white p-4 sm:flex-row sm:items-center';
          var imgWrap = document.createElement('a');
          imgWrap.href = '/products/' + encodeURIComponent(it.productId);
          imgWrap.className = 'shrink-0';
          var img = document.createElement('img');
          img.className = 'h-24 w-24 rounded object-cover bg-[#f3f4f6]';
          img.alt = it.name || '';
          img.src = it.image || 'https://placehold.co/96x96/eef0f3/8c8f95?text=P';
          imgWrap.appendChild(img);
          var mid = document.createElement('div');
          mid.className = 'min-w-0 flex-1';
          var a = document.createElement('a');
          a.href = '/products/' + encodeURIComponent(it.productId);
          a.className = 'font-semibold text-[#181b20] hover:text-[#f48525]';
          a.textContent = it.name || 'Sản phẩm';
          mid.appendChild(a);
          if (it.sku) {
            var sku = document.createElement('p');
            sku.className = 'text-xs text-[#8c8f95]';
            sku.textContent = 'SKU: ' + it.sku;
            mid.appendChild(sku);
          }
          var price = document.createElement('p');
          price.className = 'mt-1 text-sm font-medium text-[#0d0d0d]';
          price.textContent = vnd(it.price) + ' × ' + (it.quantity || 0);
          mid.appendChild(price);
          var actions = document.createElement('div');
          actions.className = 'flex flex-wrap items-center gap-2 sm:flex-col sm:items-end';
          var row = document.createElement('div');
          row.className = 'inline-flex items-center border border-[#dee1e6]';
          var dec = document.createElement('button');
          dec.type = 'button';
          dec.className = 'h-9 w-9 text-[#323842] hover:bg-[#f4f5f7]';
          dec.textContent = '−';
          dec.addEventListener('click', function () {
            window.ProToolsStore.cartSetQty(it.productId, it.variantId, (Number(it.quantity) || 1) - 1);
            render();
          });
          var num = document.createElement('span');
          num.className = 'min-w-[2rem] text-center text-sm';
          num.textContent = String(it.quantity || 0);
          var inc = document.createElement('button');
          inc.type = 'button';
          inc.className = 'h-9 w-9 text-[#323842] hover:bg-[#f4f5f7]';
          inc.textContent = '+';
          inc.addEventListener('click', function () {
            window.ProToolsStore.cartSetQty(it.productId, it.variantId, (Number(it.quantity) || 0) + 1);
            render();
          });
          row.appendChild(dec);
          row.appendChild(num);
          row.appendChild(inc);
          actions.appendChild(row);
          var del = document.createElement('button');
          del.type = 'button';
          del.className = 'text-sm font-semibold text-red-600 hover:underline';
          del.textContent = 'Xóa';
          del.addEventListener('click', function () {
            window.ProToolsStore.cartRemove(it.productId, it.variantId);
            render();
          });
          actions.appendChild(del);
          card.appendChild(imgWrap);
          card.appendChild(mid);
          card.appendChild(actions);
          linesEl.appendChild(card);
        });
        subEl.textContent = vnd(sub);
      }

      clearBtn.addEventListener('click', function () {
        if (!confirm('Xóa toàn bộ giỏ hàng?')) return;
        window.ProToolsStore.cartClear();
        render();
      });

      window.addEventListener('protools-cart-updated', render);
      render();
    })();
