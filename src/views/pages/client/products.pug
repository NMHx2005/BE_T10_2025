extends ../../../layouts/main
include ../../../mixins/cards
include ../../../mixins/buttons

block content
  .max-w-7xl.mx-auto.px-4(class="sm:px-6 lg:px-8 py-12")
    // Page Header
    .mb-8
      h1.text-4xl.font-bold.text-gray-900.mb-2 Products
      p.text-lg.text-gray-600 Browse our complete product catalog
    
    // Filter Section
    .grid.grid-cols-1(class="lg:grid-cols-4 gap-8")
      // Filters Sidebar
      aside.bg-white.rounded-lg.shadow-md.p-6.h-fit
        h2.text-lg.font-semibold.text-gray-900.mb-6 Filters
        
        form.space-y-6(id="filter-form")
          // Search
          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-2(for="search") Search
            input.form-input.w-full.px-3.py-2.border.border-gray-300.rounded-md.focus:outline-none.focus:ring-2.focus:ring-blue-500(
              type="text",
              id="search",
              name="search",
              placeholder="Search products..."
            )
          
          // Price Range
          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-2 Price Range
            .space-y-3
              .flex.gap-2
                input.form-input.w-1/2.px-3.py-2.border.border-gray-300.rounded-md(
                  type="number",
                  name="minPrice",
                  placeholder="Min",
                  min="0"
                )
                input.form-input.w-1/2.px-3.py-2.border.border-gray-300.rounded-md(
                  type="number",
                  name="maxPrice",
                  placeholder="Max"
                )
          
          // Category Filter
          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-3 Categories
            .space-y-2
              if categories && categories.length > 0
                each category in categories
                  .flex.items-center
                    input.w-4.h-4.rounded.border-gray-300(
                      type="checkbox",
                      name="category",
                      value=category._id,
                      id=`cat-${category._id}`
                    )
                    label.ml-3.text-sm.text-gray-600.cursor-pointer(for=`cat-${category._id}`)
                      = category.name
              else
                p.text-sm.text-gray-500 No categories available
          
          // Brand Filter (if applicable)
          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-3 Brand
            input.form-input.w-full.px-3.py-2.border.border-gray-300.rounded-md(
              type="text",
              name="brand",
              placeholder="Filter by brand"
            )
          
          // Sort
          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-2(for="sort") Sort By
            select.form-input.w-full.px-3.py-2.border.border-gray-300.rounded-md.focus:ring-2.focus:ring-blue-500(
              id="sort",
              name="sort"
            )
              option(value="newest", selected) Newest
              option(value="oldest") Oldest
              option(value="price_asc") Price: Low to High
              option(value="price_desc") Price: High to Low
              option(value="name_asc") Name: A to Z
              option(value="name_desc") Name: Z to A
          
          // Apply Filters Button
          .flex.gap-2
            button.flex-1.bg-blue-600.hover:bg-blue-700.text-white.font-medium.py-2.px-4.rounded-lg.transition-colors(
              type="submit",
              form="filter-form"
            )
              i.fas.fa-filter.mr-2
              | Apply Filters
            
            a.flex-1.text-center.bg-gray-200.hover:bg-gray-300.text-gray-800.font-medium.py-2.px-4.rounded-lg.transition-colors(
              href="/products"
            )
              i.fas.fa-redo.mr-2
              | Clear

      // Products Grid
      .col-span-1(class="lg:col-span-3")
        // Results Info
        if totalItems !== undefined
          .mb-6.flex.justify-between.items-center
            p.text-gray-600
              | Showing 
              span.font-semibold= (page - 1) * limit + 1
              |  to 
              span.font-semibold= Math.min(page * limit, totalItems)
              |  of 
              span.font-semibold= totalItems
              |  products
        
        // Products Grid
        if products && products.length > 0
          .grid.grid-cols-1(class="md:grid-cols-2 gap-6 mb-8")
            each product in products
              .bg-white.rounded-lg.shadow-md.border.border-gray-200.overflow-hidden(class="hover:shadow-lg transition-shadow duration-300")
                // Product Image
                a.block.relative.h-48.bg-gray-200.overflow-hidden(href=`/products/${product._id}`)
                  if product.thumbnail
                    img.w-full.h-full.object-cover(src=product.thumbnail, alt=product.name)
                  else if product.images && product.images.length > 0
                    img.w-full.h-full.object-cover(src=product.images[0], alt=product.name)
                  else
                    .w-full.h-full.flex.items-center.justify-center.bg-gray-100
                      i.fas.fa-image.text-gray-400.text-4xl
                  
                  // Category Badge
                  if product.category
                    .absolute.top-2.left-2.bg-blue-600.text-white.px-3.py-1.rounded-full.text-xs.font-medium
                      = product.category.name || 'Uncategorized'
                
                // Product Info
                .p-6
                  h3.text-lg.font-semibold.text-gray-900.mb-2
                    a.hover:text-blue-600.transition-colors(href=`/products/${product._id}`)
                      = product.name
                  
                  p.text-gray-600.text-sm.mb-4
                    = product.description ? product.description.substring(0, 80) + '...' : 'No description'
                  
                  // Rating
                  if product.rating
                    .flex.items-center.mb-4
                      .flex.text-yellow-400
                        - let stars = Math.round(product.rating.average || 0)
                        - for (let i = 0; i < 5; i++) {
                          if i < stars
                            i.fas.fa-star
                          else
                            i.far.fa-star
                        - }
                      span.text-sm.text-gray-600.ml-2
                        = `${product.rating.average || 0}/5 (${product.rating.count || 0} reviews)`
                  
                  // Price & Stock
                  .flex.justify-between.items-end
                    .flex.flex-col
                      span.text-2xl.font-bold.text-blue-600 $#{product.price}
                      if product.stock > 0
                        span.text-xs.text-green-600.font-medium
                          = product.stock + ' in stock'
                      else
                        span.text-xs.text-red-600.font-medium Out of stock
                    
                    // Action Button
                    if product.stock > 0
                      a.bg-blue-600.hover:bg-blue-700.text-white.font-medium.py-2.px-4.rounded-lg.transition-colors.inline-flex.items-center.gap-2(
                        href=`/products/${product._id}`
                      )
                        i.fas.fa-eye
                        | View
                    else
                      button.bg-gray-400.cursor-not-allowed.text-white.font-medium.py-2.px-4.rounded-lg.inline-flex.items-center.gap-2(
                        disabled
                      )
                        i.fas.fa-ban
                        | Out of Stock
        else
          // No Products
          .text-center.py-12.bg-white.rounded-lg.border.border-gray-200
            i.fas.fa-inbox.text-gray-400.text-5xl.mb-4
            h3.text-xl.font-semibold.text-gray-900.mb-2 No products found
            p.text-gray-600.mb-6 Try adjusting your filters or search criteria
            a.inline-block.bg-blue-600.hover:bg-blue-700.text-white.font-medium.py-2.px-6.rounded-lg.transition-colors(
              href="/products"
            )
              i.fas.fa-redo.mr-2
              | Clear Filters

        // Pagination
        if totalPages && totalPages > 1
          .flex.justify-center.items-center.gap-2.mt-8
            if page > 1
              a.px-3.py-2.border.border-gray-300.rounded-md.text-gray-700.hover:bg-gray-50.transition-colors(
                href=`/products?page=${page - 1}${minPrice ? `&minPrice=${minPrice}` : ''}${maxPrice ? `&maxPrice=${maxPrice}` : ''}${sort ? `&sort=${sort}` : ''}`
              )
                i.fas.fa-chevron-left.mr-1
                | Previous
            
            .flex.gap-1
              - for (let i = Math.max(1, page - 2); i <= Math.min(totalPages, page + 2); i++) {
                if i === page
                  .px-3.py-2.bg-blue-600.text-white.rounded-md.font-medium
                    = i
                else
                  a.px-3.py-2.border.border-gray-300.rounded-md.text-gray-700.hover:bg-gray-50.transition-colors(
                    href=`/products?page=${i}${minPrice ? `&minPrice=${minPrice}` : ''}${maxPrice ? `&maxPrice=${maxPrice}` : ''}${sort ? `&sort=${sort}` : ''}`
                  )
                    = i
              - }
            
            if page < totalPages
              a.px-3.py-2.border.border-gray-300.rounded-md.text-gray-700.hover:bg-gray-50.transition-colors(
                href=`/products?page=${page + 1}${minPrice ? `&minPrice=${minPrice}` : ''}${maxPrice ? `&maxPrice=${maxPrice}` : ''}${sort ? `&sort=${sort}` : ''}`
              )
                | Next
                i.fas.fa-chevron-right.ml-1
