extends ../../../layouts/main

block content
  .max-w-7xl.mx-auto.px-4(class="sm:px-6 lg:px-8 py-12")
    .grid.grid-cols-1(class="lg:grid-cols-4 gap-8")
      // Sidebar Navigation
      aside.bg-white.rounded-lg.shadow-md.h-fit
        nav.flex.flex-col
          a.px-6.py-4.text-gray-700.hover:bg-gray-50.border-l-4.border-l-transparent(href="/profile")
            i.fas.fa-user.mr-3
            | Profile
          a.px-6.py-4.text-gray-700.hover:bg-gray-50.border-l-4.border-l-transparent(href="/profile/addresses")
            i.fas.fa-map-marker.mr-3
            | Addresses
          a.px-6.py-4.text-gray-700.hover:bg-gray-50.border-l-4.border-l-blue-600.font-medium(href="/profile/orders")
            i.fas.fa-shopping-bag.mr-3
            | My Orders
          a.px-6.py-4.text-gray-700.hover:bg-gray-50.border-l-4.border-l-transparent(href="/profile/settings")
            i.fas.fa-cog.mr-3
            | Settings
          a.px-6.py-4.text-gray-700.hover:bg-gray-50.border-l-4.border-l-transparent(href="/logout")
            i.fas.fa-sign-out-alt.mr-3
            | Logout

      // Main Content
      .col-span-1(class="lg:col-span-3")
        // Header
        .mb-8
          h1.text-3xl.font-bold.text-gray-900 My Orders
          p.text-gray-600.mt-2 View and manage your orders

        // Filters
        .bg-white.rounded-lg.shadow-md.p-4.mb-6
          .flex.flex-col(class="md:flex-row gap-4")
            .flex-1
              input.form-input.w-full.px-4.py-2.border.border-gray-300.rounded-lg.focus:ring-2.focus:ring-blue-500(
                type="text",
                placeholder="Search by order number...",
                id="search-input"
              )
            
            select.form-input.px-4.py-2.border.border-gray-300.rounded-lg.focus:ring-2.focus:ring-blue-500(
              id="status-filter"
            )
              option(value="") All Orders
              option(value="pending") Pending
              option(value="confirmed") Confirmed
              option(value="processing") Processing
              option(value="shipped") Shipped
              option(value="delivered") Delivered
              option(value="cancelled") Cancelled

        if orders && orders.length > 0
          // Orders List
          .space-y-4
            each order in orders
              .bg-white.rounded-lg.shadow-md.border.border-gray-200.overflow-hidden.hover:shadow-lg.transition-shadow

                // Order Header
                .bg-gray-50.px-6.py-4.border-b.border-gray-200
                  .flex.items-center.justify-between(class="md:flex-row flex-col gap-4")
                    .flex-1
                      p.text-sm.text-gray-600 Order #
                        span.font-bold.text-gray-900
                          = order.orderNumber
                      p.text-xs.text-gray-500.mt-1
                        = new Date(order.createdAt).toLocaleDateString()
                    
                    .flex.items-center.gap-4(class="md:flex-row flex-col")
                      .text-right
                        p.text-sm.text-gray-600 Total
                        p.text-lg.font-bold.text-gray-900
                          = '$' + order.total.toFixed(2)
                      
                      // Status Badge
                      span(class={
                        'pending': 'bg-yellow-100 text-yellow-800',
                        'confirmed': 'bg-blue-100 text-blue-800',
                        'processing': 'bg-purple-100 text-purple-800',
                        'shipped': 'bg-indigo-100 text-indigo-800',
                        'delivered': 'bg-green-100 text-green-800',
                        'cancelled': 'bg-red-100 text-red-800'
                      }[order.status]}.px-3.py-1.rounded-full.text-xs.font-semibold)
                        if order.status === 'pending'
                          i.fas.fa-clock.mr-1
                          | Pending
                        else if order.status === 'confirmed'
                          i.fas.fa-check.mr-1
                          | Confirmed
                        else if order.status === 'processing'
                          i.fas.fa-spinner.mr-1
                          | Processing
                        else if order.status === 'shipped'
                          i.fas.fa-truck.mr-1
                          | Shipped
                        else if order.status === 'delivered'
                          i.fas.fa-check-circle.mr-1
                          | Delivered
                        else if order.status === 'cancelled'
                          i.fas.fa-times-circle.mr-1
                          | Cancelled

                // Order Items
                .px-6.py-4.border-b.border-gray-200
                  if order.items && order.items.length > 0
                    .space-y-2
                      each item in order.items.slice(0, 2)
                        .flex.items-center.justify-between.text-sm
                          .flex-1
                            p.text-gray-900
                              = item.productName + ' × ' + item.quantity
                            if item.variant && item.variant.name
                              p.text-xs.text-gray-500
                                = 'Variant: ' + item.variant.name
                          p.font-medium.text-gray-900
                            = '$' + item.subtotal.toFixed(2)
                      
                      if order.items.length > 2
                        p.text-xs.text-gray-500.text-center.pt-2
                          = '+ ' + (order.items.length - 2) + ' more item(s)'

                // Order Details
                .px-6.py-4.bg-gray-50.text-sm.text-gray-600.grid.grid-cols-2(class="md:grid-cols-4 gap-4")
                  .flex.items-center.gap-2
                    i.fas.fa-map-marker.text-gray-400
                    .flex.flex-col
                      p.font-medium.text-gray-700 Shipping
                      p
                        = order.shippingAddress?.city || 'N/A'
                  
                  .flex.items-center.gap-2
                    i.fas.fa-truck.text-gray-400
                    .flex.flex-col
                      p.font-medium.text-gray-700 Method
                      p
                        = order.shipping?.method || 'Standard'
                  
                  .flex.items-center.gap-2
                    i.fas.fa-credit-card.text-gray-400
                    .flex.flex-col
                      p.font-medium.text-gray-700 Payment
                      p(class={
                        'paid': 'text-green-600',
                        'pending': 'text-yellow-600',
                        'failed': 'text-red-600'
                      }[order.payment?.status])
                        if order.payment?.status === 'paid'
                          i.fas.fa-check-circle.mr-1
                        else if order.payment?.status === 'pending'
                          i.fas.fa-clock.mr-1
                        else
                          i.fas.fa-times-circle.mr-1
                        = order.payment?.status || 'Pending'
                  
                  .flex.items-center.gap-2
                    i.fas.fa-barcode.text-gray-400
                    .flex.flex-col
                      p.font-medium.text-gray-700 Tracking
                      p
                        = order.shipping?.trackingNumber || 'N/A'

                // Order Actions
                .px-6.py-4.flex.gap-2.justify-between(class="md:justify-end")
                  a.px-4.py-2.border.border-gray-300.rounded-lg.text-gray-700.hover:bg-gray-50.transition-colors.flex.items-center.gap-2.text-sm(
                    href=`/profile/orders/${order._id}`
                  )
                    i.fas.fa-eye
                    | View Details
                  
                  if order.status === 'pending' || order.status === 'confirmed'
                    button.px-4.py-2.border.border-red-300.text-red-600.rounded-lg.hover:bg-red-50.transition-colors.flex.items-center.gap-2.text-sm(
                      type="button",
                      onclick=`cancelOrder('${order._id}')`
                    )
                      i.fas.fa-times
                      | Cancel Order
                  
                  if order.status === 'delivered'
                    a.px-4.py-2.bg-blue-600.text-white.rounded-lg.hover:bg-blue-700.transition-colors.flex.items-center.gap-2.text-sm(
                      href=`/products?reorder=${order._id}`
                    )
                      i.fas.fa-redo
                      | Reorder

        else
          // No Orders
          .bg-white.rounded-lg.shadow-md.p-12.text-center
            i.fas.fa-shopping-bag.text-gray-400.text-5xl.mb-4
            h3.text-xl.font-semibold.text-gray-900.mb-2 No Orders Yet
            p.text-gray-600.mb-6 Start shopping to see your orders here
            a.inline-block.bg-blue-600.hover:bg-blue-700.text-white.font-medium.py-2.px-6.rounded-lg.transition-colors(
              href="/products"
            )
              i.fas.fa-shopping-cart.mr-2
              | Continue Shopping

        // Pagination (if needed)
        if pagination && pagination.pages > 1
          .flex.justify-center.items-center.gap-2.mt-8
            if pagination.page > 1
              a.px-3.py-2.border.border-gray-300.rounded-md.text-gray-700.hover:bg-gray-50.transition-colors(
                href=`/profile/orders?page=${pagination.page - 1}`
              )
                i.fas.fa-chevron-left.mr-1
                | Previous
            
            .flex.gap-1
              - for (let i = 1; i <= pagination.pages; i++) {
                if i === pagination.page
                  .px-3.py-2.bg-blue-600.text-white.rounded-md.font-medium
                    = i
                else if i === 1 || i === pagination.pages || (i >= pagination.page - 1 && i <= pagination.page + 1)
                  a.px-3.py-2.border.border-gray-300.rounded-md.text-gray-700.hover:bg-gray-50.transition-colors(
                    href=`/profile/orders?page=${i}`
                  )
                    = i
                else if i === pagination.page - 2 || i === pagination.page + 2
                  .px-3.py-2.text-gray-400
                    | ...
              - }
            
            if pagination.page < pagination.pages
              a.px-3.py-2.border.border-gray-300.rounded-md.text-gray-700.hover:bg-gray-50.transition-colors(
                href=`/profile/orders?page=${pagination.page + 1}`
              )
                | Next
                i.fas.fa-chevron-right.ml-1

