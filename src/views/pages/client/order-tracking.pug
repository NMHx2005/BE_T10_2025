extends ../../layouts/main

block content
  section(class="bg-[#0d0d0d]")
    div(class="mx-auto max-w-[1440px] px-4 py-10 sm:px-8 lg:px-[128px]")
      p(class="text-xs font-semibold uppercase tracking-wider text-[#f48525]") Tra cứu
      h1(class="text-3xl font-bold text-white") Theo dõi đơn hàng

  div(class="bg-[#f4f5f7] pb-16 pt-8")
    div(class="mx-auto max-w-2xl px-4")
      .border.bg-white.p-6(class="border-[#dee1e6]")
        p.text-sm(class="text-[#323842]")
          | Nhập mã đơn hàng (VD: ORD-20250417-001) và số điện thoại người nhận như khi đặt hàng.
        form#track-form.mt-4.space-y-4
          div
            label.block.text-sm.font-semibold.mb-1(for="track-order") Mã đơn
            input#track-order.w-full.border.px-3.text-sm(class="py-2 border-[#dee1e6]" type="text" required)
          div
            label.block.text-sm.font-semibold.mb-1(for="track-phone") Điện thoại người nhận
            input#track-phone.w-full.border.px-3.text-sm(class="py-2 border-[#dee1e6]" type="tel" required placeholder="0xxxxxxxxx")
          button#track-submit.inline-flex.h-11.w-full.items-center.justify-center.text-sm.font-semibold.text-white(
            type="submit"
            class="bg-[#0d0d0d] hover:bg-[#323842]"
          ) Tra cứu
      #track-result.hidden.mt-8.border.bg-white.p-6(class="border-[#dee1e6]")
        h2.text-lg.font-bold(class="text-[#0d0d0d]") Kết quả
        #track-result-body.mt-3.text-sm(class="text-[#323842]")

block scripts
  script.
    (function () {
      var API = '/api/v1/orders/lookup';
      var form = document.getElementById('track-form');
      var result = document.getElementById('track-result');
      var body = document.getElementById('track-result-body');

      function showAlert(type, message) {
        if (!window.AppNotify) return;
        if (type === 'error') return window.AppNotify.error(message);
        return window.AppNotify.success(message);
      }

      function vnd(n) {
        return new Intl.NumberFormat('vi-VN').format(Math.round(Number(n) || 0)) + '₫';
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var orderNumber = document.getElementById('track-order').value.trim();
        var phone = document.getElementById('track-phone').value.trim();
        try {
          var res = await fetch(API, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ orderNumber: orderNumber, phone: phone }),
          });
          var data = await res.json().catch(function () { return {}; });
          if (!res.ok) throw new Error(data.message || 'Không tìm thấy.');
          var o = data.data;
          result.classList.remove('hidden');
          var lines = (o.items || [])
            .map(function (it) {
              return '<li>' + (it.productName || '') + ' × ' + (it.quantity || 0) + ' — ' + vnd(it.subtotal) + '</li>';
            })
            .join('');
          body.innerHTML =
            '<p><strong>Mã:</strong> ' +
            (o.orderNumber || '') +
            '</p>' +
            '<p><strong>Trạng thái:</strong> ' +
            (o.status || '') +
            '</p>' +
            '<p><strong>Thanh toán:</strong> ' +
            (o.payment && o.payment.status ? o.payment.status : '') +
            '</p>' +
            '<p><strong>Tổng:</strong> ' +
            vnd(o.total) +
            '</p>' +
            '<ul class="mt-2 list-disc pl-5">' +
            lines +
            '</ul>';
          showAlert('success', 'Đã tìm thấy đơn hàng.');
        } catch (err) {
          result.classList.add('hidden');
          showAlert('error', err.message || 'Tra cứu thất bại.');
        }
      });
    })();
