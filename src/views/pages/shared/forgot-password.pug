extends ../../layouts/auth

block content
  .auth-card(class="p-8 sm:p-10")
    a.inline-flex.items-center.gap-2.text-sm.font-medium.mb-8(href="/auth/login" class="text-[#323842] hover:text-[#f48525]")
      i.fa-solid.fa-arrow-left
      span Quay lại đăng nhập

    .text-center.mb-8
      .inline-flex.items-center.justify-center.w-14.h-14.text-white.text-2xl.shadow-lg.mb-4(class="bg-[#f48525]")
        i.fa-solid.fa-key
      h1(class="text-2xl sm:text-3xl font-bold text-[#0d0d0d] tracking-tight") Quên mật khẩu
      p(class="text-[#323842] mt-2 text-sm sm:text-base")
        | Nhập email đăng ký. Hệ thống sẽ gửi link đặt lại mật khẩu khi API quên mật khẩu được bật.

    #auth-alert.hidden.mb-6.rounded-xl.px-4.py-3.text-sm.font-medium(role="alert")

    form#forgot-password-form.space-y-5
      div(class="space-y-1.5")
        label.block.text-sm.font-semibold(for="email" class="text-[#181b20]") Email
        .relative
          i.fa-regular.fa-envelope.absolute.left-3.text-sm.pointer-events-none(class="top-1/2 -translate-y-1/2 text-[#323842]")
          input#email.auth-input(
            type="email"
            name="email"
            placeholder="you@example.com"
            required
            autocomplete="email"
          )

      button#forgot-submit.auth-btn-primary(type="submit")
        span#forgot-submit-text Gửi yêu cầu
        span#forgot-submit-loading.hidden.items-center.gap-2
          i.fa-solid.fa-circle-notch.fa-spin
          span Đang xử lý...

    .mt-8.p-4.border(class="border-[#dee1e6] bg-[#f9fafb]")
      p.text-sm(class="text-[#323842]")
        i.fa-solid.fa-circle-info.mr-2(class="text-[#f48525]")
        | API `POST /api/v1/auth/forgot-password` hiện chưa có trong backend, nên trang này sẽ báo trạng thái rõ ràng thay vì giả lập gửi mail.

block scripts
  script.
    (function () {
      var API_FORGOT = '/api/v1/auth/forgot-password';
      var form = document.getElementById('forgot-password-form');
      var submitBtn = document.getElementById('forgot-submit');
      var submitText = document.getElementById('forgot-submit-text');
      var submitLoading = document.getElementById('forgot-submit-loading');

      function showAlert(type, message) {
        if (!window.AppNotify) return;
        if (type === 'error') return window.AppNotify.error(message);
        if (type === 'warn') return window.AppNotify.warning(message);
        return window.AppNotify.success(message);
      }

      function setLoading(loading) {
        submitBtn.disabled = loading;
        if (loading) {
          submitText.classList.add('hidden');
          submitLoading.classList.remove('hidden');
          submitLoading.classList.add('inline-flex');
        } else {
          submitText.classList.remove('hidden');
          submitLoading.classList.add('hidden');
          submitLoading.classList.remove('inline-flex');
        }
      }

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        var email = document.getElementById('email').value.trim();
        if (!email) {
          showAlert('error', 'Vui lòng nhập email.');
          return;
        }

        setLoading(true);
        try {
          var res = await fetch(API_FORGOT, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email })
          });
          var data = await res.json().catch(function () { return {}; });

          if (res.status === 404) {
            showAlert('warn', 'Backend hiện chưa triển khai endpoint quên mật khẩu (`POST /api/v1/auth/forgot-password`).');
            return;
          }

          if (!res.ok) {
            throw new Error(data.message || 'Không thể gửi yêu cầu quên mật khẩu.');
          }

          showAlert('success', data.message || 'Đã gửi email đặt lại mật khẩu.');
        } catch (err) {
          showAlert('error', err.message || 'Có lỗi xảy ra.');
        } finally {
          setLoading(false);
        }
      });
    })();
