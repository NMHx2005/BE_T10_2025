extends ../../layouts/auth

block content
  .min-h-screen.bg-gradient-to-br.from-blue-600.to-blue-800.flex.items-center.justify-center.px-4.py-12
    .w-full.max-w-md
      // Card
      .bg-white.rounded-lg.shadow-lg.p-8

        // Header
        .text-center.mb-8
          .inline-block.w-12.h-12.rounded-full.bg-blue-100.flex.items-center.justify-center.mb-4
            i.fas.fa-key.text-blue-600.text-xl
          h1.text-2xl.font-bold.text-gray-900 Forgot Password
          p.text-gray-600.mt-2
            | Enter your email and we'll send you a link to reset your password

        // Alert Messages
        if error
          .mb-6.p-4.bg-red-50.border.border-red-200.rounded-lg
            p.text-sm.text-red-800
              i.fas.fa-exclamation-circle.mr-2
              = error

        if success
          .mb-6.p-4.bg-green-50.border.border-green-200.rounded-lg
            p.text-sm.text-green-800
              i.fas.fa-check-circle.mr-2
              = success

        // Form
        form.space-y-4(method="POST", action="/forgot-password", id="forgot-password-form")
          // Email Field
          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-2(for="email")
              i.fas.fa-envelope.mr-2.text-blue-600
              | Email Address
            input.form-input.w-full.px-4.py-3.border.border-gray-300.rounded-lg.focus:ring-2.focus:ring-blue-500.focus:border-transparent.transition(
              type="email",
              id="email",
              name="email",
              placeholder="you@example.com",
              required,
              autofocus
            )
            p.text-xs.text-gray-500.mt-1 We'll send a reset link to this email

          // Submit Button
          button.w-full.px-4.py-3.bg-blue-600.hover:bg-blue-700.text-white.rounded-lg.font-semibold.transition.flex.items-center.justify-center.gap-2(
            type="submit"
          )
            i.fas.fa-paper-plane
            | Send Reset Link

          // Divider
          .relative.my-6
            .absolute.inset-0.flex.items-center
              .w-full.border-t.border-gray-300
            .relative.flex.justify-center.text-sm
              span.px-2.bg-white.text-gray-500 or

          // Back to Login
          a.w-full.block.px-4.py-3.border.border-gray-300.text-gray-700.hover:bg-gray-50.rounded-lg.font-medium.transition.text-center(
            href="/login"
          )
            i.fas.fa-arrow-left.mr-2
            | Back to Login

        // Info Box
        .mt-8.p-4.bg-blue-50.border.border-blue-200.rounded-lg
          p.text-sm.text-blue-900
            i.fas.fa-info-circle.mr-2
            strong Didn't receive an email?
          p.text-sm.text-blue-800.mt-2
            | Check your spam folder, or try another email address associated with your account.

        // Contact Support
        .mt-4.text-center
          p.text-sm.text-gray-600
            | Still having trouble? 
            a.text-blue-600.hover:text-blue-700.font-medium(href="/contact")
              | Contact Support

block scripts
  script.
    document.getElementById('forgot-password-form')?.addEventListener('submit', function(e) {
      const email = document.getElementById('email').value;
      
      if (!email) {
        e.preventDefault();
        alert('Please enter your email address');
        return;
      }

      // Show loading state
      const button = e.target.querySelector('button[type="submit"]');
      const originalText = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<i class="fas fa-spinner animate-spin mr-2"></i>Sending...';

      // Simulate submission
      setTimeout(() => {
        button.disabled = false;
        button.innerHTML = originalText;
      }, 2000);
    });
