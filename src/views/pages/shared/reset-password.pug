extends ../../layouts/auth

block content
  .min-h-screen.bg-gradient-to-br.from-blue-600.to-blue-800.flex.items-center.justify-center.px-4.py-12
    .w-full.max-w-md
      // Card
      .bg-white.rounded-lg.shadow-lg.p-8

        // Header
        .text-center.mb-8
          .inline-block.w-12.h-12.rounded-full.bg-green-100.flex.items-center.justify-center.mb-4
            i.fas.fa-lock.text-green-600.text-xl
          h1.text-2xl.font-bold.text-gray-900 Reset Password
          p.text-gray-600.mt-2
            | Create a new password for your account

        // Alert Messages
        if error
          .mb-6.p-4.bg-red-50.border.border-red-200.rounded-lg
            p.text-sm.text-red-800
              i.fas.fa-exclamation-circle.mr-2
              = error

        if success
          .mb-6.p-4.bg-green-50.border.border-green-200.rounded-lg
            p.text-sm.text-green-800
              i.fas.fa-check-circle.mr-2
              = success

        // Form
        form.space-y-4(method="POST", action=`/reset-password/${token}`, id="reset-password-form")
          // New Password Field
          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-2(for="password")
              i.fas.fa-lock.mr-2.text-blue-600
              | New Password
            .relative
              input.form-input.w-full.px-4.py-3.border.border-gray-300.rounded-lg.focus:ring-2.focus:ring-blue-500.focus:border-transparent.transition.pr-12(
                type="password",
                id="password",
                name="password",
                placeholder="Enter new password",
                required,
                autofocus
              )
              button.absolute.right-3.top-3.text-gray-500.hover:text-gray-700(
                type="button",
                onclick="togglePasswordVisibility('password')"
              )
                i.fas.fa-eye.text-lg

            // Password Strength Indicator
            .mt-3
              p.text-xs.font-medium.text-gray-700.mb-2 Password Strength:
              .flex.gap-1
                - for (let i = 0; i < 4; i++) {
                  .flex-1.h-1.rounded-full.bg-gray-200(id=`strength-${i}`)
                - }

            // Password Requirements
            .mt-3.p-3.bg-gray-50.rounded-lg
              p.text-xs.font-medium.text-gray-700.mb-2 Requirements:
              ul.text-xs.space-y-1.text-gray-600
                li.flex.items-center.gap-2
                  .w-2.h-2.rounded-full.bg-gray-300(id="req-length")
                  | At least 8 characters
                li.flex.items-center.gap-2
                  .w-2.h-2.rounded-full.bg-gray-300(id="req-upper")
                  | One uppercase letter
                li.flex.items-center.gap-2
                  .w-2.h-2.rounded-full.bg-gray-300(id="req-lower")
                  | One lowercase letter
                li.flex.items-center.gap-2
                  .w-2.h-2.rounded-full.bg-gray-300(id="req-number")
                  | One number

          // Confirm Password Field
          .form-group
            label.block.text-sm.font-medium.text-gray-700.mb-2(for="confirmPassword")
              i.fas.fa-check-circle.mr-2.text-blue-600
              | Confirm Password
            .relative
              input.form-input.w-full.px-4.py-3.border.border-gray-300.rounded-lg.focus:ring-2.focus:ring-blue-500.focus:border-transparent.transition.pr-12(
                type="password",
                id="confirmPassword",
                name="confirmPassword",
                placeholder="Confirm your password",
                required
              )
              button.absolute.right-3.top-3.text-gray-500.hover:text-gray-700(
                type="button",
                onclick="togglePasswordVisibility('confirmPassword')"
              )
                i.fas.fa-eye.text-lg

            // Match Indicator
            p.text-xs.text-gray-500.mt-1(id="match-status")
              i.fas.fa-circle.text-gray-300.mr-2(id="match-icon")
              span(id="match-text") Passwords must match

          // Hidden Token Field
          input(type="hidden", name="token", value=token)

          // Submit Button
          button.w-full.px-4.py-3.bg-blue-600.hover:bg-blue-700.text-white.rounded-lg.font-semibold.transition.flex.items-center.justify-center.gap-2.disabled:opacity-50.disabled:cursor-not-allowed(
            type="submit",
            id="submit-button",
            disabled
          )
            i.fas.fa-shield-alt
            | Reset Password

          // Divider
          .relative.my-6
            .absolute.inset-0.flex.items-center
              .w-full.border-t.border-gray-300
            .relative.flex.justify-center.text-sm
              span.px-2.bg-white.text-gray-500 or

          // Back to Login
          a.w-full.block.px-4.py-3.border.border-gray-300.text-gray-700.hover:bg-gray-50.rounded-lg.font-medium.transition.text-center(
            href="/login"
          )
            i.fas.fa-arrow-left.mr-2
            | Back to Login

        // Security Info
        .mt-8.p-4.bg-green-50.border.border-green-200.rounded-lg
          p.text-sm.text-green-900
            i.fas.fa-shield-alt.mr-2
            strong Secure Password Reset
          p.text-sm.text-green-800.mt-2
            | This page is secured with SSL encryption. Your password is safe with us.

        // Token Info
        .mt-4.p-4.bg-yellow-50.border.border-yellow-200.rounded-lg
          p.text-sm.text-yellow-900
            i.fas.fa-clock.mr-2
            strong Link Expires
          p.text-sm.text-yellow-800.mt-2
            | This reset link will expire in 24 hours for security reasons.

block scripts
  script.
    function togglePasswordVisibility(fieldId) {
      const field = document.getElementById(fieldId);
      const icon = event.target.closest('button').querySelector('i');
      
      if (field.type === 'password') {
        field.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
      } else {
        field.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
      }
    }

    const passwordInput = document.getElementById('password');
    const confirmInput = document.getElementById('confirmPassword');
    const submitButton = document.getElementById('submit-button');

    // Password Strength Checker
    passwordInput?.addEventListener('input', function() {
      const password = this.value;
      let strength = 0;
      let requirements = {
        length: password.length >= 8,
        upper: /[A-Z]/.test(password),
        lower: /[a-z]/.test(password),
        number: /\d/.test(password)
      };

      if (requirements.length) strength++;
      if (requirements.upper) strength++;
      if (requirements.lower) strength++;
      if (requirements.number) strength++;

      // Update strength indicator
      for (let i = 0; i < 4; i++) {
        const bar = document.getElementById(`strength-${i}`);
        if (i < strength) {
          bar.className = `flex-1 h-1 rounded-full ${
            strength === 1 ? 'bg-red-500' :
            strength === 2 ? 'bg-yellow-500' :
            strength === 3 ? 'bg-blue-500' :
            'bg-green-500'
          }`;
        } else {
          bar.className = 'flex-1 h-1 rounded-full bg-gray-200';
        }
      }

      // Update requirements
      document.getElementById('req-length').className = requirements.length ? 'w-2 h-2 rounded-full bg-green-500' : 'w-2 h-2 rounded-full bg-gray-300';
      document.getElementById('req-upper').className = requirements.upper ? 'w-2 h-2 rounded-full bg-green-500' : 'w-2 h-2 rounded-full bg-gray-300';
      document.getElementById('req-lower').className = requirements.lower ? 'w-2 h-2 rounded-full bg-green-500' : 'w-2 h-2 rounded-full bg-gray-300';
      document.getElementById('req-number').className = requirements.number ? 'w-2 h-2 rounded-full bg-green-500' : 'w-2 h-2 rounded-full bg-gray-300';

      checkFormValidity();
    });

    // Password Match Checker
    confirmInput?.addEventListener('input', function() {
      const password = passwordInput.value;
      const confirm = this.value;
      const matchStatus = document.getElementById('match-status');
      const matchIcon = document.getElementById('match-icon');
      const matchText = document.getElementById('match-text');

      if (confirm.length === 0) {
        matchIcon.className = 'fas fa-circle text-gray-300 mr-2';
        matchText.textContent = 'Passwords must match';
        matchStatus.className = 'text-xs text-gray-500 mt-1';
      } else if (password === confirm) {
        matchIcon.className = 'fas fa-check-circle text-green-500 mr-2';
        matchText.textContent = 'Passwords match';
        matchStatus.className = 'text-xs text-green-600 mt-1';
      } else {
        matchIcon.className = 'fas fa-times-circle text-red-500 mr-2';
        matchText.textContent = 'Passwords do not match';
        matchStatus.className = 'text-xs text-red-600 mt-1';
      }

      checkFormValidity();
    });

    function checkFormValidity() {
      const password = passwordInput.value;
      const confirm = confirmInput.value;
      const hasMinLength = password.length >= 8;
      const hasUpper = /[A-Z]/.test(password);
      const hasLower = /[a-z]/.test(password);
      const hasNumber = /\d/.test(password);
      const passwordsMatch = password === confirm && password.length > 0;

      const isValid = hasMinLength && hasUpper && hasLower && hasNumber && passwordsMatch;
      submitButton.disabled = !isValid;
    }

    document.getElementById('reset-password-form')?.addEventListener('submit', function(e) {
      if (document.getElementById('password').value !== document.getElementById('confirmPassword').value) {
        e.preventDefault();
        alert('Passwords do not match');
        return;
      }
    });
  