extends ../../layouts/auth

block content
  .auth-card(class="p-8 sm:p-10")
    a.inline-flex.items-center.gap-2.text-sm.font-medium.mb-8(href="/auth/login" class="text-[#323842] hover:text-[#f48525]")
      i.fa-solid.fa-arrow-left
      span Quay lại đăng nhập

    .text-center.mb-8
      .inline-flex.items-center.justify-center.w-14.h-14.text-white.text-2xl.shadow-lg.mb-4(class="bg-[#f48525]")
        i.fa-solid.fa-lock
      h1(class="text-2xl sm:text-3xl font-bold text-[#0d0d0d] tracking-tight") Đặt lại mật khẩu
      p(class="text-[#323842] mt-2 text-sm sm:text-base") Tạo mật khẩu mới cho tài khoản của bạn.

    #auth-alert.hidden.mb-6.rounded-xl.px-4.py-3.text-sm.font-medium(role="alert")

    form#reset-password-form.space-y-5
      div(class="space-y-1.5")
        label.block.text-sm.font-semibold(for="password" class="text-[#181b20]") Mật khẩu mới
        .relative
          i.fa-solid.fa-lock.absolute.left-3.text-sm.pointer-events-none(class="top-1/2 -translate-y-1/2 text-[#323842]")
          input#password.auth-input.pr-12(
            type="password"
            name="password"
            placeholder="Tối thiểu 6 ký tự"
            required
            minlength="6"
            autocomplete="new-password"
          )
          button#toggle-password.absolute.right-2.p-2(type="button", aria-label="Hiện mật khẩu", class="top-1/2 -translate-y-1/2 text-[#323842] hover:text-[#0d0d0d]")
            i.fa-regular.fa-eye

      div(class="space-y-1.5")
        label.block.text-sm.font-semibold(for="passwordConfirm" class="text-[#181b20]") Xác nhận mật khẩu
        .relative
          i.fa-solid.fa-lock.absolute.left-3.text-sm.pointer-events-none(class="top-1/2 -translate-y-1/2 text-[#323842]")
          input#passwordConfirm.auth-input.pr-12(
            type="password"
            name="passwordConfirm"
            placeholder="Nhập lại mật khẩu"
            required
            minlength="6"
            autocomplete="new-password"
          )
          button#toggle-confirm.absolute.right-2.p-2(type="button", aria-label="Hiện mật khẩu", class="top-1/2 -translate-y-1/2 text-[#323842] hover:text-[#0d0d0d]")
            i.fa-regular.fa-eye
        p#match-hint.text-xs(class="text-[#8c8f95]") Mật khẩu xác nhận phải trùng khớp.

      button#reset-submit.auth-btn-primary(type="submit")
        span#reset-submit-text Cập nhật mật khẩu
        span#reset-submit-loading.hidden.items-center.gap-2
          i.fa-solid.fa-circle-notch.fa-spin
          span Đang xử lý...

block scripts
  script.
    (function () {
      var token = !{JSON.stringify(token || '')};
      var API_RESET = '/api/v1/auth/reset-password/' + encodeURIComponent(token);
      var form = document.getElementById('reset-password-form');
      var submitBtn = document.getElementById('reset-submit');
      var submitText = document.getElementById('reset-submit-text');
      var submitLoading = document.getElementById('reset-submit-loading');
      var pwd = document.getElementById('password');
      var confirmPwd = document.getElementById('passwordConfirm');
      var matchHint = document.getElementById('match-hint');

      function showAlert(type, message) {
        if (!window.AppNotify) return;
        if (type === 'error') return window.AppNotify.error(message);
        return window.AppNotify.success(message);
      }

      function setLoading(loading) {
        submitBtn.disabled = loading;
        if (loading) {
          submitText.classList.add('hidden');
          submitLoading.classList.remove('hidden');
          submitLoading.classList.add('inline-flex');
        } else {
          submitText.classList.remove('hidden');
          submitLoading.classList.add('hidden');
          submitLoading.classList.remove('inline-flex');
        }
      }

      function bindToggle(btnId, inputId) {
        var btn = document.getElementById(btnId);
        var input = document.getElementById(inputId);
        if (!btn || !input) return;
        btn.addEventListener('click', function () {
          var isPwd = input.type === 'password';
          input.type = isPwd ? 'text' : 'password';
          btn.querySelector('i').className = isPwd ? 'fa-regular fa-eye-slash' : 'fa-regular fa-eye';
        });
      }
      bindToggle('toggle-password', 'password');
      bindToggle('toggle-confirm', 'passwordConfirm');

      function updateMatchHint() {
        if (!confirmPwd.value) {
          matchHint.className = 'text-xs text-[#8c8f95]';
          matchHint.textContent = 'Mật khẩu xác nhận phải trùng khớp.';
          return;
        }
        if (pwd.value === confirmPwd.value) {
          matchHint.className = 'text-xs text-emerald-700';
          matchHint.textContent = 'Mật khẩu khớp.';
        } else {
          matchHint.className = 'text-xs text-red-700';
          matchHint.textContent = 'Mật khẩu chưa khớp.';
        }
      }
      pwd.addEventListener('input', updateMatchHint);
      confirmPwd.addEventListener('input', updateMatchHint);

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        if (!token) {
          showAlert('error', 'Token đặt lại mật khẩu không hợp lệ.');
          return;
        }
        if (pwd.value !== confirmPwd.value) {
          showAlert('error', 'Mật khẩu xác nhận không khớp.');
          return;
        }
        if (pwd.value.length < 6) {
          showAlert('error', 'Mật khẩu phải có ít nhất 6 ký tự.');
          return;
        }

        setLoading(true);
        try {
          var res = await fetch(API_RESET, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              password: pwd.value,
              passwordConfirm: confirmPwd.value
            })
          });
          var data = await res.json().catch(function () { return {}; });

          if (!res.ok) {
            throw new Error(data.message || 'Đặt lại mật khẩu thất bại.');
          }

          showAlert('success', data.message || 'Đặt lại mật khẩu thành công. Đang chuyển về đăng nhập...');
          setTimeout(function () {
            window.location.href = '/auth/login';
          }, 900);
        } catch (err) {
          showAlert('error', err.message || 'Có lỗi xảy ra.');
        } finally {
          setLoading(false);
        }
      });
    })();
