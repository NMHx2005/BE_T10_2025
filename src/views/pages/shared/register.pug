extends ../../layouts/auth

block content
  .auth-card(class="p-8 sm:p-10")
    a.inline-flex.items-center.gap-2.transition-colors.text-sm.font-medium.mb-8(href="/", class="text-[#323842] hover:text-[#f48525]")
      i.fa-solid.fa-arrow-left
      span Về trang chủ

    .text-center.mb-8
      .inline-flex.items-center.justify-center.w-14.h-14.text-white.text-2xl.shadow-lg.mb-4(class="bg-[#f48525]")
        i.fa-solid.fa-user-plus
      h1(class="text-2xl sm:text-3xl font-bold text-[#0d0d0d] tracking-tight") Tạo tài khoản
      p(class="text-[#323842] mt-2 text-sm sm:text-base") Điền thông tin bên dưới để tạo tài khoản mới.

    #auth-alert.hidden.mb-6.rounded-xl.px-4.py-3.text-sm.font-medium(role="alert")

    form#register-form.space-y-5
      .grid.gap-4(class="grid-cols-1 sm:grid-cols-2")
        div(class="space-y-1.5")
          label.block.text-sm.font-semibold(for="firstName" class="text-[#181b20]") Tên
          .relative
            i.fa-regular.fa-user.absolute.left-3.text-sm.pointer-events-none(class="top-1/2 -translate-y-1/2 text-[#323842]")
            input#firstName.auth-input(type="text", name="firstName", placeholder="Nguyễn", required, autocomplete="given-name")

        div(class="space-y-1.5")
          label.block.text-sm.font-semibold(for="lastName" class="text-[#181b20]") Họ
          .relative
            i.fa-regular.fa-user.absolute.left-3.text-sm.pointer-events-none(class="top-1/2 -translate-y-1/2 text-[#323842]")
            input#lastName.auth-input(type="text", name="lastName", placeholder="Văn A", required, autocomplete="family-name")

      div(class="space-y-1.5")
        label.block.text-sm.font-semibold(for="email" class="text-[#181b20]") Email
        .relative
          i.fa-regular.fa-envelope.absolute.left-3.text-sm.pointer-events-none(class="top-1/2 -translate-y-1/2 text-[#323842]")
          input#email.auth-input(type="email", name="email", placeholder="you@example.com", required, autocomplete="email")

      div(class="space-y-1.5")
        label.block.text-sm.font-semibold(for="password" class="text-[#181b20]") Mật khẩu
        .relative
          i.fa-solid.fa-lock.absolute.left-3.text-sm.pointer-events-none(class="top-1/2 -translate-y-1/2 text-[#323842]")
          input#password.auth-input.pr-12(type="password", name="password", placeholder="Tối thiểu 6 ký tự", required, minlength="6", autocomplete="new-password")
          button#toggle-password.auth-toggle.absolute.right-2.p-2(type="button", aria-label="Hiện mật khẩu", class="top-1/2 -translate-y-1/2 text-[#323842] hover:text-[#0d0d0d]")
            i.fa-regular.fa-eye

      div(class="space-y-1.5")
        label.block.text-sm.font-semibold(for="confirmPassword" class="text-[#181b20]") Xác nhận mật khẩu
        .relative
          i.fa-solid.fa-lock.absolute.left-3.text-sm.pointer-events-none(class="top-1/2 -translate-y-1/2 text-[#323842]")
          input#confirmPassword.auth-input.pr-12(type="password", name="confirmPassword", placeholder="Nhập lại mật khẩu", required, autocomplete="new-password")
          button#toggle-confirm.auth-toggle.absolute.right-2.p-2(type="button", aria-label="Hiện mật khẩu", class="top-1/2 -translate-y-1/2 text-[#323842] hover:text-[#0d0d0d]")
            i.fa-regular.fa-eye

      div(class="space-y-1.5")
        label.block.text-sm.font-semibold(for="company" class="text-[#181b20]") Công ty (tuỳ chọn)
        input#company.auth-input-standalone(type="text", name="company", placeholder="Tên công ty", autocomplete="organization")

      label.flex.items-start.gap-3.cursor-pointer.select-none
        input#terms.mt-1.rounded(type="checkbox", name="terms", required class="border-[#dee1e6] text-[#f48525]")
        span.text-sm(class="text-[#323842]")
          | Tôi đồng ý với
          |
          a(href="#" class="text-[#f48525] hover:underline") Điều khoản
          |
          | và
          |
          a(href="#" class="text-[#f48525] hover:underline") Chính sách bảo mật

      button#register-submit.auth-btn-primary(type="submit")
        span#register-submit-text Đăng ký
        span#register-submit-loading.hidden.items-center.gap-2
          i.fa-solid.fa-circle-notch.fa-spin
          span Đang tạo tài khoản...

    p.text-center.text-sm.mt-8(class="text-[#323842]")
      | Đã có tài khoản?
      |
      a.font-semibold.ml-1(href="/auth/login", class="text-[#f48525] hover:text-[#e07820]") Đăng nhập

block scripts
  script.
    (function () {
      var API_REGISTER = '/api/v1/auth/register';
      var form = document.getElementById('register-form');
      var submitBtn = document.getElementById('register-submit');
      var submitText = document.getElementById('register-submit-text');
      var submitLoading = document.getElementById('register-submit-loading');

      function showAlert(type, message) {
        if (!window.AppNotify) return;
        if (type === 'error') return window.AppNotify.error(message);
        return window.AppNotify.success(message);
      }

      function hideAlert() {
        return;
      }

      function formatApiError(data) {
        if (!data) return 'Đăng ký thất bại.';
        if (data.errors && Array.isArray(data.errors) && data.errors.length) {
          return data.errors.map(function (e) { return e.message || e.msg || ''; }).filter(Boolean).join(' ') || data.message;
        }
        return data.message || 'Đăng ký thất bại.';
      }

      function setLoading(loading) {
        submitBtn.disabled = loading;
        if (loading) {
          submitText.classList.add('hidden');
          submitLoading.classList.remove('hidden');
          submitLoading.classList.add('inline-flex');
        } else {
          submitText.classList.remove('hidden');
          submitLoading.classList.add('hidden');
          submitLoading.classList.remove('inline-flex');
        }
      }

      function bindToggle(btnId, inputId) {
        var btn = document.getElementById(btnId);
        var input = document.getElementById(inputId);
        if (!btn || !input) return;
        btn.addEventListener('click', function () {
          var isPwd = input.type === 'password';
          input.type = isPwd ? 'text' : 'password';
          btn.querySelector('i').className = isPwd ? 'fa-regular fa-eye-slash' : 'fa-regular fa-eye';
        });
      }
      bindToggle('toggle-password', 'password');
      bindToggle('toggle-confirm', 'confirmPassword');

      form.addEventListener('submit', async function (e) {
        e.preventDefault();
        hideAlert();

        var firstName = document.getElementById('firstName').value.trim();
        var lastName = document.getElementById('lastName').value.trim();
        var email = document.getElementById('email').value.trim();
        var password = document.getElementById('password').value;
        var confirmPassword = document.getElementById('confirmPassword').value;
        var terms = document.getElementById('terms').checked;

        if (!firstName || !lastName || !email || !password || !confirmPassword) {
          showAlert('error', 'Vui lòng điền đầy đủ các trường bắt buộc.');
          return;
        }
        if (!terms) {
          showAlert('error', 'Vui lòng đồng ý điều khoản sử dụng.');
          return;
        }
        if (password !== confirmPassword) {
          showAlert('error', 'Mật khẩu xác nhận không khớp.');
          return;
        }

        var username = (firstName + ' ' + lastName).trim();
        //- Backend + validator dùng key passwordComfirm (typo trong API)
        var body = {
          username: username,
          email: email,
          password: password,
          passwordComfirm: confirmPassword
        };

        setLoading(true);
        try {
          var res = await fetch(API_REGISTER, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          });
          var result = await res.json().catch(function () { return {}; });

          if (!res.ok) {
            throw new Error(formatApiError(result));
          }

          if (result.tokens && result.tokens.accessToken) {
            localStorage.setItem('accessToken', result.tokens.accessToken);
            localStorage.setItem('refreshToken', result.tokens.refreshToken || '');
            localStorage.setItem('user', JSON.stringify(result.user || {}));
          }

          showAlert('success', result.message || 'Đăng ký thành công. Kiểm tra email để kích hoạt tài khoản.');
          setTimeout(function () {
            window.location.href = '/';
          }, 1200);
        } catch (err) {
          showAlert('error', err.message || 'Có lỗi xảy ra.');
        } finally {
          setLoading(false);
        }
      });
    })();
